      <label>No Kotak / Pemegang</label>
      <input type="text" id="editLaporanKotakInfo" disabled style="background:#f2f6f4;color:var(--teks-muda);">
    </div>
    <div class="form-group">
      <label>Tanggal Setor</label>
      <input type="date" id="editLaporanTanggal">
    </div>

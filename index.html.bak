        <!-- ===== SUB-TAB: INPUT RKAT ===== -->
        <div id="rkatInputSub" style="display:none;">
          <div class="card" style="max-width:640px;">
            <h3 style="margin-top:0;">➕ Tambah Rencana Baru</h3>
            <input type="hidden" id="rkatId">
            <div class="form-group">
              <label>Jenis Rencana *</label>
              <select id="rkatJenis">
                <option value="Fundraising">💰 Fundraising (Rencana Pengumpulan Sumber Dana)</option>
                <option value="Pentasyarufan">🎁 Pentasyarufan (Rencana Penyaluran)</option>
              </select>
            </div>

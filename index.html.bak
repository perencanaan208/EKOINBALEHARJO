            <select id="pencairanFilterTahun" onchange="renderPencairanFiltered_()"><option value="">Semua Tahun</option></select>
            <select id="pencairanFilterJenis" onchange="renderPencairanFiltered_()">
              <option value="">Semua Jenis</option>
              <option value="UPZISNU">Kas UPZISNU</option>
              <option value="BOP">Kas BOP</option>
            </select>
          </div>

}

// Membaca file foto yang dipilih, dikompres, lalu diubah jadi base64 (data
// URL) yang disimpan sementara di hidden input supaya ikut terkirim saat
// Simpan — foto disimpan LANGSUNG sebagai teks base64 di dalam sel Google
// Sheets (bukan ke Drive), jadi HARUS dikompres dulu di browser supaya muat —
// satu sel Sheets cuma boleh ~50.000 karakter. Fungsi ini resize gambar ke
// maksimal 700px sisi terpanjang + kompres JPEG, turun kualitasnya bertahap
// kalau hasilnya masih kepanjangan, sampai muat atau sudah dicoba beberapa kali.
function compressImageForSheet_(file, onDone, onError){
  var MAX_CHARS = 45000;
  var reader = new FileReader();
  reader.onload = function(e){
    var img = new Image();
    img.onload = function(){
      var maxDim = 700;
      var w = img.width, h = img.height;
      if(w >= h){ if(w > maxDim){ h = Math.round(h * maxDim / w); w = maxDim; } }
      else { if(h > maxDim){ w = Math.round(w * maxDim / h); h = maxDim; } }

      var canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);

      var quality = 0.75;
      var dataUrl = canvas.toDataURL('image/jpeg', quality);
      var tries = 0;
      while(dataUrl.length > MAX_CHARS && tries < 6){
        quality = Math.max(quality - 0.12, 0.2);
        dataUrl = canvas.toDataURL('image/jpeg', quality);
        tries++;
      }
      if(dataUrl.length > MAX_CHARS){
        onError('Foto masih terlalu besar setelah dikompres. Coba pakai foto lain yang lebih sederhana.');
        return;
      }
      onDone(dataUrl);
    };
    img.onerror = function(){ onError('Gagal membaca file gambar. Pastikan filenya gambar yang valid.'); };
    img.src = e.target.result;
  };
  reader.onerror = function(){ onError('Gagal membaca file.'); };
  reader.readAsDataURL(file);
}

function onPentasyarufanFotoSelect_(event){
  var file = event.target.files && event.target.files[0];
  if(!file) return;
  if(!file.type.match(/^image\//)){
    showToast('File harus berupa gambar (JPG/PNG/dll).', 'error');
    event.target.value = '';
    return;
  }
  if(file.size > 15 * 1024 * 1024){
    showToast('Ukuran file maksimal 15MB (akan otomatis dikompres).', 'error');
    event.target.value = '';
    return;
  }
  compressImageForSheet_(file, function(dataUrl){
    document.getElementById('pentasyarufanFotoBase64').value = dataUrl;
    document.getElementById('pentasyarufanFotoPreview').src = dataUrl;
    document.getElementById('pentasyarufanFotoPreviewWrap').style.display = 'block';
  }, function(errMsg){
    showToast(errMsg, 'error');
    event.target.value = '';
  });
}

function hapusFotoPentasyarufanPreview_(){
  // Ini cuma menghapus PREVIEW di form (baik foto lama maupun yang baru
  // dipilih) — kosongkan saja base64-nya di form supaya foto lama yang
  // tersimpan di sheet TETAP dipakai kecuali memang diganti foto baru saat Simpan.
  document.getElementById('pentasyarufanFotoInput').value = '';
  document.getElementById('pentasyarufanFotoBase64').value = '';
  document.getElementById('pentasyarufanFotoPreviewWrap').style.display = 'none';
}

function savePentasyarufan(){
  var id = document.getElementById('pentasyarufanId').value;
  var tanggal = document.getElementById('pentasyarufanTanggal').value;
  var namaKegiatan = document.getElementById('pentasyarufanNamaKegiatan').value.trim();
  var namaPenerima = document.getElementById('pentasyarufanNamaPenerima').value.trim();
  var alamat = document.getElementById('pentasyarufanAlamat').value.trim();
  var nominal = parseRupiahInput_(document.getElementById('pentasyarufanNominal').value);
  var fotoBase64 = document.getElementById('pentasyarufanFotoBase64').value;

  if(!tanggal || !namaKegiatan || !namaPenerima || !nominal){
    showToast('Tanggal, Nama Kegiatan, Nama Penerima, dan Nominal wajib diisi.', 'error');
    return;
  }

  var payload = {
    id: id || undefined, tanggal: tanggal, namaKegiatan: namaKegiatan,
    namaPenerima: namaPenerima, alamat: alamat, nominal: nominal
  };
  if(fotoBase64) payload.fotoBase64 = fotoBase64;

  var btn = document.getElementById('btnSavePentasyarufan');
  setBtnLoading(btn, true, 'Menyimpan...');

  var fn = id ? 'updatePentasyarufan' : 'addPentasyarufan';
  callServer(fn, STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, 'Simpan');
    if(res && res.success){
      showToast(id ? 'Data pentasyarufan diperbarui.' : 'Data pentasyarufan ditambahkan.');
      closeModal('modalPentasyarufan');
      loadPentasyarufanList_();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeletePentasyarufan(id){
  openConfirm('Hapus data pentasyarufan ini beserta fotonya? Tindakan ini tidak bisa dibatalkan.', function(){
    callServer('deletePentasyarufan', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Data pentasyarufan dihapus.');
        loadPentasyarufanList_();
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ================= UPLOAD EXCEL KOTAK =================
var RAW_HEADERS = [];   // ['No Urut','No Kotak','Nama Pemegang',...]
var RAW_DATA_ROWS = []; // array of arrays (baris data, tanpa header)
var PARSED_UPLOAD_ROWS = [];

function openUploadKotakModal(){
  document.getElementById('uploadKotakFile').value = '';
  document.getElementById('uploadMappingArea').style.display = 'none';
  document.getElementById('uploadPreviewArea').style.display = 'none';
  document.getElementById('btnConfirmUpload').style.display = 'none';
  RAW_HEADERS = [];
  RAW_DATA_ROWS = [];
  PARSED_UPLOAD_ROWS = [];
  openModal('modalUploadKotak');
}

function closeUploadModal(){
  closeModal('modalUploadKotak');
}

function normalizeHeaderKey_(h){
  return String(h || '').trim().toLowerCase().replace(/[^a-z]/g, '');
}

function guessColumnIndex_(candidates){
  for(var i=0;i<RAW_HEADERS.length;i++){
    var normKey = normalizeHeaderKey_(RAW_HEADERS[i]);
    for(var j=0;j<candidates.length;j++){
      if(normKey === candidates[j]) return i;
    }
  }
  // fallback: partial match (mengandung kata kunci)
  for(var k=0;k<RAW_HEADERS.length;k++){
    var nk = normalizeHeaderKey_(RAW_HEADERS[k]);
    for(var m=0;m<candidates.length;m++){
      if(candidates[m].length >= 3 && nk.indexOf(candidates[m]) > -1) return k;
    }
  }
  return -1;
}

function columnLabel_(idx){
  var letter = String.fromCharCode(65 + (idx % 26));
  var header = RAW_HEADERS[idx];
  return (header ? header : ('Kolom ' + letter)) + ' (' + letter + ')';
}

function populateMappingSelects_(){
  var selects = [
    { id: 'mapNoKotak', candidates: ['nokotak','nomorkotak','kodekotak'], required: true },
    { id: 'mapNama', candidates: ['namapemegang','pemegang','nama'], required: true },
    { id: 'mapDusun', candidates: ['dusun'], required: true },
    { id: 'mapAlamat', candidates: ['alamat'], required: false },
    { id: 'mapPetugas', candidates: ['namapetugas','petugas','namapetuga'], required: false }
  ];

  selects.forEach(function(cfg){
    var el = document.getElementById(cfg.id);
    var options = '';
    if(!cfg.required) options += '<option value="-1">-- Tidak ada / kosongkan --</option>';
    RAW_HEADERS.forEach(function(h, idx){
      options += '<option value="' + idx + '">' + escapeHtml(columnLabel_(idx)) + '</option>';
    });
    el.innerHTML = options;
    var guess = guessColumnIndex_(cfg.candidates);
    if(guess > -1) el.value = String(guess);
    else if(!cfg.required) el.value = '-1';
  });
}

function handleExcelFileSelect(evt){
  var file = evt.target.files[0];
  if(!file) return;

  var reader = new FileReader();
  reader.onload = function(e){
    try{
      var data = new Uint8Array(e.target.result);
      var workbook = XLSX.read(data, { type: 'array' });
      var firstSheetName = workbook.SheetNames[0];
      var sheet = workbook.Sheets[firstSheetName];
      var rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '', blankrows: false });

      if(!rows.length){
        showToast('File kosong atau tidak terbaca.', 'error');
        return;
      }

      RAW_HEADERS = rows[0].map(function(h){ return String(h).trim(); });
      RAW_DATA_ROWS = rows.slice(1).filter(function(r){
        return r.some(function(cell){ return String(cell).trim() !== ''; });
      });

      if(!RAW_DATA_ROWS.length){
        showToast('Tidak ada baris data pada file ini.', 'error');
        return;
      }

      populateMappingSelects_();
      document.getElementById('uploadMappingArea').style.display = 'block';
      rebuildPreviewFromMapping();
    }catch(err){
      showToast('Gagal membaca file: ' + err.message, 'error');
    }
  };
  reader.readAsArrayBuffer(file);
}

function rebuildPreviewFromMapping(){
  var idxNoKotak = parseInt(document.getElementById('mapNoKotak').value, 10);
  var idxNama = parseInt(document.getElementById('mapNama').value, 10);
  var idxDusun = parseInt(document.getElementById('mapDusun').value, 10);
  var idxAlamat = parseInt(document.getElementById('mapAlamat').value, 10);
  var idxPetugas = parseInt(document.getElementById('mapPetugas').value, 10);

  PARSED_UPLOAD_ROWS = RAW_DATA_ROWS.map(function(r){
    return {
      noKotak: idxNoKotak > -1 ? String(r[idxNoKotak] !== undefined ? r[idxNoKotak] : '').trim() : '',
      nama: idxNama > -1 ? String(r[idxNama] !== undefined ? r[idxNama] : '').trim() : '',
      dusun: idxDusun > -1 ? String(r[idxDusun] !== undefined ? r[idxDusun] : '').trim() : '',
      alamat: idxAlamat > -1 ? String(r[idxAlamat] !== undefined ? r[idxAlamat] : '').trim() : '',
      namaPetugas: idxPetugas > -1 ? String(r[idxPetugas] !== undefined ? r[idxPetugas] : '').trim() : ''
    };
  });

  renderUploadPreview();
}

function renderUploadPreview(){
  var area = document.getElementById('uploadPreviewArea');
  var body = document.getElementById('uploadPreviewBody');
  var summary = document.getElementById('uploadSummaryText');
  var btnConfirm = document.getElementById('btnConfirmUpload');

  if(!PARSED_UPLOAD_ROWS.length){
    area.style.display = 'none';
    btnConfirm.style.display = 'none';
    return;
  }

  var invalidCount = PARSED_UPLOAD_ROWS.filter(function(r){ return !r.noKotak || !r.nama || !r.dusun; }).length;

  summary.textContent = PARSED_UPLOAD_ROWS.length + ' baris terbaca' + (invalidCount ? ', ' + invalidCount + ' baris kurang lengkap (akan dilewati saat import)' : ', semua baris lengkap') + '.';

  body.innerHTML = PARSED_UPLOAD_ROWS.slice(0, 200).map(function(r){
    var incomplete = (!r.noKotak || !r.nama || !r.dusun);
    return '<tr style="' + (incomplete ? 'background:#fdeceb;' : '') + '">' +
      '<td>' + escapeHtml(r.noKotak || '-') + '</td>' +
      '<td>' + escapeHtml(r.nama || '-') + '</td>' +
      '<td>' + escapeHtml(r.dusun || '-') + '</td>' +
      '<td>' + escapeHtml(r.alamat || '-') + '</td>' +
      '<td>' + escapeHtml(r.namaPetugas || '-') + '</td>' +
      '</tr>';
  }).join('');

  area.style.display = 'block';
  btnConfirm.style.display = 'inline-flex';
}

function confirmBulkImport(){
  if(!PARSED_UPLOAD_ROWS.length) return;
  var btn = document.getElementById('btnConfirmUpload');
  setBtnLoading(btn, true, 'Mengimpor...');

  callServer('bulkImportKotak', STATE.token, PARSED_UPLOAD_ROWS).then(function(res){
    setBtnLoading(btn, false, null, 'Import Data');
    if(res && res.success){
      var d = res.data;
      var msg = d.inserted + ' data berhasil diimpor.';
      if(d.duplicates.length) msg += ' ' + d.duplicates.length + ' dilewati (No Kotak sudah ada).';
      if(d.invalid.length) msg += ' ' + d.invalid.length + ' baris tidak lengkap dilewati.';
      showToast(msg);
      closeUploadModal();
      loadKotakView();
      loadDashboard();
    } else {
      showToast((res && res.message) || 'Gagal mengimpor data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Import Data');
    showToast('Gagal: ' + err.message, 'error');
  });
}

</script>
<script>
// ================= SETORAN VIEW (INPUT MASSAL PER BULAN & PETUGAS) =================
var MONTH_NAMES_ID = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
var STATE_SETORAN_ROWS = [];
// Harus SAMA PERSIS dengan CONFIG.SEMUA_PETUGAS_KEY di backend (Code.gs).
var SEMUA_PETUGAS_KEY_ = '__SEMUA__';
var STATE_SETORAN_IS_SEMUA = false; // true kalau filter "Petugas" sedang di "-- Semua Petugas --"
var STATE_SETORAN_MODE = 'detail';
var STATE_SETORAN_LOCK_INFO = null; // hasil getSetoranLockStatus untuk bulan+petugas yang sedang dilihat
var STATE_GLOBAL_DATA = { jumlahKotakDibuka: 0, totalNominal: 0 };
var STATE_CURRENT_TOTAL_NOMINAL = 0;

var KOIN_DENOM = [
  { key: 'k1000', label: '1.000', nilai: 1000 },
  { key: 'k500k', label: '500 KUNING', nilai: 500 },
  { key: 'k500p', label: '500 PUTIH', nilai: 500 },
  { key: 'k200', label: '200', nilai: 200 },
  { key: 'k100k', label: '100 KUNING', nilai: 100 },
  { key: 'k100p', label: '100 PUTIH', nilai: 100 }
];
var KERTAS_DENOM = [
  { key: 'r100000', label: '100.000', nilai: 100000 },
  { key: 'r50000', label: '50.000', nilai: 50000 },
  { key: 'r20000', label: '20.000', nilai: 20000 },
  { key: 'r10000', label: '10.000', nilai: 10000 },
  { key: 'r5000', label: '5.000', nilai: 5000 },
  { key: 'r2000', label: '2.000', nilai: 2000 },
  { key: 'r1000', label: '1.000', nilai: 1000 }
];
var STATE_RINCIAN_COUNTS = {};

function loadSetoranView(){
  populateBulanDropdown_();
  populatePetugasDropdown_();

  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(bulan && petugas){
    loadSetoranBulanan(bulan, petugas);
  } else {
    showSetoranEmptyPrompt_();
  }
}

function populateBulanDropdown_(){
  var sel = document.getElementById('setoranBulan');
  var current = sel.value;
  var options = '';
  var now = new Date();
  for(var i = 0; i < 12; i++){
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var y = d.getFullYear();
    var m = ('0' + (d.getMonth() + 1)).slice(-2);
    var value = y + '-' + m;
    var label = MONTH_NAMES_ID[d.getMonth()] + ' ' + y;
    options += '<option value="' + value + '">' + label + '</option>';
  }
  sel.innerHTML = options;
  sel.value = current || (now.getFullYear() + '-' + ('0'+(now.getMonth()+1)).slice(-2));
}

function populatePetugasDropdown_(){
  var sel = document.getElementById('setoranPetugas');

  // Akun Petugas hanya boleh melihat/mengisi data miliknya sendiri: dropdown
  // dikunci ke nama akun yang sedang login, tidak bisa memilih petugas lain.
  var isPetugas = STATE.session && normalizeKeyClient_(STATE.session.role) === 'petugas';
  if(isPetugas){
    var namaSendiri = STATE.session.nama || '';
    sel.innerHTML = '<option value="' + escapeHtml(namaSendiri) + '">' + escapeHtml(namaSendiri) + '</option>';
    sel.value = namaSendiri;
    sel.disabled = true;
    sel.title = 'Akun Petugas hanya dapat mengakses data miliknya sendiri.';
    return;
  }

  sel.disabled = false;
  sel.removeAttribute('title');
  var current = sel.value;
  var petugasSet = {};
  (STATE.kotakList || []).forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasSet[p] = true;
  });
  var petugasNames = Object.keys(petugasSet).sort();

  // "Semua Petugas" selalu jadi opsi pertama (dan default terpilih) untuk
  // Admin/role lain non-Petugas, supaya begitu masuk halaman Setoran Koin
  // langsung terlihat semua kotak dari semua petugas tanpa perlu memilih dulu.
  sel.innerHTML = '<option value="' + SEMUA_PETUGAS_KEY_ + '">-- Semua Petugas --</option>' +
    petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + '</option>'; }).join('');

  if(current && (current === SEMUA_PETUGAS_KEY_ || petugasNames.indexOf(current) > -1)){
    sel.value = current;
  } else {
    sel.value = SEMUA_PETUGAS_KEY_;
  }
}

function showSetoranEmptyPrompt_(){
  document.getElementById('setoranEmptyPrompt').style.display = 'block';
  document.getElementById('setoranFormArea').style.display = 'none';
  document.getElementById('setoranRecapArea').innerHTML = '';
}

function onSetoranFilterChange(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas){
    showSetoranEmptyPrompt_();
    return;
  }
  loadSetoranBulanan(bulan, petugas);
}

function loadSetoranBulanan(bulan, petugas){
  document.getElementById('setoranEmptyPrompt').style.display = 'none';
  document.getElementById('setoranFormArea').style.display = 'block';
  document.getElementById('setoranBulananBody').innerHTML =
    '<tr><td colspan="6"><div class="loading-inline"><div class="spinner-sm"></div> Memuat data...</div></td></tr>';

  STATE_SETORAN_IS_SEMUA = (petugas === SEMUA_PETUGAS_KEY_);
  document.getElementById('setoranSemuaPetugasNotice').style.display = STATE_SETORAN_IS_SEMUA ? 'block' : 'none';
  document.getElementById('thSetoranPetugas').style.display = STATE_SETORAN_IS_SEMUA ? '' : 'none';
  document.getElementById('rincianUangCard').style.display = STATE_SETORAN_IS_SEMUA ? 'none' : 'block';
  document.getElementById('btnModeGlobal').style.display = STATE_SETORAN_IS_SEMUA ? 'none' : '';

  // Input Global & Rincian Uang bersifat khusus per satu petugas (bukan
  // gabungan), jadi tidak diambil/dipakai sama sekali saat mode "Semua Petugas".
  var calls = [
    callServer('getKotakSetoranBulanan', STATE.token, { bulan: bulan, petugas: petugas }),
    callServer('getSetoranLockStatus', STATE.token, { bulan: bulan, petugas: petugas })
  ];
  if(!STATE_SETORAN_IS_SEMUA){
    calls.push(callServer('getSetoranGlobal', STATE.token, { bulan: bulan, petugas: petugas }));
    calls.push(callServer('getRincianUang', STATE.token, { bulan: bulan, petugas: petugas }));
  }

  Promise.all(calls).then(function(results){
    var resDetail = results[0];
    var resLock = results[1];
    var resGlobal = results[2];
    var resRincian = results[3];

    if(!resDetail || !resDetail.success){
      showToast((resDetail && resDetail.message) || 'Gagal memuat data.', 'error');
      showSetoranEmptyPrompt_();
      return;
    }

    STATE_SETORAN_ROWS = resDetail.data;
    STATE_SETORAN_LOCK_INFO = (resLock && resLock.success) ? resLock.data : null;
    STATE_GLOBAL_DATA = (resGlobal && resGlobal.success) ? resGlobal.data : { jumlahKotakDibuka: 0, totalNominal: 0 };
    STATE_RINCIAN_COUNTS = (resRincian && resRincian.success) ? resRincian.data.counts : {};

    if(STATE_SETORAN_IS_SEMUA){
      // Mode "Semua Petugas" cuma menampilkan rincian per kotak (gabungan
      // semua petugas), tidak ada opsi Input Global untuk kombinasi ini.
      STATE_SETORAN_MODE = 'detail';
    } else {
      // Tentukan mode default: pakai mode yang sudah punya data, jika keduanya kosong pakai detail
      var adaDetail = STATE_SETORAN_ROWS.some(function(r){ return Number(r.jumlah) > 0; });
      var adaGlobal = Number(STATE_GLOBAL_DATA.jumlahKotakDibuka) > 0 || Number(STATE_GLOBAL_DATA.totalNominal) > 0;
      STATE_SETORAN_MODE = adaGlobal && !adaDetail ? 'global' : 'detail';
    }

    renderSetoranKunciBar_();
    renderSetoranBulananTable();
    renderGlobalForm_();
    renderRincianRows_();
    switchSetoranMode(STATE_SETORAN_MODE);

    // Form dikunci (read-only) kalau akun ini memang tidak punya izin
    // tambah/edit, ATAU (mode satu petugas) Admin sudah mengunci laporan
    // bulan ini. Mode "Semua Petugas" tidak dikunci sekaligus di sini karena
    // status kuncinya bisa beda-beda per baris — lihat renderSetoranBulananTable().
    var permReadOnly = !(canDo('setoran','tambah') || canDo('setoran','edit'));
    var adminLockReadOnly = !STATE_SETORAN_IS_SEMUA && STATE_SETORAN_LOCK_INFO && STATE_SETORAN_LOCK_INFO.mode === 'satu' && STATE_SETORAN_LOCK_INFO.locked;
    applyReadOnlyLock(document.getElementById('setoranFormArea'), permReadOnly || adminLockReadOnly, ['btnModeDetail','btnModeGlobal']);
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); showSetoranEmptyPrompt_(); });
}

function switchSetoranMode(mode){
  // Mode "Input Global" tidak tersedia untuk gabungan Semua Petugas.
  if(STATE_SETORAN_IS_SEMUA) mode = 'detail';
  STATE_SETORAN_MODE = mode;
  var btnDetail = document.getElementById('btnModeDetail');
  var btnGlobal = document.getElementById('btnModeGlobal');
  var isDetail = mode === 'detail';

  document.getElementById('setoranDetailMode').style.display = isDetail ? 'block' : 'none';
  document.getElementById('setoranGlobalMode').style.display = isDetail ? 'none' : 'block';

  btnDetail.className = 'btn btn-sm ' + (isDetail ? 'btn-primary' : 'btn-outline');
  btnGlobal.className = 'btn btn-sm ' + (isDetail ? 'btn-outline' : 'btn-primary');

  renderRecapForCurrentMode_();
}

// Menampilkan badge status kunci + tombol Kunci/Buka Kunci (khusus Admin) di
// atas form Setoran Koin, sesuai STATE_SETORAN_LOCK_INFO yang baru dimuat.
function renderSetoranKunciBar_(){
  var bar = document.getElementById('setoranKunciBar');
  var badge = document.getElementById('setoranKunciBadge');
  var detail = document.getElementById('setoranKunciDetail');
  var btnKunci = document.getElementById('btnKunciSetoran');
  var btnBuka = document.getElementById('btnBukaKunciSetoran');
  var isAdmin = STATE.session && normalizeKeyClient_(STATE.session.role) === 'admin';
  var info = STATE_SETORAN_LOCK_INFO;

  if(!info){ bar.style.display = 'none'; return; }

  if(info.mode === 'semua'){
    if(!isAdmin){ bar.style.display = 'none'; return; } // badge per-baris sudah cukup untuk non-admin
    var perPetugas = info.perPetugas || {};
    var namaList = Object.keys(perPetugas);
    var terkunciCount = namaList.filter(function(n){ return perPetugas[n]; }).length;

    bar.style.display = 'flex';
    if(!namaList.length){
      badge.innerHTML = '🔓 Belum ada petugas terdaftar';
      detail.textContent = '';
      btnKunci.style.display = 'none';
      btnBuka.style.display = 'none';
    } else if(info.semuaTerkunci){
      badge.innerHTML = '🔒 <span style="color:var(--merah);">Semua petugas terkunci bulan ini</span>';
      detail.textContent = 'Petugas tidak bisa tambah/edit/hapus data sampai dibuka kuncinya.';
      btnKunci.style.display = 'none';
      btnBuka.style.display = '';
      btnBuka.textContent = '🔓 Buka Semua Kunci';
    } else if(terkunciCount > 0){
      badge.innerHTML = '🔒 <span style="color:var(--emas);">' + terkunciCount + ' dari ' + namaList.length + ' petugas sudah terkunci</span>';
      detail.textContent = 'Baris kotak milik petugas yang terkunci ditandai 🔒 di tabel bawah.';
      btnKunci.style.display = '';
      btnKunci.textContent = '🔒 Kunci Sisanya (' + (namaList.length - terkunciCount) + ' Petugas)';
      btnBuka.style.display = '';
      btnBuka.textContent = '🔓 Buka Semua Kunci';
    } else {
      badge.innerHTML = '🔓 <span style="color:var(--hijau-tua);">Belum ada petugas yang dikunci</span>';
      detail.textContent = 'Kunci laporan kalau data semua petugas sudah diverifikasi benar.';
      btnKunci.style.display = '';
      btnKunci.textContent = '🔒 Kunci Semua Petugas';
      btnBuka.style.display = 'none';
    }
    return;
  }

  // mode 'satu' (satu petugas spesifik)
  var locked = !!info.locked;
  if(!locked && !isAdmin){ bar.style.display = 'none'; return; } // tidak perlu tampil kalau tidak dikunci & bukan admin
  bar.style.display = 'flex';
  badge.innerHTML = locked
    ? '🔒 <span style="color:var(--merah);">Laporan bulan ini TERKUNCI</span>'
    : '🔓 <span style="color:var(--hijau-tua);">Laporan bulan ini masih terbuka</span>';
  detail.textContent = locked
    ? 'Tambah/edit/hapus data setoran, input global, dan rincian uang untuk bulan ini dinonaktifkan sampai Admin membuka kunci.'
    : (isAdmin ? 'Kunci laporan ini kalau data sudah diverifikasi benar.' : '');
  btnKunci.style.display = (isAdmin && !locked) ? '' : 'none';
  btnKunci.textContent = '🔒 Kunci Laporan Ini';
  btnBuka.style.display = (isAdmin && locked) ? '' : 'none';
  btnBuka.textContent = '🔓 Buka Kunci';
}

function kunciSetoranHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas) return;
  var pesan = STATE_SETORAN_IS_SEMUA
    ? 'Kunci laporan setoran SEMUA petugas untuk bulan ini? Setelah dikunci, petugas tidak bisa lagi tambah/edit/hapus data setoran bulan ini sampai Anda membuka kuncinya lagi.'
    : 'Kunci laporan setoran ' + petugas + ' untuk bulan ini? Setelah dikunci, petugas tidak bisa lagi tambah/edit/hapus data setoran bulan ini sampai Anda membuka kuncinya lagi.';
  openConfirm(pesan, function(){
    callServer('lockSetoranBulan', STATE.token, { bulan: bulan, petugas: petugas }).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Laporan berhasil dikunci' + (res.data.jumlahDikunci ? ' (' + res.data.jumlahDikunci + ' petugas).' : '.'));
        loadSetoranBulanan(bulan, petugas);
      } else {
        showToast((res && res.message) || 'Gagal mengunci laporan.', 'error');
      }
    }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
  }, 'Ya, Kunci', 'Batal');
}

function bukaKunciSetoranHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas) return;
  var pesan = STATE_SETORAN_IS_SEMUA
    ? 'Buka kunci laporan setoran SEMUA petugas untuk bulan ini? Petugas akan bisa tambah/edit/hapus data setoran bulan ini lagi.'
    : 'Buka kunci laporan setoran ' + petugas + ' untuk bulan ini? Petugas akan bisa tambah/edit/hapus data setoran bulan ini lagi.';
  openConfirm(pesan, function(){
    callServer('unlockSetoranBulan', STATE.token, { bulan: bulan, petugas: petugas }).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Kunci berhasil dibuka.');
        loadSetoranBulanan(bulan, petugas);
      } else {
        showToast((res && res.message) || 'Gagal membuka kunci.', 'error');
      }
    }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
  }, 'Ya, Buka Kunci', 'Batal');
}

function renderSetoranBulananTable(){
  var emptyMsg = STATE_SETORAN_IS_SEMUA ? 'Belum ada kotak aktif terdaftar.' : 'Belum ada kotak terdaftar untuk petugas ini.';
  if(!STATE_SETORAN_ROWS.length){
    document.getElementById('setoranBulananBody').innerHTML = '<tr><td colspan="6">' + emptyState(emptyMsg) + '</td></tr>';
    document.getElementById('setoranCardsMobile').innerHTML = emptyState(emptyMsg);
    return;
  }

  // Tabel desktop (>860px) — tetap pakai <table> asli.
  document.getElementById('setoranBulananBody').innerHTML = STATE_SETORAN_ROWS.map(function(r, idx){
    var rowLocked = isSetoranRowLocked_(r);
    var inputAttrs = rowLocked
      ? ' class="setor-input-desktop setor-locked" disabled title="Terkunci Admin"'
      : ' class="setor-input-desktop ' + (r.jumlah > 0 ? 'setor-filled' : 'setor-empty') + '" oninput="onSetoranRowInputChange_(this, ' + idx + ')"';
    return '<tr>' +
      '<td><b>' + escapeHtml(r.noKotak) + '</b></td>' +
      (STATE_SETORAN_IS_SEMUA ? '<td>' + escapeHtml(r.petugas || '-') + (rowLocked ? ' 🔒' : '') + '</td>' : '') +
      '<td>' + escapeHtml(r.nama) + '</td>' +
      '<td>' + escapeHtml(r.dusun) + '</td>' +
      '<td>' + escapeHtml(r.alamat || '-') + '</td>' +
      '<td><input type="text" inputmode="numeric" placeholder="0" value="' + (r.jumlah > 0 ? formatAngka(r.jumlah) : '') + '"' +
        inputAttrs + ' data-row-idx="' + idx + '"></td>' +
      '</tr>';
  }).join('');

  // Kartu HP (≤860px) — <div> biasa, sama sekali bukan elemen tabel, supaya
  // tidak mungkin kena keanehan lebar bawaan tabel di browser/WebView tertentu.
  document.getElementById('setoranCardsMobile').innerHTML = STATE_SETORAN_ROWS.map(function(r, idx){
    var rowLocked = isSetoranRowLocked_(r);
    var inputAttrs = rowLocked
      ? ' class="setor-locked" disabled title="Terkunci Admin"'
      : ' class="' + (r.jumlah > 0 ? 'setor-filled' : 'setor-empty') + '" oninput="onSetoranRowInputChange_(this, ' + idx + ')"';
    return '<div class="skoin-card">' +
      '<div class="skoin-field"><div class="skoin-field-label">No Kotak</div><div class="skoin-field-value"><b>' + escapeHtml(r.noKotak) + '</b></div></div>' +
      (STATE_SETORAN_IS_SEMUA ? '<div class="skoin-field"><div class="skoin-field-label">Petugas</div><div class="skoin-field-value">' + escapeHtml(r.petugas || '-') + (rowLocked ? ' 🔒' : '') + '</div></div>' : '') +
      '<div class="skoin-field"><div class="skoin-field-label">Nama Pemegang</div><div class="skoin-field-value">' + escapeHtml(r.nama) + '</div></div>' +
      '<div class="skoin-field"><div class="skoin-field-label">Dusun</div><div class="skoin-field-value">' + escapeHtml(r.dusun) + '</div></div>' +
      '<div class="skoin-field"><div class="skoin-field-label">Alamat</div><div class="skoin-field-value">' + escapeHtml(r.alamat || '-') + '</div></div>' +
      '<div class="skoin-field"><div class="skoin-field-label">Jumlah Setor (Rp)</div><div class="skoin-field-value">' +
        '<input type="text" inputmode="numeric" placeholder="0" value="' + (r.jumlah > 0 ? formatAngka(r.jumlah) : '') + '"' +
        inputAttrs + ' data-row-idx="' + idx + '"></div></div>' +
      '</div>';
  }).join('');
}

// Baris terkunci hanya relevan di mode "Semua Petugas" (kuncinya per petugas,
// jadi bisa beda-beda antar baris). Di mode 1 petugas, kunci diterapkan ke
// seluruh form lewat applyReadOnlyLock, jadi fungsi ini selalu false di situ.
function isSetoranRowLocked_(row){
  if(!STATE_SETORAN_IS_SEMUA) return false;
  if(!STATE_SETORAN_LOCK_INFO || STATE_SETORAN_LOCK_INFO.mode !== 'semua') return false;
  var perPetugas = STATE_SETORAN_LOCK_INFO.perPetugas || {};
  return !!perPetugas[row.petugas];
}

// Membersihkan input jadi angka murni (buang semua selain digit).
function parseRupiahInput_(raw){
  var digits = String(raw || '').replace(/[^\d]/g, '');
  return digits ? Number(digits) : 0;
}

// Dipakai lewat oninput="liveFormatRupiah_(this)" pada input nominal biasa
// (Kas, Pencairan Dana, Pentasyarufan, dst) supaya otomatis jadi format
// ribuan "1.234.567" begitu diketik, sama seperti input Jumlah Setor.
function liveFormatRupiah_(el){
  var value = parseRupiahInput_(el.value);
  el.value = value > 0 ? formatAngka(value) : '';
}

// Format ulang input nominal koin jadi "1.234.567" (format ribuan Indonesia)
// setiap kali diketik, supaya lebih mudah dibaca petugas saat input setoran.
function onSetoranRowInputChange_(el, idx){
  var value = parseRupiahInput_(el.value);
  el.value = value > 0 ? formatAngka(value) : '';
  el.classList.toggle('setor-filled', value > 0);
  el.classList.toggle('setor-empty', value <= 0);
  updateSetoranRowValue(idx, value);
}

function updateSetoranRowValue(idx, value){
  STATE_SETORAN_ROWS[idx].jumlah = Number(value) || 0;
  if(STATE_SETORAN_MODE === 'detail') renderRecapForCurrentMode_();
}

function renderGlobalForm_(){
  document.getElementById('globalJumlahKotak').value = STATE_GLOBAL_DATA.jumlahKotakDibuka > 0 ? STATE_GLOBAL_DATA.jumlahKotakDibuka : '';
  document.getElementById('globalTotalNominal').value = STATE_GLOBAL_DATA.totalNominal > 0 ? formatAngka(STATE_GLOBAL_DATA.totalNominal) : '';
  document.getElementById('globalTotalKotakInfo').textContent = ' Total kotak terdaftar untuk petugas ini: ' + STATE_SETORAN_ROWS.length + ' kotak.';
  document.getElementById('globalJumlahKotak').max = STATE_SETORAN_ROWS.length;

  var adaDataGlobal = Number(STATE_GLOBAL_DATA.jumlahKotakDibuka) > 0 || Number(STATE_GLOBAL_DATA.totalNominal) > 0;
  document.getElementById('btnHapusGlobal').style.display = (adaDataGlobal && canDo('setoran','hapus')) ? 'block' : 'none';
}

function onGlobalInputChange(){
  STATE_GLOBAL_DATA.jumlahKotakDibuka = Number(document.getElementById('globalJumlahKotak').value) || 0;
  STATE_GLOBAL_DATA.totalNominal = parseRupiahInput_(document.getElementById('globalTotalNominal').value);
  renderRecapForCurrentMode_();
}

// Format ulang input "Jumlah Total Koin (Rp)" jadi angka ribuan saat diketik.
function onGlobalNominalInputChange_(el){
  var value = parseRupiahInput_(el.value);
  el.value = value > 0 ? formatAngka(value) : '';
  STATE_GLOBAL_DATA.totalNominal = value;
  renderRecapForCurrentMode_();
}

function renderRecapForCurrentMode_(){
  var totalKotak = STATE_SETORAN_ROWS.length;
  var sudah, belum, totalNominal;

  if(STATE_SETORAN_MODE === 'global'){
    sudah = Math.min(Number(STATE_GLOBAL_DATA.jumlahKotakDibuka) || 0, totalKotak);
    belum = Math.max(totalKotak - sudah, 0);
    totalNominal = Number(STATE_GLOBAL_DATA.totalNominal) || 0;
  } else {
    sudah = STATE_SETORAN_ROWS.filter(function(r){ return Number(r.jumlah) > 0; }).length;
    belum = totalKotak - sudah;
    totalNominal = STATE_SETORAN_ROWS.reduce(function(sum, r){ return sum + (Number(r.jumlah) > 0 ? Number(r.jumlah) : 0); }, 0);
  }

  var bisaroh = sudah * 1000;
  var uangDisetor = Math.max(totalNominal - bisaroh, 0);
  STATE_CURRENT_TOTAL_NOMINAL = uangDisetor;

  document.getElementById('setoranRecapArea').innerHTML =
    '<div class="stat-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr));">' +
    statCard('✅', 'Kotak Sudah Setor', sudah, 'dari ' + totalKotak + ' kotak') +
    statCard('⏳', 'Kotak Belum Setor', belum, '', false) +
    statCard('💰', 'Total Terkumpul', formatRupiah(totalNominal), '', true) +
    statCard('🎯', 'Bisaroh', formatRupiah(bisaroh), '1.000 x ' + sudah + ' kotak') +
    statCard('💵', 'Uang Disetorkan', formatRupiah(uangDisetor), 'Total Terkumpul − Bisaroh', true) +
    '</div>';

  renderRincianNotif_();
}

function saveSetoranBulananHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas || !STATE_SETORAN_ROWS.length) return;

  var btn = document.getElementById('btnSimpanSetoranBulanan');
  setBtnLoading(btn, true, 'Menyimpan...');

  var payload = {
    bulan: bulan,
    petugas: petugas,
    rows: STATE_SETORAN_ROWS.map(function(r){ return { noKotak: r.noKotak, jumlah: r.jumlah }; })
  };

  callServer('saveSetoranBulanan', STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan Semua');
    if(res && res.success){
      var msg = 'Tersimpan: ' + res.data.updated + ' diperbarui, ' + res.data.inserted + ' baru, ' + res.data.deleted + ' dihapus.';
      if(res.data.skippedLocked){
        msg += ' ' + res.data.skippedLocked + ' baris dilewati karena sudah dikunci (' + res.data.skippedLockedPetugas.join(', ') + ').';
      }
      showToast(msg);
      loadSetoranBulanan(bulan, petugas);
      loadDashboard();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan Semua');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function saveSetoranGlobalHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas) return;

  var btn = document.getElementById('btnSimpanGlobal');
  setBtnLoading(btn, true, 'Menyimpan...');

  var payload = {
    bulan: bulan,
    petugas: petugas,
    jumlahKotakDibuka: STATE_GLOBAL_DATA.jumlahKotakDibuka,
    totalNominal: STATE_GLOBAL_DATA.totalNominal
  };

  callServer('saveSetoranGlobal', STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan Input Global');
    if(res && res.success){
      showToast('Input global tersimpan.');
      loadSetoranBulanan(bulan, petugas);
      loadDashboard();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan Input Global');
    showToast('Gagal: ' + err.message, 'error');
  });
}

// Menghapus input global bulan ini (kirim jumlah=0 & nominal=0 ke endpoint
// yang sama — backend otomatis menghapus barisnya kalau keduanya nol).
function hapusSetoranGlobalHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas) return;

  openConfirm('Hapus input global bulan ini untuk ' + petugas + '? Tindakan ini tidak bisa dibatalkan.', function(){
    var btn = document.getElementById('btnHapusGlobal');
    setBtnLoading(btn, true, 'Menghapus...');
    callServer('saveSetoranGlobal', STATE.token, { bulan: bulan, petugas: petugas, jumlahKotakDibuka: 0, totalNominal: 0 }).then(function(res){
      setBtnLoading(btn, false, null, '🗑️ Hapus Input Global');
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Input global dihapus.');
        STATE_GLOBAL_DATA = { jumlahKotakDibuka: 0, totalNominal: 0 };
        document.getElementById('globalJumlahKotak').value = '';
        document.getElementById('globalTotalNominal').value = '';
        loadSetoranBulanan(bulan, petugas);
        loadDashboard();
      } else {
        showToast((res && res.message) || 'Gagal menghapus data.', 'error');
      }
    }).catch(function(err){
      setBtnLoading(btn, false, null, '🗑️ Hapus Input Global');
      closeModal('modalConfirm');
      showToast('Gagal: ' + err.message, 'error');
    });
  });
}

// ================= RINCIAN UANG (Koin & Kertas) =================
function renderDenomRows_(containerId, denomList){
  var html = denomList.map(function(d){
    var val = STATE_RINCIAN_COUNTS[d.key] || 0;
    return '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">' +
      '<div style="width:88px;font-size:12.5px;color:var(--teks-muda);flex-shrink:0;">' + escapeHtml(d.label) + '</div>' +
      '<span style="font-size:12.5px;color:var(--teks-muda);">Rp</span>' +
      '<input type="text" inputmode="numeric" placeholder="0" value="' + (val > 0 ? formatAngka(val) : '') +
        '" class="denom-input ' + (val > 0 ? 'setor-filled' : 'setor-empty') + '" ' +
        'oninput="onRincianInputChange_(this, \'' + d.key + '\')">' +
      '</div>';
  }).join('');

  var total = denomList.reduce(function(sum, d){ return sum + (STATE_RINCIAN_COUNTS[d.key] || 0); }, 0);
  html += '<div style="display:flex;justify-content:space-between;padding-top:8px;margin-top:4px;border-top:1.5px solid #e9efec;font-weight:700;font-size:13px;color:var(--hijau-tua);">' +
    '<span>Total</span><span id="' + containerId + '_total">' + formatRupiah(total) + '</span></div>';

  document.getElementById(containerId).innerHTML = html;
}

function renderRincianRows_(){
  renderDenomRows_('rincianKoinRows', KOIN_DENOM);
  renderDenomRows_('rincianKertasRows', KERTAS_DENOM);
}

// Format ulang input rincian uang jadi "1.234.567" (format ribuan Indonesia)
// setiap kali diketik, sekaligus menandai warna kotak sudah/belum diisi
// (sama seperti input Jumlah Setor — lihat .setor-filled/.setor-empty).
function onRincianInputChange_(el, key){
  var value = parseRupiahInput_(el.value);
  el.value = value > 0 ? formatAngka(value) : '';
  el.classList.toggle('setor-filled', value > 0);
  el.classList.toggle('setor-empty', value <= 0);
  updateRincianValue(key, value);
}

function updateRincianValue(key, value){
  STATE_RINCIAN_COUNTS[key] = Number(value) || 0;

  var totalKoin = KOIN_DENOM.reduce(function(sum, d){ return sum + (STATE_RINCIAN_COUNTS[d.key] || 0); }, 0);
  var totalKertas = KERTAS_DENOM.reduce(function(sum, d){ return sum + (STATE_RINCIAN_COUNTS[d.key] || 0); }, 0);
  document.getElementById('rincianKoinRows_total').textContent = formatRupiah(totalKoin);
  document.getElementById('rincianKertasRows_total').textContent = formatRupiah(totalKertas);

  renderRincianNotif_();
}

function hitungTotalRincianClient_(){
  return KOIN_DENOM.concat(KERTAS_DENOM).reduce(function(sum, d){
    return sum + (STATE_RINCIAN_COUNTS[d.key] || 0);
  }, 0);
}

function renderRincianNotif_(){
  var el = document.getElementById('rincianNotifArea');
  if(!el) return;

  var totalRincian = hitungTotalRincianClient_();
  var totalSetoran = STATE_CURRENT_TOTAL_NOMINAL || 0;
  var selisih = totalRincian - totalSetoran;

  if(totalRincian === 0 && totalSetoran === 0){
    el.innerHTML = '';
    return;
  }

  if(selisih === 0){
    el.innerHTML = '<div style="background:#d9f2e3;color:var(--hijau-tua);padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;">' +
      '✅ Sudah sesuai — Rincian uang (' + formatRupiah(totalRincian) + ') sama dengan jumlah setoran (' + formatRupiah(totalSetoran) + ').</div>';
  } else {
    var label = selisih > 0 ? 'lebih' : 'kurang';
    el.innerHTML = '<div style="background:#fdeceb;color:var(--merah);padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;">' +
      '⚠️ Belum sesuai — Rincian uang (' + formatRupiah(totalRincian) + ') ' + label + ' ' + formatRupiah(Math.abs(selisih)) +
      ' dari jumlah setoran (' + formatRupiah(totalSetoran) + ').</div>';
  }
}

function saveRincianUangHandler(){
  var bulan = document.getElementById('setoranBulan').value;
  var petugas = document.getElementById('setoranPetugas').value;
  if(!bulan || !petugas) return;

  var btn = document.getElementById('btnSimpanRincian');
  setBtnLoading(btn, true, 'Menyimpan...');

  callServer('saveRincianUang', STATE.token, { bulan: bulan, petugas: petugas, counts: STATE_RINCIAN_COUNTS }).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan Rincian Uang');
    if(res && res.success){
      showToast('Rincian uang tersimpan.');
    } else {
      showToast((res && res.message) || 'Gagal menyimpan rincian uang.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan Rincian Uang');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function handleFabClick(){
  if(STATE.currentView === 'setoran'){
    if(!STATE_SETORAN_ROWS.length){ showToast('Pilih bulan dan petugas terlebih dahulu.', 'error'); return; }
    if(STATE_SETORAN_MODE === 'global') saveSetoranGlobalHandler();
    else saveSetoranBulananHandler();
  } else {
    switchView('setoran');
  }
}

// ================= RKAT (RENCANA KERJA & ANGGARAN TAHUNAN) =================
function loadRkatView(){
  switchRkatSubTab_(STATE_RKAT_TAB);
}

function switchRkatSubTab_(tab){
  STATE_RKAT_TAB = tab;
  document.getElementById('rkatInputSub').style.display = tab === 'input' ? 'block' : 'none';
  document.getElementById('rkatDataSub').style.display = tab === 'data' ? 'block' : 'none';
  document.getElementById('rkatRealisasiSub').style.display = tab === 'realisasi' ? 'block' : 'none';

  var judul = { input: 'Input RKAT', data: 'Data RKAT', realisasi: 'Realisasi Anggaran' };
  var subjudul = {
    input: 'Masukkan rencana Fundraising (target pengumpulan sumber dana) atau Pentasyarufan (target penyaluran)',
    data: 'Rekap seluruh rencana RKAT yang sudah diinput',
    realisasi: 'Bandingkan rencana awal dengan realisasi aktual — kurang/lebih anggaran'
  };
  document.getElementById('rkatViewTitle').textContent = judul[tab] || 'RKAT';
  document.getElementById('rkatViewSubtitle').textContent = subjudul[tab] || '';

  if(tab === 'input') resetRkatInputForm_();
  loadRkatList_();
}

// Data RKAT dipakai bersama oleh 3 sub-tab (Input butuh daftar tahun yang
// sudah ada, Data & Realisasi butuh seluruh rekapnya) — jadi cukup satu kali
// fetch, lalu render ulang sub-tab yang lagi aktif.
function loadRkatList_(){
  callServer('getRkatList', STATE.token).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat data RKAT.', 'error');
      return;
    }
    STATE_RKAT_DATA = res.data.rows;
    if(STATE_RKAT_TAB === 'data'){
      populateRkatFilterDropdowns_('rkatData');
      renderRkatDataFiltered_();
    }
    if(STATE_RKAT_TAB === 'realisasi'){
      populateRkatFilterDropdowns_('rkatRealisasi');
      renderRkatRealisasiFiltered_();
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function populateRkatFilterDropdowns_(prefix){
  var tahunSel = document.getElementById(prefix + 'FilterTahun');
  var currentTahun = tahunSel.value;
  var tahunSet = {};
  STATE_RKAT_DATA.forEach(function(r){ if(r.tahun) tahunSet[r.tahun] = true; });
  tahunSet[String(new Date().getFullYear())] = true;
  var tahunList = Object.keys(tahunSet).sort().reverse();
  tahunSel.innerHTML = '<option value="">Semua Tahun</option>' +
    tahunList.map(function(y){ return '<option value="' + y + '">' + y + '</option>'; }).join('');
  if(currentTahun && tahunList.indexOf(currentTahun) > -1) tahunSel.value = currentTahun;
}

// ---- Sub-tab: Input RKAT ----
function resetRkatInputForm_(){
  document.getElementById('rkatId').value = '';
  document.getElementById('rkatJenis').value = 'Fundraising';
  document.getElementById('rkatTahun').value = new Date().getFullYear();
  document.getElementById('rkatNamaKegiatan').value = '';
  document.getElementById('rkatTargetAnggaran').value = '';
  document.getElementById('rkatKeterangan').value = '';
  document.getElementById('rkatBatalEditBtn').style.display = 'none';
}

function saveRkatHandler_(){
  var id = document.getElementById('rkatId').value;
  var payload = {
    id: id,
    jenis: document.getElementById('rkatJenis').value,
    tahun: document.getElementById('rkatTahun').value,
    namaKegiatan: document.getElementById('rkatNamaKegiatan').value.trim(),
    targetAnggaran: parseRupiahInput_(document.getElementById('rkatTargetAnggaran').value),
    keterangan: document.getElementById('rkatKeterangan').value.trim()
  };
  if(!payload.namaKegiatan || !payload.targetAnggaran || !payload.tahun){
    showToast('Tahun, Nama Kegiatan, dan Target Anggaran wajib diisi.', 'error');
    return;
  }
  callServer(id ? 'updateRkat' : 'addRkat', STATE.token, payload).then(function(res){
    if(res && res.success){
      showToast(id ? 'Rencana RKAT diperbarui.' : 'Rencana RKAT tersimpan.');
      resetRkatInputForm_();
      loadRkatList_();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan RKAT.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function editRkatHandler_(id){
  var row = STATE_RKAT_DATA.find(function(x){ return x.id === id; });
  if(!row) return;
  switchViewSubTab_('rkat', 'input');
  document.getElementById('rkatId').value = row.id;
  document.getElementById('rkatJenis').value = row.jenis;
  document.getElementById('rkatTahun').value = row.tahun;
  document.getElementById('rkatNamaKegiatan').value = row.namaKegiatan;
  document.getElementById('rkatTargetAnggaran').value = formatAngka(row.targetAnggaran);
  document.getElementById('rkatKeterangan').value = row.keterangan || '';
  document.getElementById('rkatBatalEditBtn').style.display = 'inline-block';
}

function confirmDeleteRkat_(id){
  openConfirm('Hapus rencana RKAT ini? Data realisasi yang sudah diisi juga akan ikut terhapus.', function(){
    callServer('deleteRkat', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Rencana RKAT dihapus.');
        loadRkatList_();
      } else {
        showToast((res && res.message) || 'Gagal menghapus RKAT.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ---- Sub-tab: Data RKAT ----
function renderRkatDataFiltered_(){
  var tahun = document.getElementById('rkatDataFilterTahun').value;
  var jenis = document.getElementById('rkatDataFilterJenis').value;
  var rows = STATE_RKAT_DATA.filter(function(r){
    if(tahun && r.tahun !== tahun) return false;
    if(jenis && r.jenis !== jenis) return false;
    return true;
  });

  var totalFundraising = 0, totalPentasyarufan = 0;
  rows.forEach(function(r){
    if(r.jenis === 'Fundraising') totalFundraising += r.targetAnggaran;
    else totalPentasyarufan += r.targetAnggaran;
  });
  document.getElementById('rkatDataStatGrid').innerHTML =
    statCard('💰', 'Target Fundraising', formatRupiah(totalFundraising), rows.filter(function(r){ return r.jenis === 'Fundraising'; }).length + ' rencana', true) +
    statCard('🎁', 'Target Pentasyarufan', formatRupiah(totalPentasyarufan), rows.filter(function(r){ return r.jenis === 'Pentasyarufan'; }).length + ' rencana');

  document.getElementById('rkatDataTableBody').innerHTML = rows.length ? rows.map(function(r, idx){
    return '<tr>' +
      '<td>' + (idx + 1) + '</td>' +
      '<td>' + r.tahun + '</td>' +
      '<td>' + (r.jenis === 'Fundraising' ? '💰 Fundraising' : '🎁 Pentasyarufan') + '</td>' +
      '<td>' + escapeHtml(r.namaKegiatan) + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.targetAnggaran) + '</td>' +
      '<td>' + escapeHtml(r.keterangan || '-') + '</td>' +
      '<td class="row-actions">' +
        (canDo('rkat_input','edit') ? '<button class="icon-btn" onclick="editRkatHandler_(\'' + r.id + '\')" title="Edit">✏️</button>' : '') +
        (canDo('rkat_input','hapus') ? '<button class="icon-btn" onclick="confirmDeleteRkat_(\'' + r.id + '\')" title="Hapus">🗑️</button>' : '') +
      '</td>' +
      '</tr>';
  }).join('') : '<tr><td colspan="7" style="text-align:center;color:var(--teks-muda);padding:24px;">Belum ada data RKAT untuk filter ini.</td></tr>';

  var teksTahun = tahun ? ('Tahun ' + tahun) : 'Semua Tahun';
  var teksJenis = jenis ? (' • Jenis: ' + jenis) : '';
  document.getElementById('rkatDataPrintFilterInfo').textContent = teksTahun + teksJenis;
}

function cetakRkatDataPDF_(){
  if(!STATE_RKAT_DATA.length){
    showToast('Belum ada data RKAT untuk dicetak.', 'error');
    return;
  }
  window.print();
}

// ---- Sub-tab: Realisasi Anggaran ----
function renderRkatRealisasiFiltered_(){
  var tahun = document.getElementById('rkatRealisasiFilterTahun').value;
  var jenis = document.getElementById('rkatRealisasiFilterJenis').value;
  var kegiatan = normalizeKeyClient_(document.getElementById('rkatRealisasiFilterKegiatan').value);
  var rows = STATE_RKAT_DATA.filter(function(r){
    if(tahun && r.tahun !== tahun) return false;
    if(jenis && r.jenis !== jenis) return false;
    if(kegiatan && normalizeKeyClient_(r.namaKegiatan).indexOf(kegiatan) === -1) return false;
    return true;
  });

  var totalRencana = 0, totalRealisasi = 0;
  rows.forEach(function(r){ totalRencana += r.targetAnggaran; totalRealisasi += r.realisasi; });
  var totalSelisih = totalRealisasi - totalRencana;
  document.getElementById('rkatRealisasiStatGrid').innerHTML =
    statCard('📋', 'Total Rencana', formatRupiah(totalRencana), rows.length + ' kegiatan', true) +
    statCard('✅', 'Total Realisasi', formatRupiah(totalRealisasi)) +
    statCard(totalSelisih >= 0 ? '📈' : '📉', totalSelisih >= 0 ? 'Lebih Anggaran' : 'Kurang Anggaran', formatRupiah(Math.abs(totalSelisih)));

  document.getElementById('rkatRealisasiTableBody').innerHTML = rows.length ? rows.map(function(r, idx){
    var selisihWarna = r.selisih > 0 ? 'var(--hijau)' : (r.selisih < 0 ? 'var(--merah)' : 'inherit');
    var selisihLabel = (r.selisih > 0 ? '+' : '') + formatAngka(r.selisih);
    return '<tr>' +
      '<td>' + (idx + 1) + '</td>' +
      '<td>' + r.tahun + '</td>' +
      '<td>' + (r.jenis === 'Fundraising' ? '💰 Fundraising' : '🎁 Pentasyarufan') + '</td>' +
      '<td>' + escapeHtml(r.namaKegiatan) + '</td>' +
      '<td style="text-align:right;">' + formatRupiah(r.targetAnggaran) + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.realisasi) + '</td>' +
      '<td style="text-align:right;font-weight:700;color:' + selisihWarna + ';">Rp ' + selisihLabel + '</td>' +
      '<td class="row-actions">' +
        (canDo('rkat_realisasi','edit') ? '<button class="icon-btn" onclick="openUpdateRealisasiModal_(\'' + r.id + '\')" title="Update Realisasi">✏️</button>' : '') +
      '</td>' +
      '</tr>';
  }).join('') : '<tr><td colspan="8" style="text-align:center;color:var(--teks-muda);padding:24px;">Belum ada data RKAT untuk filter ini.</td></tr>';

  var teksTahun = tahun ? ('Tahun ' + tahun) : 'Semua Tahun';
  var teksJenis = jenis ? (' • Jenis: ' + jenis) : '';
  var teksKegiatan = kegiatan ? (' • Kegiatan: ' + document.getElementById('rkatRealisasiFilterKegiatan').value) : '';
  document.getElementById('rkatRealisasiPrintFilterInfo').textContent = teksTahun + teksJenis + teksKegiatan;
}

function openUpdateRealisasiModal_(id){
  var row = STATE_RKAT_DATA.find(function(x){ return x.id === id; });
  if(!row) return;
  document.getElementById('rkatRealisasiId').value = row.id;
  document.getElementById('rkatRealisasiNamaKegiatan').value = row.namaKegiatan;
  document.getElementById('rkatRealisasiTarget').value = formatRupiah(row.targetAnggaran);
  document.getElementById('rkatRealisasiNominal').value = row.realisasi > 0 ? formatAngka(row.realisasi) : '';
  openModal('modalRkatRealisasi');
}

function saveRealisasiRkatHandler_(){
  var payload = {
    id: document.getElementById('rkatRealisasiId').value,
    realisasi: parseRupiahInput_(document.getElementById('rkatRealisasiNominal').value)
  };
  callServer('updateRealisasiRkat', STATE.token, payload).then(function(res){
    if(res && res.success){
      showToast('Realisasi diperbarui.');
      closeModal('modalRkatRealisasi');
      loadRkatList_();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan realisasi.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function cetakRkatRealisasiPDF_(){
  if(!STATE_RKAT_DATA.length){
    showToast('Belum ada data RKAT untuk dicetak.', 'error');
    return;
  }
  window.print();
}

</script>
<script>
// ================= LAPORAN =================
var LAST_LAPORAN = null;
var LAST_REKAP_RINCIAN = null;

var STATE_LAPORAN_TAB = 'perolehan';

function loadLaporanView(){
  applyUnduhButtonVisibility_();
  populateLaporanBulanDropdown_();
  populateLaporanPetugasDropdown_();
  populateRekapRincianDropdowns_();
  switchLaporanTab(STATE_LAPORAN_TAB);
}

// Sembunyikan tombol Export Excel & Cetak PDF per sub-tab Laporan kalau akun
// (atau pengunjung Mode Publik) tidak punya hak akses "Unduh" pada sub-menu
// tsb — granular per sub-tab (Laporan Perolehan / Rekap Rincian / Rekap Petugas),
// bukan satu saklar untuk semua sub-tab Laporan sekaligus.
function applyUnduhButtonVisibility_(){
  var tombolPerSubMenu = {
    btnExportLaporan: 'laporan_perolehan', btnCetakLaporan: 'laporan_perolehan',
    btnExportRekapRincian: 'laporan_rincian', btnCetakRekapRincian: 'laporan_rincian',
    btnExportRekapPetugas: 'laporan_rekapPetugas', btnCetakRekapPetugas: 'laporan_rekapPetugas'
  };
  Object.keys(tombolPerSubMenu).forEach(function(id){
    var el = document.getElementById(id);
    if(el) el.style.display = canDo(tombolPerSubMenu[id], 'unduh') ? '' : 'none';
  });
}

function switchLaporanTab(tab){
  STATE_LAPORAN_TAB = tab;

  document.getElementById('laporanPerolehanSub').style.display = tab === 'perolehan' ? 'block' : 'none';
  document.getElementById('laporanRincianSub').style.display = tab === 'rincian' ? 'block' : 'none';
  document.getElementById('laporanRekapPetugasSub').style.display = tab === 'rekapPetugas' ? 'block' : 'none';

  var judul = { perolehan: 'Laporan Perolehan', rincian: 'Rekap Rincian Koin', rekapPetugas: 'Rekap Petugas' };
  var subjudul = {
    perolehan: 'Rekap setoran per kotak berdasarkan bulan & petugas',
    rincian: 'Rekap rincian pecahan uang koin & kertas per bulan',
    rekapPetugas: 'Rekapitulasi perolehan kotak koin per petugas'
  };
  document.getElementById('laporanViewTitle').textContent = judul[tab] || 'Laporan Koin';
  document.getElementById('laporanViewSubtitle').textContent = subjudul[tab] || '';

  if(tab === 'perolehan') generateLaporan();
  else if(tab === 'rincian') generateRekapRincian();
  else { populateRekapPetugasBulanDropdown_(); generateRekapPetugas(); }
}

function populateLaporanBulanDropdown_(){
  var sel = document.getElementById('laporanBulan');
  var current = sel.value;
  var options = '';
  var now = new Date();
  for(var i = 0; i < 12; i++){
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var y = d.getFullYear();
    var m = ('0' + (d.getMonth() + 1)).slice(-2);
    var value = y + '-' + m;
    var label = MONTH_NAMES_ID[d.getMonth()] + ' ' + y;
    options += '<option value="' + value + '">' + label + '</option>';
  }
  sel.innerHTML = options;
  sel.value = current || (now.getFullYear() + '-' + ('0'+(now.getMonth()+1)).slice(-2));
}

function populateLaporanPetugasDropdown_(){
  var sel = document.getElementById('laporanPetugas');
  var current = sel.value;
  var petugasSet = {};
  (STATE.kotakList || []).forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasSet[p] = true;
  });
  var petugasNames = Object.keys(petugasSet).sort();

  sel.innerHTML = '<option value="">Semua Petugas</option>' +
    petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + '</option>'; }).join('');
  if(current && (current === '' || petugasNames.indexOf(current) > -1)) sel.value = current;
}

function populateRekapRincianDropdowns_(){
  var selBulan = document.getElementById('rekapRincianBulan');
  var currentBulan = selBulan.value;
  var options = '';
  var now = new Date();
  for(var i = 0; i < 12; i++){
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var y = d.getFullYear();
    var m = ('0' + (d.getMonth() + 1)).slice(-2);
    var value = y + '-' + m;
    var label = MONTH_NAMES_ID[d.getMonth()] + ' ' + y;
    options += '<option value="' + value + '">' + label + '</option>';
  }
  selBulan.innerHTML = options;
  selBulan.value = currentBulan || (now.getFullYear() + '-' + ('0'+(now.getMonth()+1)).slice(-2));

  var selPetugas = document.getElementById('rekapRincianPetugas');
  var currentPetugas = selPetugas.value;
  var petugasSet = {};
  (STATE.kotakList || []).forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasSet[p] = true;
  });
  var petugasNames = Object.keys(petugasSet).sort();
  selPetugas.innerHTML = '<option value="">Semua Petugas</option>' +
    petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + '</option>'; }).join('');
  if(currentPetugas && (currentPetugas === '' || petugasNames.indexOf(currentPetugas) > -1)) selPetugas.value = currentPetugas;
}

var STATE_REKAP_SUM_PER_DENOM = {};
var STATE_VERIFIKASI_COUNTS = {};

function generateRekapRincian(){
  var bulan = document.getElementById('rekapRincianBulan').value;
  var params = {
    bulan: bulan,
    petugas: document.getElementById('rekapRincianPetugas').value
  };
  document.getElementById('rekapRincianTableBody').innerHTML = '<tr><td colspan="4"><div class="loading-inline"><div class="spinner-sm"></div> Memuat rekap...</div></td></tr>';

  Promise.all([
    callServer('getRekapRincianUang', STATE.token, params),
    callServer('getVerifikasiUang', STATE.token, { bulan: bulan })
  ]).then(function(results){
    var res = results[0];
    var resVerif = results[1];

    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat rekap.', 'error');
      return;
    }
    var d = res.data;
    STATE_REKAP_SUM_PER_DENOM = d.sumPerDenom;
    LAST_REKAP_RINCIAN = d;
    STATE_VERIFIKASI_COUNTS = (resVerif && resVerif.success) ? resVerif.data.counts : {};

    document.getElementById('rekapRincianSummary').innerHTML =
      '<div class="stat-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr));margin-bottom:16px;">' +
      statCard('📋', 'Jumlah Setoran Fisik', d.entries.length, '') +
      statCard('💰', 'Total Hitung Semua', formatRupiah(d.grandTotal), '', true) +
      '</div>';

    renderRekapDenomRows_('rekapKoinRows', KOIN_DENOM, d.sumPerDenom);
    renderRekapDenomRows_('rekapKertasRows', KERTAS_DENOM, d.sumPerDenom);
    renderVerifikasiRows_();

    if(!d.entries.length){
      document.getElementById('rekapRincianTableBody').innerHTML = '<tr><td colspan="4">' + emptyState('Tidak ada data rincian uang pada periode ini.') + '</td></tr>';
      return;
    }

    document.getElementById('rekapRincianTableBody').innerHTML = d.entries.map(function(r){
      return '<tr>' +
        '<td>' + escapeHtml(r.bulan) + '</td>' +
        '<td>' + escapeHtml(r.petugas) + '</td>' +
        '<td style="font-weight:700;color:var(--hijau-tua);">' + formatRupiah(r.totalHitung) + '</td>' +
        '<td>' + escapeHtml(r.timestamp || '-') + '</td>' +
        '</tr>';
    }).join('');
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function renderVerifikasiDenomRows_(containerId, denomList){
  var html = denomList.map(function(d){
    var rekapVal = (STATE_REKAP_SUM_PER_DENOM && STATE_REKAP_SUM_PER_DENOM[d.key]) || 0;
    var verifVal = STATE_VERIFIKASI_COUNTS[d.key] || 0;
    var diff = verifVal - rekapVal;
    var selisihHtml = '';
    if(verifVal !== 0 || rekapVal !== 0){
      if(diff === 0){
        selisihHtml = '<span style="color:var(--hijau-tua);font-weight:700;">✅ Pas</span>';
      } else {
        var label = diff > 0 ? 'Lebih' : 'Kurang';
        selisihHtml = '<span style="color:var(--merah);font-weight:700;">' + label + ' ' + formatRupiah(Math.abs(diff)) + '</span>';
      }
    }

    return '<div style="margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #f1f4f2;">' +
      '<div style="display:flex;justify-content:space-between;font-size:11.5px;color:var(--teks-muda);margin-bottom:4px;">' +
        '<span>' + escapeHtml(d.label) + '</span><span>Rekap: ' + formatRupiah(rekapVal) + '</span>' +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:6px;">' +
        '<span style="font-size:11.5px;color:var(--teks-muda);">Rp</span>' +
        '<input type="text" inputmode="numeric" placeholder="0" value="' + (verifVal > 0 ? formatAngka(verifVal) : '') +
          '" class="denom-input denom-input-sm ' + (verifVal > 0 ? 'setor-filled' : 'setor-empty') + '" ' +
          'oninput="onVerifikasiInputChange_(this, \'' + d.key + '\')">' +
        '<span id="selisihRow_' + d.key + '" style="font-size:11px;white-space:nowrap;min-width:70px;text-align:right;">' + selisihHtml + '</span>' +
      '</div>' +
      '</div>';
  }).join('');

  var totalRekap = denomList.reduce(function(sum, d){ return sum + ((STATE_REKAP_SUM_PER_DENOM && STATE_REKAP_SUM_PER_DENOM[d.key]) || 0); }, 0);
  var totalVerif = denomList.reduce(function(sum, d){ return sum + (STATE_VERIFIKASI_COUNTS[d.key] || 0); }, 0);
  html += '<div style="display:flex;justify-content:space-between;padding-top:4px;font-weight:700;font-size:12.5px;color:var(--hijau-tua);">' +
    '<span>Total (rekap ' + formatRupiah(totalRekap) + ')</span><span id="verifTotalText_' + containerId + '">' + formatRupiah(totalVerif) + '</span></div>';

  document.getElementById(containerId).innerHTML = html;
}

function renderVerifikasiRows_(){
  renderVerifikasiDenomRows_('verifKoinRows', KOIN_DENOM);
  renderVerifikasiDenomRows_('verifKertasRows', KERTAS_DENOM);
  renderVerifikasiNotif_();
  applyReadOnlyLock(document.getElementById('verifikasiCard'), !(canDo('laporan_rincian','tambah') || canDo('laporan_rincian','edit')));
}

// Sama seperti onRincianInputChange_: format ribuan otomatis + toggle warna
// terisi/kosong untuk kolom Verifikasi Uang Sebenarnya.
function onVerifikasiInputChange_(el, key){
  var value = parseRupiahInput_(el.value);
  el.value = value > 0 ? formatAngka(value) : '';
  el.classList.toggle('setor-filled', value > 0);
  el.classList.toggle('setor-empty', value <= 0);
  updateVerifikasiValue(key, value);
}

function updateVerifikasiValue(key, value){
  STATE_VERIFIKASI_COUNTS[key] = Number(value) || 0;

  var isKoin = KOIN_DENOM.some(function(d){ return d.key === key; });
  var denomList = isKoin ? KOIN_DENOM : KERTAS_DENOM;
  var containerId = isKoin ? 'verifKoinRows' : 'verifKertasRows';

  var rekapVal = (STATE_REKAP_SUM_PER_DENOM && STATE_REKAP_SUM_PER_DENOM[key]) || 0;
  var verifVal = STATE_VERIFIKASI_COUNTS[key] || 0;
  var diff = verifVal - rekapVal;
  var badgeEl = document.getElementById('selisihRow_' + key);
  if(badgeEl){
    if(verifVal === 0 && rekapVal === 0){
      badgeEl.innerHTML = '';
    } else if(diff === 0){
      badgeEl.innerHTML = '<span style="color:var(--hijau-tua);font-weight:700;">✅ Pas</span>';
    } else {
      var label = diff > 0 ? 'Lebih' : 'Kurang';
      badgeEl.innerHTML = '<span style="color:var(--merah);font-weight:700;">' + label + ' ' + formatRupiah(Math.abs(diff)) + '</span>';
    }
  }

  var totalVerif = denomList.reduce(function(sum, d){ return sum + (STATE_VERIFIKASI_COUNTS[d.key] || 0); }, 0);
  var totalTextEl = document.getElementById('verifTotalText_' + containerId);
  if(totalTextEl) totalTextEl.textContent = formatRupiah(totalVerif);

  renderVerifikasiNotif_();
}

function renderVerifikasiNotif_(){
  var el = document.getElementById('verifNotifArea');
  if(!el) return;

  var totalRekap = KOIN_DENOM.concat(KERTAS_DENOM).reduce(function(sum, d){ return sum + ((STATE_REKAP_SUM_PER_DENOM && STATE_REKAP_SUM_PER_DENOM[d.key]) || 0); }, 0);
  var totalVerif = KOIN_DENOM.concat(KERTAS_DENOM).reduce(function(sum, d){ return sum + (STATE_VERIFIKASI_COUNTS[d.key] || 0); }, 0);

  if(totalVerif === 0){
    el.innerHTML = '';
    return;
  }

  var selisih = totalVerif - totalRekap;
  if(selisih === 0){
    el.innerHTML = '<div style="background:#d9f2e3;color:var(--hijau-tua);padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;">' +
      '✅ Pas — Uang sebenarnya (' + formatRupiah(totalVerif) + ') sama dengan rekap setoran (' + formatRupiah(totalRekap) + ').</div>';
  } else {
    var label = selisih > 0 ? 'Lebih' : 'Kurang';
    el.innerHTML = '<div style="background:#fdeceb;color:var(--merah);padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;">' +
      '⚠️ ' + label + ' — Uang sebenarnya (' + formatRupiah(totalVerif) + ') ' + label.toLowerCase() + ' ' + formatRupiah(Math.abs(selisih)) +
      ' dari rekap setoran (' + formatRupiah(totalRekap) + ').</div>';
  }
}

function saveVerifikasiHandler(){
  var bulan = document.getElementById('rekapRincianBulan').value;
  if(!bulan) return;

  var btn = document.getElementById('btnSimpanVerifikasi');
  setBtnLoading(btn, true, 'Menyimpan...');

  callServer('saveVerifikasiUang', STATE.token, { bulan: bulan, counts: STATE_VERIFIKASI_COUNTS }).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan Verifikasi');
    if(res && res.success){
      showToast('Verifikasi uang tersimpan.');
    } else {
      showToast((res && res.message) || 'Gagal menyimpan verifikasi.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan Verifikasi');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function renderRekapDenomRows_(containerId, denomList, sumPerDenom){
  var html = denomList.map(function(d){
    var val = (sumPerDenom && sumPerDenom[d.key]) || 0;
    return '<div style="display:flex;justify-content:space-between;padding:6px 0;font-size:13px;">' +
      '<span style="color:var(--teks-muda);">' + escapeHtml(d.label) + '</span>' +
      '<span style="font-weight:600;">' + formatRupiah(val) + '</span>' +
      '</div>';
  }).join('');

  var total = denomList.reduce(function(sum, d){ return sum + ((sumPerDenom && sumPerDenom[d.key]) || 0); }, 0);
  html += '<div style="display:flex;justify-content:space-between;padding-top:8px;margin-top:4px;border-top:1.5px solid #e9efec;font-weight:700;font-size:13px;color:var(--hijau-tua);">' +
    '<span>Total</span><span>' + formatRupiah(total) + '</span></div>';

  document.getElementById(containerId).innerHTML = html;
}

function generateLaporan(){
  var params = {
    bulan: document.getElementById('laporanBulan').value,
    petugas: document.getElementById('laporanPetugas').value,
    dusun: document.getElementById('laporanDusun').value
  };
  document.getElementById('laporanTableBody').innerHTML = '<tr><td colspan="7"><div class="loading-inline"><div class="spinner-sm"></div> Memuat laporan...</div></td></tr>';

  callServer('getLaporan', STATE.token, params).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat laporan.', 'error');
      return;
    }
    LAST_LAPORAN = res.data;
    var d = res.data;

    var petugasSudahInput = {};
    (d.rows || []).forEach(function(r){
      var p = (r.namaPetugas || '').trim().toLowerCase();
      if(p && p !== '-') petugasSudahInput[p] = true;
    });
    (d.globalEntries || []).forEach(function(g){
      var p = (g.petugas || '').trim().toLowerCase();
      if(p) petugasSudahInput[p] = true;
    });
    var totalPetugasInput = Object.keys(petugasSudahInput).length;

    document.getElementById('laporanSummary').innerHTML =
      '<div class="stat-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr));margin-bottom:16px;">' +
      statCard('👥', 'Total Petugas Sudah Input Setoran', totalPetugasInput, '') +
      statCard('💰', 'Total Nominal', formatRupiah(d.totalNominal), '', true) +
      '</div>';

    if(!d.rows.length){
      document.getElementById('laporanTableBody').innerHTML = '<tr><td colspan="7">' + emptyState('Tidak ada data pada periode ini.') + '</td></tr>';
      renderLaporanGlobalArea_(d.globalEntries || []);
      renderLaporanRincianArea_(d.rincianUang || []);
      return;
    }

    var canEditLaporan = canDo('setoran', 'edit');
    var canHapusLaporan = canDo('setoran', 'hapus');

    document.getElementById('laporanTableBody').innerHTML = d.rows.map(function(s){
      var aksi = (canEditLaporan ? '<div class="icon-btn" onclick="openEditLaporan(\'' + s.id + '\')" title="Edit">✏️</div>' : '') +
                 (canHapusLaporan ? '<div class="icon-btn danger" onclick="confirmDeleteLaporan(\'' + s.id + '\')" title="Hapus">🗑️</div>' : '');
      return '<tr>' +
        '<td>' + formatTanggalIndo(s.tanggal) + '</td>' +
        '<td><b>' + escapeHtml(s.idKotak) + '</b></td>' +
        '<td>' + escapeHtml(s.nama) + '</td>' +
        '<td>' + escapeHtml(s.dusun) + '</td>' +
        '<td style="font-weight:700;color:var(--hijau-tua);">' + formatRupiah(s.jumlah) + '</td>' +
        '<td>' + escapeHtml(s.namaPetugas || '-') + '</td>' +
        '<td>' + (aksi ? '<div class="row-actions">' + aksi + '</div>' : '-') + '</td>' +
        '</tr>';
    }).join('');

    renderLaporanGlobalArea_(d.globalEntries || []);
    renderLaporanRincianArea_(d.rincianUang || []);
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function openEditLaporan(id){
  var s = (LAST_LAPORAN && LAST_LAPORAN.rows || []).find(function(x){ return x.id === id; });
  if(!s) return;
  document.getElementById('editLaporanId').value = s.id;
  document.getElementById('editLaporanKotakInfo').value = s.idKotak + ' - ' + s.nama + ' (' + s.dusun + ')';
  document.getElementById('editLaporanTanggal').value = s.tanggal;
  document.getElementById('editLaporanJumlah').value = s.jumlah;
  document.getElementById('editLaporanKeterangan').value = s.keterangan || '';
  openModal('modalEditLaporan');
}

function saveEditLaporan(){
  var id = document.getElementById('editLaporanId').value;
  var jumlah = document.getElementById('editLaporanJumlah').value;
  if(!jumlah || Number(jumlah) < 0){
    showToast('Jumlah tidak valid.', 'error');
    return;
  }

  var payload = {
    id: id,
    tanggal: document.getElementById('editLaporanTanggal').value,
    jumlah: jumlah,
    keterangan: document.getElementById('editLaporanKeterangan').value.trim()
  };

  var btn = document.getElementById('btnSaveEditLaporan');
  setBtnLoading(btn, true, 'Menyimpan...');

  callServer('updateSetoran', STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, 'Simpan');
    if(res && res.success){
      showToast('Data setoran diperbarui.');
      closeModal('modalEditLaporan');
      generateLaporan();
      loadDashboard();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan perubahan.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeleteLaporan(id){
  openConfirm('Hapus data setoran ini? Tindakan ini tidak dapat dibatalkan.', function(){
    callServer('deleteSetoran', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Data setoran dihapus.');
        generateLaporan();
        loadDashboard();
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

function renderLaporanGlobalArea_(entries){
  var el = document.getElementById('laporanGlobalArea');
  if(!entries.length){ el.innerHTML = ''; return; }

  var totalGlobal = entries.reduce(function(sum, g){ return sum + g.totalNominal; }, 0);

  el.innerHTML = '<div class="card" style="margin-top:16px;">' +
    '<h3>🧮 Input Global (Ringkas) pada Periode Ini</h3>' +
    '<p style="font-size:12.5px;color:var(--teks-muda);margin-bottom:12px;">Total dari input global: <b>' + formatRupiah(totalGlobal) + '</b> — sudah termasuk di Total Nominal di atas.</p>' +
    '<div class="table-wrap"><table><thead><tr><th>Bulan</th><th>Petugas</th><th>Kotak Dibuka</th><th>Total Nominal</th></tr></thead><tbody>' +
    entries.map(function(g){
      return '<tr><td>' + escapeHtml(g.bulan) + '</td><td>' + escapeHtml(g.petugas) + '</td><td>' + escapeHtml(g.jumlahKotakDibuka) + '</td><td style="font-weight:700;color:var(--hijau-tua);">' + formatRupiah(g.totalNominal) + '</td></tr>';
    }).join('') +
    '</tbody></table></div></div>';
}

function renderLaporanRincianArea_(entries){
  var el = document.getElementById('laporanRincianArea');
  if(!entries.length){ el.innerHTML = ''; return; }

  el.innerHTML = '<div class="card" style="margin-top:16px;">' +
    '<h3>💵 Rincian Uang Fisik pada Periode Ini</h3>' +
    '<div class="table-wrap"><table><thead><tr><th>Bulan</th><th>Petugas</th><th>Total Hitung Fisik</th><th>Terakhir Diperbarui</th></tr></thead><tbody>' +
    entries.map(function(r){
      return '<tr><td>' + escapeHtml(r.bulan) + '</td><td>' + escapeHtml(r.petugas) + '</td><td style="font-weight:700;color:var(--hijau-tua);">' + formatRupiah(r.totalHitung) + '</td><td>' + escapeHtml(r.timestamp || '-') + '</td></tr>';
    }).join('') +
    '</tbody></table></div></div>';
}

function exportLaporanCSV(){
  if(!LAST_LAPORAN || !LAST_LAPORAN.rows.length){
    showToast('Tampilkan laporan terlebih dahulu sebelum export.', 'error');
    return;
  }

  var wb = XLSX.utils.book_new();

  var sheetTransaksi = LAST_LAPORAN.rows.map(function(s){
    return {
      'Tanggal': s.tanggal, 'ID Kotak': s.idKotak, 'Nama Pemegang': s.nama, 'Dusun': s.dusun,
      'Jumlah': s.jumlah, 'Petugas': s.namaPetugas || '-', 'Admin Input': s.adminInput, 'Keterangan': s.keterangan || ''
    };
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetTransaksi), 'Transaksi');

  if(LAST_LAPORAN.globalEntries && LAST_LAPORAN.globalEntries.length){
    var sheetGlobal = LAST_LAPORAN.globalEntries.map(function(g){
      return { 'Bulan': g.bulan, 'Petugas': g.petugas, 'Kotak Dibuka': g.jumlahKotakDibuka, 'Total Nominal': g.totalNominal };
    });
    XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetGlobal), 'Input Global');
  }

  if(LAST_LAPORAN.rincianUang && LAST_LAPORAN.rincianUang.length){
    var sheetRincian = LAST_LAPORAN.rincianUang.map(function(r){
      return { 'Bulan': r.bulan, 'Petugas': r.petugas, 'Total Hitung': r.totalHitung, 'Terakhir Diperbarui': r.timestamp || '-' };
    });
    XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetRincian), 'Rincian Uang');
  }

  XLSX.writeFile(wb, 'Laporan_Koin_UPZISNU_' + todayISO() + '.xlsx');
  showToast('File Excel berhasil diunduh.');
}

function printLaporan(){
  if(!LAST_LAPORAN || !LAST_LAPORAN.rows.length){
    showToast('Tampilkan laporan terlebih dahulu sebelum mencetak.', 'error');
    return;
  }
  window.print();
}

function exportRekapRincianExcel(){
  if(!LAST_REKAP_RINCIAN || !LAST_REKAP_RINCIAN.entries.length){
    showToast('Tampilkan rekap terlebih dahulu sebelum export.', 'error');
    return;
  }
  var wb = XLSX.utils.book_new();
  var d = LAST_REKAP_RINCIAN;

  var sheetEntri = d.entries.map(function(r){
    return { 'Bulan': r.bulan, 'Petugas': r.petugas, 'Total Hitung': r.totalHitung, 'Terakhir Diperbarui': r.timestamp || '-' };
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetEntri), 'Rekap per Petugas');

  var sheetPecahan = KOIN_DENOM.concat(KERTAS_DENOM).map(function(dn){
    return { 'Jenis': KOIN_DENOM.indexOf(dn) > -1 ? 'Koin' : 'Kertas', 'Pecahan': dn.label, 'Total': (d.sumPerDenom && d.sumPerDenom[dn.key]) || 0 };
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetPecahan), 'Total per Pecahan');

  XLSX.writeFile(wb, 'Rekap_Rincian_Koin_UPZISNU_' + todayISO() + '.xlsx');
  showToast('File Excel berhasil diunduh.');
}

function printRekapRincian(){
  if(!LAST_REKAP_RINCIAN || !LAST_REKAP_RINCIAN.entries.length){
    showToast('Tampilkan rekap terlebih dahulu sebelum mencetak.', 'error');
    return;
  }
  window.print();
}

// ================= REKAP PETUGAS (format cetak resmi berkop) =================
var LAST_REKAP_PETUGAS = null;

function populateRekapPetugasBulanDropdown_(){
  var sel = document.getElementById('rekapPetugasBulan');
  var current = sel.value;
  var options = '';
  var now = new Date();
  for(var i = 0; i < 12; i++){
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var y = d.getFullYear();
    var m = ('0' + (d.getMonth() + 1)).slice(-2);
    var value = y + '-' + m;
    var label = MONTH_NAMES_ID[d.getMonth()] + ' ' + y;
    options += '<option value="' + value + '">' + label + '</option>';
  }
  sel.innerHTML = options;
  sel.value = current || (now.getFullYear() + '-' + ('0'+(now.getMonth()+1)).slice(-2));
}

function generateRekapPetugas(){
  var bulan = document.getElementById('rekapPetugasBulan').value;
  document.getElementById('rekapPetugasTableBody').innerHTML = '<tr><td colspan="10"><div class="loading-inline"><div class="spinner-sm"></div> Memuat rekap...</div></td></tr>';

  callServer('getRekapPetugasBulanan', STATE.token, { bulan: bulan }).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat rekap.', 'error');
      return;
    }
    LAST_REKAP_PETUGAS = res.data;
    var d = res.data;

    var bulanIdx = parseInt(bulan.substring(5,7), 10) - 1;
    var tahun = bulan.substring(0,4);
    document.getElementById('rekapPetugasTahun').textContent = tahun;
    document.getElementById('rekapPetugasBulanLabel').textContent = (MONTH_NAMES_ID[bulanIdx] || '').toUpperCase();

    document.getElementById('rekapPetugasTableBody').innerHTML = d.rows.map(function(r, idx){
      return '<tr>' +
        '<td>' + (idx+1) + '</td>' +
        '<td>' + escapeHtml(r.namaPetugas) + '</td>' +
        '<td>' + escapeHtml(r.wilayahKerja) + '</td>' +
        '<td>' + r.jumlahKotak + '</td>' +
        '<td>' + r.kotakDibuka + '</td>' +
        '<td>' + r.kotakTidakDibuka + '</td>' +
        '<td>' + formatAngka(r.perolehanKoin) + '</td>' +
        '<td>' + formatAngka(r.rataRata) + '</td>' +
        '<td>' + formatAngka(r.bisaroh) + '</td>' +
        '<td style="font-weight:700;color:var(--hijau-tua);">' + formatAngka(r.totalDisetorkan) + '</td>' +
        '</tr>';
    }).join('') + (d.tanpaPetugasCount > 0 ?
      '<tr><td>' + (d.rows.length+1) + '</td><td>BELUM TERDISTRIBUSI</td><td>-</td><td>' + d.tanpaPetugasCount + '</td>' +
      '<td>-</td><td>' + d.tanpaPetugasCount + '</td><td>-</td><td>-</td><td>-</td><td>-</td></tr>' : '');

    document.getElementById('rekapPetugasTableFoot').innerHTML =
      '<tr style="font-weight:700;background:#f2f6f4;">' +
      '<td colspan="3">TOTAL</td>' +
      '<td>' + d.totals.jumlahKotak + '</td>' +
      '<td>' + d.totals.kotakDibuka + '</td>' +
      '<td>' + d.totals.kotakTidakDibuka + '</td>' +
      '<td>' + formatAngka(d.totals.perolehanKoin) + '</td>' +
      '<td>' + formatAngka(d.totals.rataRata) + '</td>' +
      '<td>' + formatAngka(d.totals.bisaroh) + '</td>' +
      '<td style="color:var(--hijau-tua);">' + formatAngka(d.totals.totalDisetorkan) + '</td>' +
      '</tr>';

    renderRekapPetugasFooter_();

    var today = new Date();
    var bulanNames = MONTH_NAMES_ID[today.getMonth()];
    document.getElementById('rekapPetugasTtdTanggal').textContent = 'Baleharjo, ' + today.getDate() + ' ' + bulanNames + ' ' + today.getFullYear();

    loadKonsumsiPenghitungan_(bulan);
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// Ambil nominal Konsumsi Penghitungan Koin yang sudah tersimpan untuk bulan
// ini (kalau ada), tampilkan di kolom input, lalu recompute footer.
function loadKonsumsiPenghitungan_(bulan){
  callServer('getKonsumsiPenghitungan', STATE.token, { bulan: bulan }).then(function(res){
    var input = document.getElementById('konsumsiPenghitungan');
    input.value = (res && res.success && res.data.nominal > 0) ? formatAngka(res.data.nominal) : '';
    renderRekapPetugasFooter_();
  }).catch(function(){ /* diam-diam gagal, bukan fitur kritikal */ });
}

function onKonsumsiInput_(el){
  liveFormatRupiah_(el);
  renderRekapPetugasFooter_();
}

function saveKonsumsiHandler(){
  var bulan = document.getElementById('rekapPetugasBulan').value;
  var nominal = parseRupiahInput_(document.getElementById('konsumsiPenghitungan').value);
  var btn = document.getElementById('btnSimpanKonsumsi');
  setBtnLoading(btn, true, 'Menyimpan...');
  callServer('saveKonsumsiPenghitungan', STATE.token, { bulan: bulan, nominal: nominal }).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan Konsumsi');
    if(res && res.success){
      showToast('Konsumsi Penghitungan Koin tersimpan untuk bulan ini.');
    } else {
      showToast((res && res.message) || 'Gagal menyimpan konsumsi.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan Konsumsi');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function renderRekapPetugasFooter_(){
  if(!LAST_REKAP_PETUGAS) return;
  var konsumsi = parseRupiahInput_(document.getElementById('konsumsiPenghitungan').value);
  var totalDisetorkan = LAST_REKAP_PETUGAS.totals.totalDisetorkan;
  var disetorkanBersih = totalDisetorkan - konsumsi;

  document.getElementById('rekapPetugasFooterArea').innerHTML =
    '<div style="text-align:right;font-size:13px;padding:2px 0;">' +
      'Konsumsi Penghitungan Koin&nbsp; <b>-' + formatRupiah(konsumsi) + '</b>' +
    '</div>' +
    '<div style="text-align:right;font-size:14px;font-weight:700;color:var(--hijau-tua);padding:6px 0 2px;border-top:1.5px solid #e9efec;margin-top:6px;">' +
      'Dana disetorkan ke BMT&nbsp; ' + formatRupiah(disetorkanBersih) +
    '</div>';
}

function exportRekapPetugasExcel(){
  if(!LAST_REKAP_PETUGAS || !LAST_REKAP_PETUGAS.rows.length){
    showToast('Tampilkan rekap terlebih dahulu sebelum export.', 'error');
    return;
  }
  var d = LAST_REKAP_PETUGAS;
  var konsumsi = parseRupiahInput_(document.getElementById('konsumsiPenghitungan').value);

  var sheetData = d.rows.map(function(r, idx){
    return {
      'No': idx+1, 'Nama Petugas': r.namaPetugas, 'Wilayah Kerja': r.wilayahKerja,
      'Jumlah Kotak': r.jumlahKotak, 'Kotak Dibuka': r.kotakDibuka, 'Kotak Tidak Dibuka': r.kotakTidakDibuka,
      'Perolehan Koin': r.perolehanKoin, 'Rata-rata per Kotak': r.rataRata, 'Bisaroh': r.bisaroh, 'Total Disetorkan': r.totalDisetorkan
    };
  });
  if(d.tanpaPetugasCount > 0){
    sheetData.push({ 'No': d.rows.length+1, 'Nama Petugas': 'BELUM TERDISTRIBUSI', 'Wilayah Kerja': '-', 'Jumlah Kotak': d.tanpaPetugasCount, 'Kotak Dibuka': '-', 'Kotak Tidak Dibuka': d.tanpaPetugasCount, 'Perolehan Koin': '-', 'Rata-rata per Kotak': '-', 'Bisaroh': '-', 'Total Disetorkan': '-' });
  }
  sheetData.push({ 'No': '', 'Nama Petugas': 'TOTAL', 'Wilayah Kerja': '', 'Jumlah Kotak': d.totals.jumlahKotak, 'Kotak Dibuka': d.totals.kotakDibuka, 'Kotak Tidak Dibuka': d.totals.kotakTidakDibuka, 'Perolehan Koin': d.totals.perolehanKoin, 'Rata-rata per Kotak': d.totals.rataRata, 'Bisaroh': d.totals.bisaroh, 'Total Disetorkan': d.totals.totalDisetorkan });
  sheetData.push({});
  sheetData.push({ 'Nama Petugas': 'Konsumsi Penghitungan Koin', 'Total Disetorkan': -konsumsi });
  sheetData.push({ 'Nama Petugas': 'Dana disetorkan ke BMT', 'Total Disetorkan': d.totals.totalDisetorkan - konsumsi });

  var wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(sheetData), 'Rekap Petugas');
  XLSX.writeFile(wb, 'Rekap_Petugas_UPZISNU_' + document.getElementById('rekapPetugasBulan').value + '.xlsx');
  showToast('File Excel berhasil diunduh.');
}

function printRekapPetugas(){
  if(!LAST_REKAP_PETUGAS || !LAST_REKAP_PETUGAS.rows.length){
    showToast('Tampilkan rekap terlebih dahulu sebelum mencetak.', 'error');
    return;
  }
  window.print();
}

// ================= PENGATURAN =================
function handleChangePassword(){
  var oldPw = document.getElementById('oldPassword').value;
  var newPw = document.getElementById('newPassword').value;
  var confirmPw = document.getElementById('confirmPassword').value;

  if(!oldPw || !newPw || !confirmPw){
    showToast('Semua field wajib diisi.', 'error');
    return;
  }
  if(newPw !== confirmPw){
    showToast('Konfirmasi password baru tidak cocok.', 'error');
    return;
  }
  if(newPw.length < 6){
    showToast('Password baru minimal 6 karakter.', 'error');
    return;
  }

  callServer('changePassword', STATE.token, oldPw, newPw).then(function(res){
    if(res && res.success){
      showToast('Password berhasil diubah.');
      document.getElementById('oldPassword').value = '';
      document.getElementById('newPassword').value = '';
      document.getElementById('confirmPassword').value = '';
    } else {
      showToast((res && res.message) || 'Gagal mengubah password.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function openProfileModal(){
  STATE_PENGATURAN_TAB = 'akun';
  switchView('pengaturan');
}

// ================= PENGATURAN: ADMIN-ONLY SECTIONS =================
var STATE_PENGATURAN_TAB = 'akun';

function switchPengaturanTab(tab){
  STATE_PENGATURAN_TAB = tab;

  document.getElementById('pengaturanAkunSub').style.display = tab === 'akun' ? 'block' : 'none';
  document.getElementById('pengaturanPublikSub').style.display = tab === 'publik' ? 'block' : 'none';
  document.getElementById('pengaturanRunningTextSub').style.display = tab === 'runningtext' ? 'block' : 'none';
  document.getElementById('pengaturanOrganisasiSub').style.display = tab === 'organisasi' ? 'block' : 'none';
  document.getElementById('pengaturanRekeningSub').style.display = tab === 'rekening' ? 'block' : 'none';
  document.getElementById('pengaturanGantiPetugasSub').style.display = tab === 'gantipetugas' ? 'block' : 'none';
  document.getElementById('pengaturanUserSub').style.display = tab === 'user' ? 'block' : 'none';

  var judul = {
    akun: 'Akun Saya', publik: 'Tampilan Publik', runningtext: 'Running Text',
    organisasi: 'Data Organisasi', rekening: 'Data Rekening', gantipetugas: 'Ganti Nama Petugas', user: 'Manajemen User'
  };
  var subjudul = {
    akun: 'Kelola password akun Anda',
    publik: 'Atur tampilan yang bisa dilihat publik tanpa login',
    runningtext: 'Teks berjalan pengumuman di bawah header',
    organisasi: 'Logo & data pengurus untuk kop surat dan tanda tangan dokumen cetak',
    rekening: 'Rekening bank/BMT Kas UPZISNU & Kas BOP untuk Surat Perintah Pencairan Dana',
    gantipetugas: 'Ganti nama petugas secara global di semua kotak sekaligus',
    user: 'Kelola akun & hak akses pengguna aplikasi'
  };
  document.getElementById('pengaturanViewTitle').textContent = judul[tab] || 'Pengaturan';
  document.getElementById('pengaturanViewSubtitle').textContent = subjudul[tab] || 'Kelola akun dan preferensi';
}

function loadPengaturanView(){
  var isAdmin = STATE.session && normalizeKeyClient_(STATE.session.role) === 'admin';

  // Tab "Tampilan Publik", "Running Text" & "Manajemen User" cuma untuk
  // Admin — sub-menunya ada di sidebar (grup "Pengaturan"), bukan tombol di
  // halaman ini. Akun lain (Petugas/Bendahara/dst) otomatis cuma bisa lihat
  // "Akun Saya".
  switchPengaturanTab(isAdmin ? STATE_PENGATURAN_TAB : 'akun');

  if(!isAdmin) return;

  callServer('getPengaturanPublik', STATE.token).then(function(res){
    if(res && res.success){
      document.getElementById('togglePublikAktif').checked = !!res.data.aktif;
    }
  });

  callServer('getRunningText', STATE.token).then(function(res){
    if(res && res.success){
      document.getElementById('toggleRunningTextAktif').checked = !!res.data.aktif;
      document.getElementById('runningTextIsi').value = res.data.isi || '';
      document.getElementById('runningTextKecepatan').value = res.data.kecepatan || 'sedang';
    }
  });

  callServer('getPengaturanOrganisasi', STATE.token).then(function(res){
    if(res && res.success){
      document.getElementById('orgNamaKetua').value = res.data.namaKetua || '';
      document.getElementById('orgAlamatKetua').value = res.data.alamatKetua || '';
      document.getElementById('orgNamaSekretaris').value = res.data.namaSekretaris || '';
      document.getElementById('orgAlamatSekretaris').value = res.data.alamatSekretaris || '';
      document.getElementById('orgNamaBendahara').value = res.data.namaBendahara || '';
      document.getElementById('orgAlamatBendahara').value = res.data.alamatBendahara || '';
      document.getElementById('orgAlamatSekretariat').value = res.data.alamatSekretariat || '';
      document.getElementById('rekUpzisnuNamaBank').value = res.data.namaBankUpzisnu || '';
      document.getElementById('rekUpzisnuAlamatBank').value = res.data.alamatBankUpzisnu || '';
      document.getElementById('rekUpzisnuNomorRekening').value = res.data.nomorRekeningUpzisnu || '';
      document.getElementById('rekUpzisnuAtasNama').value = res.data.atasNamaRekeningUpzisnu || '';
      document.getElementById('rekBopNamaBank').value = res.data.namaBankBop || '';
      document.getElementById('rekBopAlamatBank').value = res.data.alamatBankBop || '';
      document.getElementById('rekBopNomorRekening').value = res.data.nomorRekeningBop || '';
      document.getElementById('rekBopAtasNama').value = res.data.atasNamaRekeningBop || '';
      if(res.data.logoUrl){
        document.getElementById('orgLogoPreview').src = res.data.logoUrl;
        document.getElementById('orgLogoPreviewWrap').style.display = 'block';
      }
    }
  });

  callServer('getKotakList', STATE.token).then(function(res){
    if(res && res.success){
      STATE.kotakList = res.data;
      populateGantiPetugasDropdown_();
    }
  });

  loadAkunList();
  loadAksesMenuTable();
}

function saveRunningTextHandler(){
  var payload = {
    aktif: document.getElementById('toggleRunningTextAktif').checked,
    isi: document.getElementById('runningTextIsi').value.trim(),
    kecepatan: document.getElementById('runningTextKecepatan').value
  };
  if(payload.aktif && !payload.isi){
    showToast('Isi tulisan wajib diisi kalau Running Text diaktifkan.', 'error');
    return;
  }
  callServer('saveRunningText', STATE.token, payload).then(function(res){
    if(res && res.success){
      showToast('Running Text tersimpan.');
      applyRunningTextSettings_(payload); // langsung terapkan tanpa perlu reload halaman
    } else {
      showToast((res && res.message) || 'Gagal menyimpan Running Text.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// ================= DATA ORGANISASI (LOGO & NAMA PENGURUS) =================
var STATE_ORG_SETTINGS = { logoUrl: '', namaKetua: '', alamatKetua: '', namaSekretaris: '', alamatSekretaris: '', namaBendahara: '', alamatBendahara: '', alamatSekretariat: '', namaBankUpzisnu: '', alamatBankUpzisnu: '', nomorRekeningUpzisnu: '', atasNamaRekeningUpzisnu: '', namaBankBop: '', alamatBankBop: '', nomorRekeningBop: '', atasNamaRekeningBop: '' };
var STATE_ORG_LOGO_BASE64 = '';

// Dipanggil sekali saat aplikasi dibuka (lihat bootApp), supaya nama
// pengurus & logo sudah siap dipakai di semua template surat/kop cetak
// tanpa perlu buka halaman Pengaturan dulu.
function loadOrgSettings_(){
  callServer('getPengaturanOrganisasi', STATE.token).then(function(res){
    if(res && res.success){
      STATE_ORG_SETTINGS = res.data;
      terapkanOrgSettingsKeTemplate_();
    }
  }).catch(function(){ /* diam-diam gagal, bukan fitur kritikal */ });
}

// Menempelkan nama Ketua/Sekretaris/Bendahara ke template TTD yang ada di
// halaman (Rekap Petugas). Dipanggil ulang tiap kali datanya berubah.
function terapkanOrgSettingsKeTemplate_(){
  var elKetua = document.getElementById('rekapPetugasTtdKetua');
  var elSekretaris = document.getElementById('rekapPetugasTtdSekretaris');
  var elBendahara = document.getElementById('rekapPetugasTtdBendahara');
  if(elKetua) elKetua.textContent = STATE_ORG_SETTINGS.namaKetua || '.........................';
  if(elSekretaris) elSekretaris.textContent = STATE_ORG_SETTINGS.namaSekretaris || '.........................';
  if(elBendahara) elBendahara.textContent = STATE_ORG_SETTINGS.namaBendahara || '.........................';

  ['kasUpzisnu', 'kasBop'].forEach(function(prefix){
    var k = document.getElementById(prefix + 'TtdKetua');
    var s = document.getElementById(prefix + 'TtdSekretaris');
    var b = document.getElementById(prefix + 'TtdBendahara');
    if(k) k.textContent = STATE_ORG_SETTINGS.namaKetua || '.........................';
    if(s) s.textContent = STATE_ORG_SETTINGS.namaSekretaris || '.........................';
    if(b) b.textContent = STATE_ORG_SETTINGS.namaBendahara || '.........................';
  });

  // Logo dipasang di semua kop cetak (Rekap Kas, Kwitansi Pencairan, Surat
  // Perintah, Laporan Pentasyarufan, Rekap Petugas) sekaligus lewat class
  // yang sama, supaya tidak perlu update satu-satu tiap ada kop baru nanti.
  document.querySelectorAll('.org-logo-print').forEach(function(img){
    if(STATE_ORG_SETTINGS.logoUrl){
      img.src = STATE_ORG_SETTINGS.logoUrl;
      img.style.display = 'block';
    } else {
      img.style.display = 'none';
    }
  });

  // Alamat sekretariat dipasang di semua kop cetak (baris tambahan di bawah
  // "KEC SUKODONO KAB SRAGEN"), sama seperti logo — cukup diisi sekali di
  // Pengaturan > Data Organisasi, tidak muncul kalau memang belum diisi.
  document.querySelectorAll('.org-alamat-print').forEach(function(el){
    if(STATE_ORG_SETTINGS.alamatSekretariat){
      el.textContent = STATE_ORG_SETTINGS.alamatSekretariat;
      el.style.display = 'block';
    } else {
      el.style.display = 'none';
    }
  });

  // Logo yang sama juga dipasang di topbar (kiri atas), layar loading, dan
  // layar login — kalau belum ada logo diupload, tetap tampil ikon 🪙 default.
  var logoImgHtml = '<img src="' + STATE_ORG_SETTINGS.logoUrl + '" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
  ['topbarLogo', 'loadingCoinIcon', 'loginLogo'].forEach(function(id){
    var el = document.getElementById(id);
    if(!el) return;
    el.innerHTML = STATE_ORG_SETTINGS.logoUrl ? logoImgHtml : '🪙';
  });
}

function onOrgLogoSelect_(event){
  var file = event.target.files && event.target.files[0];
  if(!file) return;
  if(!file.type.match(/^image\//)){
    showToast('File harus berupa gambar (JPG/PNG/dll).', 'error');
    event.target.value = '';
    return;
  }
  if(file.size > 15 * 1024 * 1024){
    showToast('Ukuran file maksimal 15MB (akan otomatis dikompres).', 'error');
    event.target.value = '';
    return;
  }
  compressImageForSheet_(file, function(dataUrl){
    STATE_ORG_LOGO_BASE64 = dataUrl;
    document.getElementById('orgLogoPreview').src = dataUrl;
    document.getElementById('orgLogoPreviewWrap').style.display = 'block';
  }, function(errMsg){
    showToast(errMsg, 'error');
    event.target.value = '';
  });
}

function saveOrganisasiHandler(){
  var payload = {
    namaKetua: document.getElementById('orgNamaKetua').value.trim(),
    alamatKetua: document.getElementById('orgAlamatKetua').value.trim(),
    namaSekretaris: document.getElementById('orgNamaSekretaris').value.trim(),
    alamatSekretaris: document.getElementById('orgAlamatSekretaris').value.trim(),
    namaBendahara: document.getElementById('orgNamaBendahara').value.trim(),
    alamatBendahara: document.getElementById('orgAlamatBendahara').value.trim(),
    alamatSekretariat: document.getElementById('orgAlamatSekretariat').value.trim()
  };
  if(STATE_ORG_LOGO_BASE64) payload.logoBase64 = STATE_ORG_LOGO_BASE64;

  callServer('savePengaturanOrganisasi', STATE.token, payload).then(function(res){
    if(res && res.success){
      showToast('Data Organisasi tersimpan.');
      STATE_ORG_LOGO_BASE64 = '';
      document.getElementById('orgLogoInput').value = '';
      loadOrgSettings_(); // ambil ulang dari server (termasuk URL logo baru kalau ada)
    } else {
      showToast((res && res.message) || 'Gagal menyimpan Data Organisasi.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function saveDataRekeningHandler(){
  var payload = {
    namaBankUpzisnu: document.getElementById('rekUpzisnuNamaBank').value.trim(),
    alamatBankUpzisnu: document.getElementById('rekUpzisnuAlamatBank').value.trim(),
    nomorRekeningUpzisnu: document.getElementById('rekUpzisnuNomorRekening').value.trim(),
    atasNamaRekeningUpzisnu: document.getElementById('rekUpzisnuAtasNama').value.trim(),
    namaBankBop: document.getElementById('rekBopNamaBank').value.trim(),
    alamatBankBop: document.getElementById('rekBopAlamatBank').value.trim(),
    nomorRekeningBop: document.getElementById('rekBopNomorRekening').value.trim(),
    atasNamaRekeningBop: document.getElementById('rekBopAtasNama').value.trim()
  };

  callServer('savePengaturanOrganisasi', STATE.token, payload).then(function(res){
    if(res && res.success){
      showToast('Data Rekening tersimpan.');
      loadOrgSettings_(); // ambil ulang dari server supaya STATE_ORG_SETTINGS ikut ter-update
    } else {
      showToast((res && res.message) || 'Gagal menyimpan Data Rekening.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// ================= GANTI NAMA PETUGAS (GLOBAL) =================
function populateGantiPetugasDropdown_(){
  var sel = document.getElementById('gantiPetugasLama');
  if(!sel) return;
  var current = sel.value;
  var petugasCount = {};
  (STATE.kotakList || []).forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasCount[p] = (petugasCount[p] || 0) + 1;
  });
  var petugasNames = Object.keys(petugasCount).sort();
  sel.innerHTML = '<option value="">-- Pilih Petugas --</option>' +
    petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + ' (' + petugasCount[p] + ' kotak)</option>'; }).join('');
  if(current && petugasNames.indexOf(current) > -1) sel.value = current;
  onGantiPetugasLamaChange_();
}

function onGantiPetugasLamaChange_(){
  var nama = document.getElementById('gantiPetugasLama').value;
  var info = document.getElementById('gantiPetugasJumlahKotak');
  if(!nama){ info.textContent = ''; return; }
  var count = (STATE.kotakList || []).filter(function(k){ return (k.namaPetugas || '').trim() === nama; }).length;
  info.textContent = '📦 ' + count + ' kotak akan ikut berubah ke nama baru.';
}

function terapkanGantiPetugasHandler(){
  var namaLama = document.getElementById('gantiPetugasLama').value;
  var namaBaru = document.getElementById('gantiPetugasBaru').value.trim();

  if(!namaLama){ showToast('Pilih Nama Petugas Lama terlebih dahulu.', 'error'); return; }
  if(!namaBaru){ showToast('Nama Petugas Baru wajib diisi.', 'error'); return; }
  if(normalizeKeyClient_(namaLama) === normalizeKeyClient_(namaBaru)){
    showToast('Nama baru harus berbeda dari nama lama.', 'error');
    return;
  }

  openConfirm(
    'Ganti semua kotak milik "' + namaLama + '" menjadi "' + namaBaru + '"? Tindakan ini akan mengubah SEMUA kotak yang saat ini memakai nama petugas lama sekaligus, tidak bisa dibatalkan otomatis.',
    function(){
      callServer('renamePetugasGlobal', STATE.token, { namaLama: namaLama, namaBaru: namaBaru }).then(function(res){
        closeModal('modalConfirm');
        if(res && res.success){
          showToast('Berhasil: ' + res.data.jumlahKotak + ' kotak diganti ke "' + namaBaru + '".');
          document.getElementById('gantiPetugasBaru').value = '';
          callServer('getKotakList', STATE.token).then(function(r2){
            if(r2 && r2.success){ STATE.kotakList = r2.data; populateGantiPetugasDropdown_(); }
          });
        } else {
          showToast((res && res.message) || 'Gagal mengganti nama petugas.', 'error');
        }
      }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
    },
    'Ya, Ganti Semua', 'Batal'
  );
}

function normalizeKeyClient_(str){
  return String(str || '').trim().toLowerCase();
}

function handleTogglePublik(){
  var aktif = document.getElementById('togglePublikAktif').checked;
  callServer('savePengaturanPublik', STATE.token, { aktif: aktif }).then(function(res){
    if(res && res.success){
      showToast('Pengaturan tampilan publik disimpan.');
    } else {
      showToast((res && res.message) || 'Gagal menyimpan.', 'error');
      document.getElementById('togglePublikAktif').checked = !aktif;
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// ---- Kelola Akun ----
var STATE_AKUN_LIST = [];

function loadAkunList(){
  document.getElementById('akunTableBody').innerHTML = '<tr><td colspan="5"><div class="loading-inline"><div class="spinner-sm"></div> Memuat akun...</div></td></tr>';
  callServer('getAkunList', STATE.token).then(function(res){
    if(res && res.success){
      STATE_AKUN_LIST = res.data;
      renderAkunTable_();
    } else {
      showToast((res && res.message) || 'Gagal memuat akun.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function renderAkunTable_(){
  if(!STATE_AKUN_LIST.length){
    document.getElementById('akunTableBody').innerHTML = '<tr><td colspan="5">' + emptyState('Belum ada akun.') + '</td></tr>';
    return;
  }
  document.getElementById('akunTableBody').innerHTML = STATE_AKUN_LIST.map(function(a){
    var badgeClass = a.status === 'Aktif' ? 'badge-aktif' : 'badge-nonaktif';
    var isSelf = STATE.session && normalizeKeyClient_(a.username) === normalizeKeyClient_(STATE.session.username);
    return '<tr>' +
      '<td><b>' + escapeHtml(a.username) + '</b>' + (isSelf ? ' <span style="color:var(--teks-muda);font-size:11px;">(Anda)</span>' : '') + '</td>' +
      '<td>' + escapeHtml(a.nama) + '</td>' +
      '<td><span class="badge">' + escapeHtml(a.role) + '</span></td>' +
      '<td><span class="badge ' + badgeClass + '">' + escapeHtml(a.status) + '</span></td>' +
      '<td><div class="row-actions">' +
        '<div class="icon-btn" onclick="openAkunModal(\'' + a.username + '\')" title="Edit / Hak Akses">✏️</div>' +
        (isSelf ? '' : '<div class="icon-btn danger" onclick="confirmDeleteAkun(\'' + a.username + '\')" title="Hapus">🗑️</div>') +
      '</div></td>' +
      '</tr>';
  }).join('');
}

function handleBuatAkunPetugasOtomatis(){
  openConfirm('Buat akun login otomatis untuk semua Nama Petugas yang belum punya akun? Password sementara semuanya "ganti123", wajib direset lewat tombol ✏️ setelah ini.', function(){
    closeModal('modalConfirm');
    callServer('buatAkunPetugasOtomatis', STATE.token).then(function(res){
      if(res && res.success){
        var d = res.data;
        showToast(d.created.length + ' akun petugas dibuat' + (d.skipped.length ? ', ' + d.skipped.length + ' dilewati (sudah ada)' : '') + '.');
        loadAkunList();
      } else {
        showToast((res && res.message) || 'Gagal membuat akun.', 'error');
      }
    }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
  }, 'Ya, Buat Akun', 'Batal');
}

function resetSemuaPasswordPetugasHandler(){
  var newPassword = document.getElementById('bulkPetugasPassword').value.trim() || 'ganti123';
  if(newPassword.length < 6){
    showToast('Password baru minimal 6 karakter.', 'error');
    return;
  }
  openConfirm('Ganti password SEMUA akun Petugas jadi "' + newPassword + '"? Setiap petugas akan pakai password baru yang SAMA ini untuk login berikutnya. Tindakan ini tidak bisa dibatalkan.', function(){
    closeModal('modalConfirm');
    callServer('resetSemuaPasswordPetugas', STATE.token, { newPassword: newPassword }).then(function(res){
      if(res && res.success){
        showToast('Password ' + res.data.jumlah + ' akun Petugas berhasil diganti.');
        document.getElementById('bulkPetugasPassword').value = '';
      } else {
        showToast((res && res.message) || 'Gagal mengganti password.', 'error');
      }
    }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
  }, 'Ya, Ganti Semua', 'Batal');
}

// Matriks "Hak Akses Menu" (modal Tambah/Edit User) SEKARANG diturunkan otomatis
// dari MENU_CONFIG (sumber tunggal yang sama dipakai buat sidebar) — supaya kalau
// nanti ada menu ATAU sub-menu baru ditambahkan ke MENU_CONFIG, baris hak aksesnya
// otomatis ikut muncul di sini juga, tanpa perlu ubah kode ini lagi.
// Menu 'pengaturan' sengaja tidak disertakan: menu Sistem (Kelola Akun, Hak Akses,
// Tampilan Publik, dst) selalu eksklusif Admin — harus sama dengan MENU_TREE_ di
// Code.gs (backend).
function buildHakAksesMenuTree_(){
  return MENU_CONFIG.filter(function(m){ return m.key !== 'pengaturan'; }).map(function(m){
    return {
      key: m.key,
      label: m.icon + ' ' + m.label,
      children: (m.subItems || []).map(function(s){
        return { key: m.key + '_' + s.key, label: s.label };
      })
    };
  });
}
var HAK_AKSES_MENU_TREE_ = buildHakAksesMenuTree_();
var MENU_LABEL_MAP_ = {};
var HAK_AKSES_CHILD_KEYS_ = {}; // set: menu-key yang statusnya sub-menu (buat gaya indentasi di tabel)
HAK_AKSES_MENU_TREE_.forEach(function(m){
  MENU_LABEL_MAP_[m.key] = m.label;
  m.children.forEach(function(c){
    MENU_LABEL_MAP_[c.key] = c.label;
    HAK_AKSES_CHILD_KEYS_[c.key] = true;
  });
});
var STATE_HAK_AKSES_ROWS = []; // baris matriks hak akses yang sedang diedit di modal

// Role yang hak aksesnya dibagi rata ke semua akun dengan role tsb (samakan
// dengan SHARED_PERMISSION_ROLES_ di backend). Dipakai untuk menampilkan
// notice di modal Tambah/Edit User.
var SHARED_PERMISSION_ROLES_CLIENT_ = ['petugas'];
function onAkunRoleChange_(){
  var role = document.getElementById('akunRole').value;
  var isShared = SHARED_PERMISSION_ROLES_CLIENT_.indexOf(normalizeKeyClient_(role)) > -1;
  document.getElementById('hakAksesSharedNotice').style.display = isShared ? 'block' : 'none';
}

function renderHakAksesMatrix_(rows){
  document.getElementById('hakAksesUserTableBody').innerHTML = rows.map(function(r, idx){
    var perms = ['lihat','tambah','edit','hapus','upload','unduh'];
    var isSub = !!HAK_AKSES_CHILD_KEYS_[r.menu];
    var label = MENU_LABEL_MAP_[r.menu] || r.menu;
    var tdMenuStyle = isSub
      ? 'padding-left:26px;font-size:12.5px;color:var(--teks-muda,#666);'
      : 'font-weight:600;';
    return '<tr' + (isSub ? ' style="background:rgba(0,0,0,0.02);"' : '') + '>' +
      '<td style="' + tdMenuStyle + '">' + (isSub ? '↳ ' : '') + label + '</td>' +
      perms.map(function(p){
        return '<td style="text-align:center;"><input type="checkbox" ' + (r[p] ? 'checked' : '') +
          ' onchange="STATE_HAK_AKSES_ROWS[' + idx + '].' + p + '=this.checked" style="width:16px;height:16px;"></td>';
      }).join('') +
      '</tr>';
  }).join('');
}

function openAkunModal(username){
  var isEdit = !!username;
  document.getElementById('akunModalMode').value = isEdit ? 'edit' : 'add';
  document.getElementById('akunUsernameAsli').value = username || '';
  document.getElementById('akunModalTitle').textContent = isEdit ? ('Edit User: ' + username) : 'Tambah User';
  document.getElementById('akunPasswordHint').textContent = isEdit ? '(kosongkan jika tidak diganti)' : '(kosongkan = ganti123)';
  document.getElementById('akunPassword').value = '';

  if(isEdit){
    var akun = STATE_AKUN_LIST.find(function(a){ return normalizeKeyClient_(a.username) === normalizeKeyClient_(username); });
    document.getElementById('akunUsername').value = akun ? akun.username : username;
    document.getElementById('akunUsername').disabled = true;
    document.getElementById('akunNama').value = akun ? akun.nama : '';
    document.getElementById('akunRole').value = akun ? akun.role : 'Bendahara';
    document.getElementById('akunAktif').checked = !akun || akun.status === 'Aktif';
    onAkunRoleChange_();

    STATE_HAK_AKSES_ROWS = [];
    document.getElementById('hakAksesUserTableBody').innerHTML = '<tr><td colspan="7"><div class="loading-inline"><div class="spinner-sm"></div> Memuat hak akses...</div></td></tr>';
    openModal('modalAkun');
    callServer('getHakAksesUser', STATE.token, username).then(function(res){
      if(res && res.success){
        STATE_HAK_AKSES_ROWS = res.data;
        renderHakAksesMatrix_(STATE_HAK_AKSES_ROWS);
      } else {
        showToast((res && res.message) || 'Gagal memuat hak akses.', 'error');
      }
    }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
  } else {
    document.getElementById('akunUsername').value = '';
    document.getElementById('akunUsername').disabled = false;
    document.getElementById('akunNama').value = '';
    document.getElementById('akunRole').value = 'Bendahara';
    document.getElementById('akunAktif').checked = true;
    onAkunRoleChange_();
    STATE_HAK_AKSES_ROWS = Object.keys(MENU_LABEL_MAP_).map(function(m){
      return { menu: m, lihat: false, tambah: false, edit: false, hapus: false, upload: false, unduh: false };
    });
    renderHakAksesMatrix_(STATE_HAK_AKSES_ROWS);
    openModal('modalAkun');
  }
}

function saveAkunManual(){
  var isEdit = document.getElementById('akunModalMode').value === 'edit';
  var nama = document.getElementById('akunNama').value.trim();
  if(!nama){ showToast('Nama wajib diisi.', 'error'); return; }
  var role = document.getElementById('akunRole').value;

  var payload = {
    username: isEdit ? document.getElementById('akunUsernameAsli').value : document.getElementById('akunUsername').value.trim(),
    nama: nama,
    role: role,
    password: document.getElementById('akunPassword').value.trim(),
    aktif: document.getElementById('akunAktif').checked,
    rows: STATE_HAK_AKSES_ROWS
  };

  var btn = document.getElementById('btnSaveAkun');
  setBtnLoading(btn, true, 'Menyimpan...');

  var fn = isEdit ? 'updateAkunManual' : 'addAkunManual';
  callServer(fn, STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, '💾 Simpan');
    if(res && res.success){
      if(!isEdit && res.data && res.data.password){
        showToast('Akun "' + res.data.username + '" dibuat. Password: ' + res.data.password);
      } else {
        showToast('Akun "' + payload.username + '" tersimpan.');
      }
      closeModal('modalAkun');
      loadAkunList();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan akun.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, '💾 Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeleteAkun(username){
  openConfirm('Hapus akun "' + username + '"? Tindakan ini tidak dapat dibatalkan.', function(){
    callServer('deleteAkun', STATE.token, username).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Akun dihapus.');
        loadAkunList();
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ---- Setting Tampilan Publik ----
var STATE_AKSES_MENU = [];

var AKSES_MENU_SUB_ACTIONS_ = ['tambah', 'edit', 'hapus', 'unduh'];

function loadAksesMenuTable(){
  document.getElementById('aksesMenuTableBody').innerHTML = '<tr><td colspan="6"><div class="loading-inline"><div class="spinner-sm"></div> Memuat...</div></td></tr>';
  callServer('getAksesMenu', STATE.token).then(function(res){
    if(res && res.success){
      STATE_AKSES_MENU = res.data;
      renderAksesMenuTable_();
    } else {
      showToast((res && res.message) || 'Gagal memuat pengaturan.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function renderAksesMenuTable_(){
  document.getElementById('aksesMenuTableBody').innerHTML = STATE_AKSES_MENU.map(function(r, idx){
    var subDisabled = !r.publik; // Tambah/Edit/Hapus/Unduh cuma relevan kalau menu tampil publik
    return '<tr>' +
      '<td>' + escapeHtml(r.label) + '</td>' +
      '<td style="text-align:center;"><input type="checkbox" ' + (r.publik ? 'checked' : '') +
        ' onchange="handleAksesMenuPublikChange_(' + idx + ',this.checked)" style="width:16px;height:16px;"></td>' +
      AKSES_MENU_SUB_ACTIONS_.map(function(action){
        return '<td style="text-align:center;"><input type="checkbox" ' + (r[action] ? 'checked' : '') + (subDisabled ? ' disabled' : '') +
          ' onchange="STATE_AKSES_MENU[' + idx + '].' + action + '=this.checked" style="width:16px;height:16px;"></td>';
      }).join('') +
      '</tr>';
  }).join('');
}

// Kalau menu dimatikan dari "Tampil ke Publik", ikut matikan toggle
// Tambah/Edit/Hapus/Unduh-nya juga supaya tidak ada aksi publik yang "menyala diam-diam"
// untuk menu yang sudah tidak tampil.
function handleAksesMenuPublikChange_(idx, checked){
  STATE_AKSES_MENU[idx].publik = checked;
  if(!checked){
    AKSES_MENU_SUB_ACTIONS_.forEach(function(action){ STATE_AKSES_MENU[idx][action] = false; });
  }
  renderAksesMenuTable_();
}

function saveAksesMenuHandler(){
  callServer('saveAksesMenu', STATE.token, STATE_AKSES_MENU).then(function(res){
    if(res && res.success){
      showToast('Pengaturan tampilan publik tersimpan.');
    } else {
      showToast((res && res.message) || 'Gagal menyimpan.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// ================= MODAL HELPERS =================
function openModal(id){ document.getElementById(id).classList.add('show'); }
function closeModal(id){ document.getElementById(id).classList.remove('show'); }

function openConfirm(message, onYes, yesLabel, noLabel){
  document.getElementById('confirmMessage').textContent = message;
  document.getElementById('btnConfirmNo').textContent = noLabel || 'Batal';
  var btn = document.getElementById('btnConfirmYes');
  var newBtn = btn.cloneNode(true); // reset listener lama
  newBtn.textContent = yesLabel || 'Ya, Hapus';
  newBtn.className = yesLabel ? 'btn btn-primary' : 'btn btn-danger';
  btn.parentNode.replaceChild(newBtn, btn);
  newBtn.addEventListener('click', onYes);
  openModal('modalConfirm');
}

document.querySelectorAll('.modal-overlay').forEach(function(overlay){
  overlay.addEventListener('click', function(e){
    if(e.target === overlay) overlay.classList.remove('show');
  });
});
</script>
</body>
</html>

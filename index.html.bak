              <label>Nama Kegiatan / Sumber Dana *</label>
              <input type="text" id="rkatNamaKegiatan" placeholder="Contoh: Setoran Koin Rutin, Santunan Yatim Ramadhan, dll">
            </div>
            <div class="form-group">
              <label>Target Anggaran (Rp) *</label>
              <input type="text" inputmode="numeric" id="rkatTargetAnggaran" placeholder="0" oninput="liveFormatRupiah_(this)">
            </div>
            <div class="form-group">
              <label>Keterangan (opsional)</label>
              <input type="text" id="rkatKeterangan" placeholder="Catatan tambahan">
            </div>

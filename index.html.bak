      <button class="btn btn-outline" onclick="closeModal('modalEditLaporan')">Batal</button>
      <button class="btn btn-primary" id="btnSaveEditLaporan" onclick="saveEditLaporan()">Simpan</button>
    </div>
  </div>
</div>

<div id="toastContainer"></div>

<script>
// ================= STATE =================
var STATE = {
  token: localStorage_get('ekoin_token', null),
  session: null,
  myPerms: null, // null = Admin (akses penuh). Selain itu: {menu: {lihat,tambah,edit,hapus,upload,unduh}}
  kotakList: [],
  dusunList: [],
  setoranList: [],
  dashboard: null,
  trendChartInstance: null,
  currentView: 'dashboard'
};

// Cek apakah akun yang sedang login boleh melakukan `action` (lihat/tambah/edit/hapus/upload/unduh)
// pada `menu` tertentu. Admin selalu true. Dipakai untuk menyembunyikan/menonaktifkan
// tombol Tambah/Edit/Hapus/Upload/Unduh di UI sesuai hak akses per-user yang diatur Admin.
function canDo(menu, action){
  if(STATE.session && normalizeKeyClient_(STATE.session.role) === 'admin') return true;
  if(!STATE.myPerms || !STATE.myPerms[menu]) return false;
  return !!STATE.myPerms[menu][action];
}

// Menerjemahkan jenisKas ('UPZISNU'/'BOP') ke kunci sub-menu hak akses yang
// sesuai — harus sama persis dengan kasChildKey_ di Code.gs (backend), supaya
// tombol Edit/Hapus per baris Kas UPZISNU/BOP tampil sesuai izin yang benar.
function kasChildKeyClient_(jenisKas){
  return normalizeKeyClient_(jenisKas) === 'bop' ? 'kas_bop' : 'kas_upzisnu';
}

// Mengunci semua input/select/tombol di dalam sebuah container (dipakai untuk
// Mode Publik atau akun tanpa hak Tambah/Edit) supaya halaman tetap tampil
// persis sama, hanya saja tidak bisa diketik/diklik. Elemen dengan id di
// `exceptIds` (mis. tombol ganti tab) tetap aktif.
function applyReadOnlyLock(container, isReadOnly, exceptIds){
  if(!container) return;
  exceptIds = exceptIds || [];
  container.querySelectorAll('input, select, textarea, button').forEach(function(el){
    if(exceptIds.indexOf(el.id) > -1) return;
    el.disabled = isReadOnly;
  });
  container.classList.toggle('read-only-locked', isReadOnly);
}

// NB: localStorage tidak didukung di beberapa konteks HtmlService sandbox lama,
// jadi kita bungkus dengan fallback in-memory supaya tidak error.
var MEMORY_STORE = {};
function localStorage_get(key, def){
  try{
    var v = localStorage.getItem(key);
    return v === null ? def : v;
  }catch(e){ return MEMORY_STORE[key] !== undefined ? MEMORY_STORE[key] : def; }
}
function localStorage_set(key, val){
  try{ localStorage.setItem(key, val); }catch(e){ MEMORY_STORE[key] = val; }
}
function localStorage_remove(key){
  try{ localStorage.removeItem(key); }catch(e){ delete MEMORY_STORE[key]; }
}

// ================= HELPERS =================
function formatRupiah(n){
  n = Number(n) || 0;
  return 'Rp ' + n.toLocaleString('id-ID');
}
function formatAngka(n){
  n = Number(n) || 0;
  return n.toLocaleString('id-ID');
}
function formatTanggalIndo(tgl){
  if(!tgl) return '-';
  var bulan = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  var parts = String(tgl).split('-');
  if(parts.length !== 3) return tgl;
  return parseInt(parts[2],10) + ' ' + bulan[parseInt(parts[1],10)-1] + ' ' + parts[0];
}
function todayISO(){
  var d = new Date();
  var m = ('0'+(d.getMonth()+1)).slice(-2);
  var day = ('0'+d.getDate()).slice(-2);
  return d.getFullYear()+'-'+m+'-'+day;
}
function showToast(message, type){
  type = type || 'success';
  var el = document.createElement('div');
  el.className = 'toast ' + type;
  el.innerHTML = (type==='success' ? '✅ ' : '⚠️ ') + message;
  document.getElementById('toastContainer').appendChild(el);
  setTimeout(function(){ el.style.opacity='0'; el.style.transition='opacity .3s'; setTimeout(function(){el.remove();}, 300); }, 3200);
}
function setBtnLoading(btn, loading, textLoading, textNormal){
  if(loading){ btn.disabled = true; btn.dataset.orig = btn.innerHTML; btn.innerHTML = textLoading || 'Menyimpan...'; }
  else{ btn.disabled = false; btn.innerHTML = textNormal || btn.dataset.orig || btn.innerHTML; }
}
function escapeHtml(str){
  if(str === null || str === undefined) return '';
  return String(str).replace(/[&<>"']/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}

// ================= GAS CALL WRAPPER =================
// URL Web App Apps Script — dipakai HANYA sebagai fallback saat halaman ini
// dibuka dari luar Apps Script (mis. hosting statis di Vercel/GitHub Pages),
// di mana google.script.run tidak tersedia sama sekali. Kalau nanti alamat
// deployment Apps Script berganti, cukup update baris ini saja.
var GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbwxr2WZ9nHuXTELzNRDTPYQ57iST_Ts5ZO0AEFYNLP3RrCZsmOOMu9FrrLGAHjqu6y-/exec';

function callServer(fnName){
  var args = Array.prototype.slice.call(arguments, 1);
  return new Promise(function(resolve, reject){
    function selesai(res){
      if(res && res.success === false && res.message === 'Sesi berakhir. Silakan login kembali.'){
        handleSessionExpired();
      }
      resolve(res);
    }

    // Native: halaman ini dibuka LANGSUNG dari Apps Script, google.script.run
    // tersedia otomatis — jalur ini yang selalu dipakai saat diakses lewat
    // URL .../exec Apps Script.
    if(typeof google !== 'undefined' && google.script && google.script.run){
      google.script.run
        .withSuccessHandler(selesai)
        .withFailureHandler(function(err){ reject(err); })
        [fnName].apply(null, args);
      return;
    }

    // Fallback: halaman ini dibuka dari hosting statis (Vercel/GitHub Pages,
    // dst) di mana google.script.run tidak ada — panggil server lewat
    // fetch() biasa. Sengaja pakai Content-Type "text/plain" (bukan
    // application/json) supaya browser TIDAK mengirim preflight OPTIONS,
    // karena Apps Script Web App tidak bisa menangani preflight request.
    fetch(GAS_WEB_APP_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({ fn: fnName, args: args })
    })
      .then(function(res){ return res.json(); })
      .then(selesai)
      .catch(function(err){ reject(err); });
  });
}

function handleSessionExpired(){
  showToast('Sesi Anda berakhir, silakan login kembali.', 'error');
  localStorage_remove('ekoin_token');
  STATE.token = null;
  setTimeout(function(){ location.reload(); }, 1200);
}

// ================= INIT =================
window.onload = function(){
  document.getElementById('loginYear').textContent = new Date().getFullYear();
  document.getElementById('publicTopbarYear').textContent = new Date().getFullYear();
  loadOrgSettings_(); // publik, tidak perlu login — dipanggil sedini mungkin biar logo sempat tampil pas loading

  if(STATE.token){
    callServer('checkSession', STATE.token).then(function(res){
      if(res && res.success){
        STATE.session = res.data;
        bootApp();
      } else {
        localStorage_remove('ekoin_token');
        showPublicScreen();
      }
    }).catch(function(){ showPublicScreen(); });
  } else {
    showPublicScreen();
  }
};

function showLogin(){
  document.getElementById('loadingScreen').style.display = 'none';
  document.getElementById('publicScreen').style.display = 'none';
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

function showLoginFromPublic(){
  showLogin();
}

document.getElementById('btnBackToPublic').addEventListener('click', function(){
  showPublicScreen();
});

// Mode Publik sekarang memakai SPA yang sama persis dengan akun yang login
// (view-dashboard/view-kotak/view-setoran/view-laporan) — hanya saja sesi yang
// dipakai bersifat read-only (lihat requirePermission_ di server). Ini
// menjamin tampilannya identik dengan tampilan Admin/staf, tidak ada lagi UI
// publik terpisah yang bisa berbeda/ketinggalan fitur.
function showPublicScreen(){
  document.getElementById('loadingScreen').style.display = 'flex';
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('publicScreen').style.display = 'none';
  document.getElementById('app').style.display = 'none';

  callServer('loginPublic').then(function(res){
    if(!res || !res.success){
      document.getElementById('loadingScreen').style.display = 'none';
      showLogin();
      showToast((res && res.message) || 'Tampilan publik belum diaktifkan. Silakan login.', 'error');
      return;
    }
    STATE.token = res.data.token;
    STATE.session = null; // diisi ulang oleh bootApp() dari getInitialData
    bootApp(false);
  }).catch(function(err){
    document.getElementById('loadingScreen').style.display = 'none';
    showLogin();
    showToast('Gagal memuat tampilan publik: ' + err.message, 'error');
  });
}

function loadPublicView(){
  document.getElementById('publicStatGrid').innerHTML = '<div class="loading-inline"><div class="spinner-sm"></div> Memuat data...</div>';
  document.getElementById('publicDisabledNotice').style.display = 'none';

  callServer('getPublicBootstrap').then(function(res){
    if(!res || !res.success){
      document.getElementById('publicStatGrid').innerHTML = '';
      document.getElementById('publicDisabledNotice').style.display = 'block';
      return;
    }
    var d = res.data;
    STATE.menuPublik = d.menuPublik || ['dashboard'];
    renderPublicNav_(STATE.menuPublik, STATE.publicView || 'dashboard');

    document.getElementById('publicStatGrid').innerHTML =
      statCard('📦', 'Kotak Aktif', d.totalKotakAktif, d.totalKotak + ' total kotak') +
      statCard('💰', 'Total Terkumpul', formatRupiah(d.totalNominalKeseluruhan), '', true) +
      statCard('🏦', 'Bulan Ini', formatRupiah(d.totalNominalBulanIni), '', true) +
      statCard('🗺️', 'Dusun Aktif', d.dusunAktifBulanIni, 'bulan ini');

    renderPublicTrendChart_(d.trend);
    renderPublicDusunBreakdown_(d.perDusun);
  }).catch(function(){
    document.getElementById('publicStatGrid').innerHTML = '';
    document.getElementById('publicDisabledNotice').style.display = 'block';
  });
}

// Navigasi sidebar/bottom-nav di mode publik. 'dashboard' dan 'kotak' punya
// tampilan publik nyata (read-only); menu lain yang mungkin diizinkan Admin
// untuk Publik di masa depan akan menampilkan ajakan login (datanya perlu
// login untuk diakses lengkap).
var PUBLIC_VIEWS_WITH_CONTENT_ = ['dashboard', 'kotak'];
function switchPublicView(viewKey){
  closeSidebar('publicSidebar');
  STATE.publicView = viewKey;
  document.querySelectorAll('#publicSidebar .nav-item, #publicBottomNav .bn-item').forEach(function(n){
    n.classList.toggle('active', n.dataset.view === viewKey);
  });
  document.getElementById('publicDashboardContent').style.display = viewKey === 'dashboard' ? '' : 'none';
  document.getElementById('publicKotakContent').style.display = viewKey === 'kotak' ? '' : 'none';
  var hasContent = PUBLIC_VIEWS_WITH_CONTENT_.indexOf(viewKey) > -1;
  document.getElementById('publicComingSoon').style.display = hasContent ? 'none' : '';
  if(viewKey === 'dashboard') loadPublicView();
  if(viewKey === 'kotak') loadPublicKotakView_();
}

// Memuat data kotak untuk tampilan publik (read-only): tidak ada tombol
// tambah/upload/edit/hapus, hanya pencarian dan filter seperti tampilan Admin.
function loadPublicKotakView_(){
  document.getElementById('publicKotakTableBody').innerHTML = '<tr><td colspan="7"><div class="loading-inline"><div class="spinner-sm"></div> Memuat data kotak...</div></td></tr>';

  callServer('getPublicKotakList').then(function(res){
    if(!res || !res.success){
      document.getElementById('publicKotakTableBody').innerHTML = '<tr><td colspan="7">' + emptyState(res && res.error ? res.error : 'Data tidak tersedia.') + '</td></tr>';
      return;
    }
    STATE.publicKotakList = res.data.list || [];

    var dusunSel = document.getElementById('publicKotakFilterDusun');
    dusunSel.innerHTML = '<option value="">Semua Dusun</option>' +
      (res.data.dusunList || []).map(function(d){ return '<option value="' + escapeHtml(d) + '">' + escapeHtml(d) + '</option>'; }).join('');

    var petugasSet = {};
    STATE.publicKotakList.forEach(function(k){
      var p = (k.namaPetugas || '').trim();
      if(p) petugasSet[p] = true;
    });
    var petugasSel = document.getElementById('publicKotakFilterPetugas');
    petugasSel.innerHTML = '<option value="">Semua Petugas</option>' +
      Object.keys(petugasSet).sort().map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + '</option>'; }).join('');

    renderPublicKotakTable_();
  }).catch(function(){
    document.getElementById('publicKotakTableBody').innerHTML = '<tr><td colspan="7">' + emptyState('Gagal memuat data.') + '</td></tr>';
  });
}

function renderPublicKotakTable_(){
  var list = STATE.publicKotakList || [];
  var q = (document.getElementById('publicKotakSearch').value || '').toLowerCase().trim();
  var filterDusun = document.getElementById('publicKotakFilterDusun').value;
  var filterPetugas = document.getElementById('publicKotakFilterPetugas').value;
  var filterStatus = document.getElementById('publicKotakFilterStatus').value;

  var filtered = list.filter(function(k){
    if(q && !((k.nama||'').toLowerCase().indexOf(q) > -1 || String(k.id||'').toLowerCase().indexOf(q) > -1)) return false;
    if(filterDusun && k.dusun !== filterDusun) return false;
    if(filterPetugas && k.namaPetugas !== filterPetugas) return false;
    if(filterStatus && k.status !== filterStatus) return false;
    return true;
  });

  if(!filtered.length){
    document.getElementById('publicKotakTableBody').innerHTML = '<tr><td colspan="7">' + emptyState('Tidak ada data kotak.') + '</td></tr>';
    return;
  }

  document.getElementById('publicKotakTableBody').innerHTML = filtered.map(function(k){
    return '<tr>' +
      '<td>' + escapeHtml(k.noUrut) + '</td>' +
      '<td><b>' + escapeHtml(k.id) + '</b></td>' +
      '<td>' + escapeHtml(k.nama) + '</td>' +
      '<td>' + escapeHtml(k.alamat) + '</td>' +
      '<td>' + escapeHtml(k.dusun) + '</td>' +
      '<td>' + escapeHtml(k.namaPetugas) + '</td>' +
      '<td><span class="badge ' + (k.status === 'Aktif' ? 'badge-aktif' : 'badge-nonaktif') + '">' + escapeHtml(k.status) + '</span></td>' +
      '</tr>';
  }).join('');
}

function renderPublicTrendChart_(trend){
  var canvas = document.getElementById('publicTrendChart');
  if(!canvas || !trend) return;
  var ctx = canvas.getContext('2d');
  if(STATE.publicChartInstance) STATE.publicChartInstance.destroy();
  STATE.publicChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: trend.map(function(t){ return t.label; }),
      datasets: [{ data: trend.map(function(t){ return t.nominal; }), backgroundColor: '#146c43', borderRadius: 6, maxBarThickness: 38 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { ticks: { callback: function(v){ return 'Rp ' + (v/1000) + 'rb'; } }, grid:{color:'#eef3f0'} }, x: { grid: { display: false } } }
    }
  });
}

function renderPublicDusunBreakdown_(perDusun){
  if(!perDusun || !perDusun.length){
    document.getElementById('publicDusunBreakdown').innerHTML = emptyState('Belum ada data.');
    return;
  }
  var maxNominal = Math.max.apply(null, perDusun.map(function(p){ return p.nominal; }).concat([1]));
  var sorted = perDusun.slice().sort(function(a,b){ return b.nominal - a.nominal; });
  document.getElementById('publicDusunBreakdown').innerHTML = sorted.map(function(p){
    var pct = Math.round((p.nominal / maxNominal) * 100);
    return '<div class="dusun-row">' +
      '<div class="dusun-row-head"><span>' + escapeHtml(p.dusun) + '</span><b>' + formatRupiah(p.nominal) + '</b></div>' +
      '<div class="progress-bg"><div class="progress-fill" style="width:' + pct + '%"></div></div>' +
      '</div>';
  }).join('');
}

document.addEventListener('DOMContentLoaded', function(){
  document.getElementById('loginForm').addEventListener('submit', handleLogin);
});

function handleLogin(e){
  if(e) e.preventDefault();
  var username = document.getElementById('loginUsername').value.trim();
  var password = document.getElementById('loginPassword').value;
  var errBox = document.getElementById('loginError');
  errBox.style.display = 'none';

  if(!username || !password){
    errBox.textContent = 'Username dan password wajib diisi.';
    errBox.style.display = 'block';
    return;
  }

  var btn = document.getElementById('btnLogin');
  setBtnLoading(btn, true, 'Memproses...');

  callServer('login', username, password).then(function(res){
    setBtnLoading(btn, false, null, 'Masuk');
    if(res && res.success){
      STATE.token = res.data.token;
      STATE.session = res.data;
      localStorage_set('ekoin_token', STATE.token);
      document.getElementById('loginScreen').style.display = 'none';
      bootApp(true);
    } else {
      errBox.textContent = (res && res.message) || 'Login gagal.';
      errBox.style.display = 'block';
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Masuk');
    errBox.textContent = 'Terjadi kesalahan koneksi: ' + err.message;
    errBox.style.display = 'block';
  });
}

// ================= RUNNING TEXT (ticker di bawah topbar) =================
var RUNNING_TEXT_SPEED_SECONDS_CLIENT_ = { lambat: 40, sedang: 25, cepat: 15, sangatcepat: 8 };

function loadRunningText_(){
  callServer('getRunningText', STATE.token).then(function(res){
    if(res && res.success) applyRunningTextSettings_(res.data);
  }).catch(function(){ /* diam-diam gagal, bukan fitur kritikal */ });
}

function applyRunningTextSettings_(settings){
  var bar = document.getElementById('runningTextBar');
  var track = document.getElementById('runningTextTrack');
  if(!bar || !track) return;

  var isiRaw = String(settings && settings.isi || '');
  var aktif = !!(settings && settings.aktif && isiRaw.trim());
  bar.classList.toggle('show', aktif);
  document.body.classList.toggle('has-running-text', aktif);

  if(aktif){
    // Admin bisa isi BEBERAPA info sekaligus (satu baris = satu info di
    // textarea Pengaturan > Running Text) — di sini otomatis disambung jadi
    // satu teks berjalan dengan ikon pemisah "•" di antara tiap info.
    var items = isiRaw.split('\n').map(function(s){ return s.trim(); }).filter(Boolean);
    track.innerHTML = items.map(escapeHtml).join('<span class="running-text-sep">•</span>');
    var durasi = RUNNING_TEXT_SPEED_SECONDS_CLIENT_[settings.kecepatan] || 25;
    track.style.animationDuration = durasi + 's';
  }
}

function bootApp(isFreshLogin){
  document.getElementById('loadingScreen').style.display = 'flex';
  document.getElementById('publicScreen').style.display = 'none';
  document.getElementById('loginScreen').style.display = 'none';
  callServer('getInitialData', STATE.token).then(function(res){
    document.getElementById('loadingScreen').style.display = 'none';
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat data awal.', 'error');
      showLogin();
      return;
    }
    STATE.session = res.data.session;
    STATE.kotakList = res.data.kotakList;
    STATE.dusunList = res.data.dusunList;
    STATE.dashboard = res.data.dashboard;
    STATE.setoranRecent = res.data.setoranRecent;
    STATE.menuAllowed = res.data.menuAllowed || ['dashboard'];
    STATE.myPerms = res.data.myPermissions || null;

    document.getElementById('app').style.display = 'block';
    document.getElementById('topbarYear').textContent = new Date().getFullYear();

    renderTopbarUser_();
    renderAppNav_(STATE.menuAllowed);
    populateDusunSelects();
    renderDashboard();
    loadRunningText_();
    loadOrgSettings_();
    if(STATE.menuAllowed.length){
      switchView(STATE.menuAllowed.indexOf('dashboard') > -1 ? 'dashboard' : STATE.menuAllowed[0]);
    } else {
      document.querySelectorAll('.view').forEach(function(v){ v.classList.remove('active'); });
      document.getElementById('appSidebar').innerHTML = '<div style="padding:16px;font-size:12.5px;color:var(--teks-muda);">Belum ada menu yang bisa diakses.</div>';
    }

    if(isFreshLogin){
      showToast('Berhasil masuk. Selamat datang, ' + (STATE.session.nama || '') + '!');
    }
  }).catch(function(err){
    document.getElementById('loadingScreen').style.display = 'none';
    showToast('Gagal terhubung ke server: ' + err.message, 'error');
    showLogin();
  });
}

// ================= HAMBURGER MENU (MOBILE) =================
// Menggantikan bottom-nav lama: di layar sempit, .sidebar menjadi drawer
// off-canvas yang dibuka/ditutup lewat tombol hamburger di topbar.
function sidebarOverlayId_(sidebarId){
  return sidebarId === 'publicSidebar' ? 'publicSidebarOverlay' : 'appSidebarOverlay';
}
function toggleSidebar(sidebarId){
  var sb = document.getElementById(sidebarId);
  if(!sb) return;
  var isOpen = sb.classList.toggle('open');
  var overlay = document.getElementById(sidebarOverlayId_(sidebarId));
  if(overlay) overlay.classList.toggle('show', isOpen);
}
function closeSidebar(sidebarId){
  var sb = document.getElementById(sidebarId);
  if(sb) sb.classList.remove('open');
  var overlay = document.getElementById(sidebarOverlayId_(sidebarId));
  if(overlay) overlay.classList.remove('show');
}

// Konfigurasi menu terpusat: dipakai untuk merender sidebar & bottom-nav,
// baik untuk pengguna yang sudah login maupun mode publik.
var MENU_CONFIG = [
  { key: 'dashboard', label: 'Dashboard', shortLabel: 'Dashboard', icon: '📊' },
  { key: 'kotak', label: 'Data Kotak', shortLabel: 'Kotak', icon: '📦' },
  { key: 'setoran', label: 'Setoran Koin', shortLabel: 'Setoran', icon: '💰' },
  { key: 'laporan', label: 'Laporan Koin', shortLabel: 'Laporan', icon: '📄', subItems: [
    { key: 'perolehan', label: '📄 Laporan Perolehan' },
    { key: 'rincian', label: '💵 Rekap Rincian Koin' },
    { key: 'rekapPetugas', label: '📋 Rekap Petugas' }
  ]},
  { key: 'kas', label: 'Data Kas', shortLabel: 'Kas', icon: '🏦', subItems: [
    { key: 'upzisnu', label: '🏦 Kas UPZISNU' },
    { key: 'bop', label: '💼 Kas BOP' },
    { key: 'pencairan', label: '🧾 Rekap Pencairan Dana' }
  ]},
  { key: 'pentasyarufan', label: 'Pentasyarufan', shortLabel: 'Tasyaruf', icon: '🎁', subItems: [
    { key: 'rekap', label: '📋 Rekap Pentasyarufan' }
  ]},
  { key: 'rkat', label: 'RKAT', shortLabel: 'RKAT', icon: '📈', subItems: [
    { key: 'input', label: '➕ Input RKAT' },
    { key: 'data', label: '📊 Data RKAT' },
    { key: 'realisasi', label: '📉 Realisasi Anggaran' }
  ]},
  { key: 'pengaturan', label: 'Pengaturan', shortLabel: 'Atur', icon: '⚙️', subItems: [
    { key: 'akun', label: '🔒 Akun Saya' },
    { key: 'publik', label: '🌐 Tampilan Publik' },
    { key: 'runningtext', label: '📢 Running Text' },
    { key: 'organisasi', label: '🏢 Data Organisasi' },
    { key: 'rekening', label: '🏦 Data Rekening' },
    { key: 'gantipetugas', label: '🔀 Ganti Nama Petugas' },
    { key: 'user', label: '👥 Manajemen User' }
  ]}
];

// Melacak grup sidebar mana (Laporan/Pengaturan) yang sedang dibuka (expanded).
var STATE_NAV_EXPANDED = {};

// Mengembalikan sub-tab yang lagi aktif untuk suatu grup menu, dipakai untuk
// menyorot sub-item yang tepat di sidebar.
function getActiveSubTabFor_(menuKey){
  if(menuKey === 'laporan') return typeof STATE_LAPORAN_TAB !== 'undefined' ? STATE_LAPORAN_TAB : null;
  if(menuKey === 'pengaturan') return typeof STATE_PENGATURAN_TAB !== 'undefined' ? STATE_PENGATURAN_TAB : null;
  if(menuKey === 'kas') return typeof STATE_KAS_TAB !== 'undefined' ? STATE_KAS_TAB : null;
  if(menuKey === 'rkat') return typeof STATE_RKAT_TAB !== 'undefined' ? STATE_RKAT_TAB : null;
  if(menuKey === 'pentasyarufan') return 'rekap';
  return null;
}

// Klik pada header grup (mis. "Laporan"): kalau grup itu belum jadi
// halaman aktif, langsung pindah ke situ (pakai sub-tab terakhir yang
// aktif) sekaligus expand. Kalau grup itu SUDAH aktif, klik header cuma
// buka/tutup daftar sub-menunya saja tanpa reload data.
// Klik pada JUDUL grup (mis. "Laporan", "Pengaturan") di sidebar: HANYA
// buka/tutup daftar sub-menunya, TIDAK langsung pindah ke sub-menu pertama.
// Berlaku sama untuk semua menu yang punya subItems, termasuk yang nanti
// ditambahkan — tidak perlu diubah lagi per menu baru.
function onNavGroupHeaderClick_(menuKey){
  var akanDibuka = !STATE_NAV_EXPANDED[menuKey];
  STATE_NAV_EXPANDED = {}; // tutup semua grup lain dulu (mode accordion — cuma 1 grup terbuka sekaligus)
  STATE_NAV_EXPANDED[menuKey] = akanDibuka;
  renderAppNav_(STATE.menuAllowed || []);
}

// Klik pada salah satu sub-menu di dalam grup (mis. "Rekap Petugas" di
// dalam grup Laporan): set tab yang dipilih lalu pindah ke halamannya.
function switchViewSubTab_(menuKey, subKey){
  STATE_NAV_EXPANDED = {}; // tutup grup lain juga (mode accordion)
  STATE_NAV_EXPANDED[menuKey] = true;
  if(menuKey === 'laporan') STATE_LAPORAN_TAB = subKey;
  if(menuKey === 'pengaturan') STATE_PENGATURAN_TAB = subKey;
  if(menuKey === 'kas') STATE_KAS_TAB = subKey;
  if(menuKey === 'rkat') STATE_RKAT_TAB = subKey;
  switchView(menuKey);
}

// Merender sidebar + bottom-nav untuk pengguna yang sudah login. HANYA
// menu yang diizinkan untuk role saat ini yang dirender — tidak ada lagi
// menu "terkunci" yang tampil tapi tidak bisa diklik.
// "pengaturan" HANYA dirender untuk Admin (jadi menu biasa di sidebar/bottom-nav,
// sama seperti menu lain). Akun Petugas/Bendahara dkk tidak melihatnya sama
// sekali, karena bukan menu yang diatur lewat Hak Akses Menu.
// Menu dengan `subItems` (Laporan, Pengaturan) dirender sebagai grup yang
// bisa di-expand/collapse — sub-menunya tampil langsung di sidebar, BUKAN
// sebagai tombol tab terpisah di halaman.
function renderAppNav_(allowed){
  allowed = allowed || [];
  var isAdmin = STATE.session && normalizeKeyClient_(STATE.session.role) === 'admin';
  var items = MENU_CONFIG.filter(function(m){
    if(m.key === 'pengaturan') return isAdmin;
    return allowed.indexOf(m.key) > -1;
  });
  var activeView = (STATE.currentView && allowed.concat('pengaturan').indexOf(STATE.currentView) > -1) ? STATE.currentView : (items[0] ? items[0].key : null);

  var sidebar = document.getElementById('appSidebar');
  var bottomNav = document.getElementById('appBottomNav');

  sidebar.innerHTML = items.map(function(m){
    if(m.subItems && m.subItems.length){
      // Sub-menu yang di-uncheck Admin lewat matriks Hak Akses (mis. "Rekap
      // Petugas" di dalam grup Laporan) otomatis disembunyikan dari sidebar.
      // Admin selalu melihat semuanya (canDo() sudah bypass untuk Admin).
      var visibleSub = m.subItems.filter(function(s){ return canDo(m.key + '_' + s.key, 'lihat'); });
      if(!visibleSub.length) return ''; // tidak ada sub-menu yang diizinkan sama sekali untuk akun ini
      var isActiveGroup = m.key === activeView;
      var expanded = !!STATE_NAV_EXPANDED[m.key];
      var activeSub = isActiveGroup ? getActiveSubTabFor_(m.key) : null;
      return '<div class="nav-group' + (expanded ? ' expanded' : '') + '">' +
        '<div class="nav-group-header' + (isActiveGroup ? ' active' : '') + '" onclick="onNavGroupHeaderClick_(\'' + m.key + '\')">' +
          '<span class="nav-icon">' + m.icon + '</span>' +
          '<span class="nav-group-label">' + escapeHtml(m.label) + '</span>' +
          '<span class="nav-group-chevron">▶</span>' +
        '</div>' +
        '<div class="nav-subitems">' +
          visibleSub.map(function(s){
            return '<div class="nav-subitem' + (activeSub === s.key ? ' active' : '') + '" onclick="switchViewSubTab_(\'' + m.key + '\', \'' + s.key + '\')">' + escapeHtml(s.label) + '</div>';
          }).join('') +
        '</div>' +
      '</div>';
    }
    return '<div class="nav-item' + (m.key === activeView ? ' active' : '') + '" data-view="' + m.key + '" onclick="switchView(\'' + m.key + '\')">' +
      '<span class="nav-icon">' + m.icon + '</span> ' + escapeHtml(m.label) + '</div>';
  }).join('');

  bottomNav.innerHTML = items.map(function(m){
    return '<div class="bn-item' + (m.key === activeView ? ' active' : '') + '" data-view="' + m.key + '" onclick="switchView(\'' + m.key + '\')">' +
      '<span class="bn-icon">' + m.icon + '</span>' + escapeHtml(m.shortLabel) + '</div>';
  }).join('');

  return activeView;
}

// Merender sidebar + bottom-nav untuk mode publik, mengikuti menuPublik
// dari server (default hanya Dashboard). Menu lain yang mungkin diizinkan
// Admik untuk publik di masa depan akan menampilkan ajakan login, karena
// datanya memang perlu login untuk diakses lengkap.
function renderPublicNav_(allowed, activeView){
  allowed = (allowed && allowed.length) ? allowed : ['dashboard'];
  var items = MENU_CONFIG.filter(function(m){ return allowed.indexOf(m.key) > -1; });
  if(!items.length) items = [MENU_CONFIG[0]];

  var sidebar = document.getElementById('publicSidebar');
  var bottomNav = document.getElementById('publicBottomNav');
  if(!sidebar) return;

  sidebar.innerHTML = items.map(function(m){
    return '<div class="nav-item' + (m.key === activeView ? ' active' : '') + '" data-view="' + m.key + '" onclick="switchPublicView(\'' + m.key + '\')">' +
      '<span class="nav-icon">' + m.icon + '</span> ' + escapeHtml(m.label) + '</div>';
  }).join('');

  if(bottomNav){
    bottomNav.innerHTML = items.map(function(m){
      return '<div class="bn-item' + (m.key === activeView ? ' active' : '') + '" data-view="' + m.key + '" onclick="switchPublicView(\'' + m.key + '\')">' +
        '<span class="bn-icon">' + m.icon + '</span>' + escapeHtml(m.shortLabel) + '</div>';
    }).join('');
  }
}

// Menampilkan siapa yang sedang login di pojok kanan atas (nama + badge
// role), supaya jelas sedang masuk sebagai Admin / Petugas / role lain.
function renderTopbarUser_(){
  if(!STATE.session) return;
  var nameEl = document.getElementById('topbarUserName');
  var roleEl = document.getElementById('topbarUserRole');
  var logoutBtn = document.getElementById('btnLogoutIcon');
  var loginBtn = document.getElementById('btnTopbarLogin');
  if(!nameEl || !roleEl) return;
  var role = STATE.session.role || '-';
  var rn = normalizeKeyClient_(role);
  var isPublic = rn === 'publik';

  if(isPublic){
    nameEl.textContent = '';
    roleEl.textContent = '👁️ Mode Publik';
    roleEl.className = 'role-badge role-publik';
    if(logoutBtn) logoutBtn.style.display = 'none';
    if(loginBtn) loginBtn.style.display = '';
    return;
  }

  var cls = rn === 'admin' ? 'role-admin' : (rn === 'petugas' ? 'role-petugas' : 'role-lainnya');
  nameEl.textContent = STATE.session.nama || STATE.session.username || '';
  roleEl.textContent = role;
  roleEl.className = 'role-badge ' + cls;
  if(logoutBtn) logoutBtn.style.display = '';
  if(loginBtn) loginBtn.style.display = 'none';
}

function handleLogout(){
  openConfirm('Yakin akan keluar?', function(){
    closeModal('modalConfirm');
    var btn = document.getElementById('btnLogoutIcon');
    if(btn) btn.style.pointerEvents = 'none';
    callServer('logout', STATE.token).then(function(){
      finishLogout_();
    }).catch(function(){
      finishLogout_();
    });
  }, 'Ya, Keluar', 'Batal');
}

// Membersihkan sesi lokal lalu langsung pindah ke Tampilan Publik tanpa
// perlu memuat ulang halaman (instan, tidak ada jeda refresh).
function finishLogout_(){
  localStorage_remove('ekoin_token');
  STATE.token = null;
  STATE.session = null;
  STATE.menuAllowed = null;
  STATE.currentView = null;
  var btn = document.getElementById('btnLogoutIcon');
  if(btn) btn.style.pointerEvents = '';
  showToast('Berhasil keluar.');
  showPublicScreen();
}

// ================= NAVIGATION =================
function switchView(viewName){
  if(STATE.menuAllowed && STATE.menuAllowed.indexOf(viewName) === -1){
    showToast('Menu ini tidak tersedia untuk akun Anda (' + (STATE.session ? STATE.session.role : '') + ').', 'error');
    return;
  }
  closeSidebar('appSidebar');
  STATE.currentView = viewName;
  // Kalau menu tujuan adalah grup ber-submenu (Laporan/Pengaturan), pastikan
  // grupnya otomatis expanded setiap kali kita PINDAH ke situ lewat jalur mana
  // pun (klik sub-menu, openProfileModal, load awal, dst). Toggle buka/tutup
  // manual (klik ulang header saat grup itu sudah aktif) ditangani terpisah
  // di onNavGroupHeaderClick_ dan tidak melewati baris ini.
  var groupCfg = MENU_CONFIG.filter(function(m){ return m.key === viewName; })[0];
  STATE_NAV_EXPANDED = {}; // tutup grup manapun yang lagi terbuka (mode accordion), termasuk saat pindah ke menu TANPA sub-menu
  if(groupCfg && groupCfg.subItems && groupCfg.subItems.length){
    STATE_NAV_EXPANDED[viewName] = true;
  }
  document.querySelectorAll('.view').forEach(function(v){ v.classList.remove('active'); });
  document.getElementById('view-' + viewName).classList.add('active');

  if(viewName === 'dashboard') renderDashboard();
  if(viewName === 'kotak') loadKotakView();
  if(viewName === 'setoran') loadSetoranView();
  if(viewName === 'kas') loadKasView();
  if(viewName === 'rkat') loadRkatView();
  if(viewName === 'pentasyarufan') loadPentasyarufanView();
  if(viewName === 'laporan') loadLaporanView();
  if(viewName === 'pengaturan') loadPengaturanView();

  // Render ulang sidebar SETELAH load-view di atas, supaya grup/sub-menu yang
  // benar (Laporan/Pengaturan) tersorot sesuai tab yang sedang aktif.
  renderAppNav_(STATE.menuAllowed || []);
  document.querySelectorAll('.bn-item[data-view]').forEach(function(n){
    n.classList.toggle('active', n.dataset.view === viewName);
  });
}

function populateDusunSelects(){
  var selects = ['setoranFilterDusun','kotakFilterDusun','kotakDusun','laporanDusun'];
  selects.forEach(function(id){
    var el = document.getElementById(id);
    if(!el) return;
    var keepFirst = el.options.length ? el.options[0].outerHTML : '';
    el.innerHTML = keepFirst;
    STATE.dusunList.forEach(function(d){
      var opt = document.createElement('option');
      opt.value = d; opt.textContent = d;
      el.appendChild(opt);
    });
  });
}

</script>
<script>
// ================= DASHBOARD =================
function renderDashboard(){
  if(!STATE.dashboard) return;
  var d = STATE.dashboard;

  document.getElementById('statGrid').innerHTML =
    statCard('📦', 'Kotak Aktif', d.totalKotakAktif, d.totalKotak + ' total kotak') +
    statCard('🔓', 'Kotak Dibuka', d.totalKotakDibukaBulanIni, 'bulan ini') +
    statCard('👥', 'Setoran Bulan Ini', d.petugasSetorBulanIni, 'Petugas yg sudah setor', true) +
    statCard('🏦', 'Total Terkumpul', formatRupiah(d.totalNominalKeseluruhan), d.totalSemuaSetoran + ' transaksi', true) +
    statCard('🗺️', 'Jumlah Dusun', d.dusunAktifBulanIni, 'dusun aktif bulan ini') +
    (d.saldoKasUpzisnu !== null && d.saldoKasUpzisnu !== undefined ? statCard('💰', 'Saldo Kas UPZISNU', formatRupiah(d.saldoKasUpzisnu), 'saldo saat ini', true) : '') +
    (d.saldoKasBop !== null && d.saldoKasBop !== undefined ? statCard('💼', 'Saldo Kas BOP', formatRupiah(d.saldoKasBop), 'saldo saat ini') : '');

  renderTrendChart(d.trend);
  renderDusunBreakdown(d.perDusun);
  renderTopKotak(d.topKotak);
  renderRecentSetoran(STATE.setoranRecent || []);
}

function statCard(icon, label, value, sub, gold){
  return '<div class="stat-card ' + (gold?'gold':'') + '">' +
    '<div class="stat-icon">' + icon + '</div>' +
    '<div class="stat-label">' + label + '</div>' +
    '<div class="stat-value">' + value + '</div>' +
    (sub ? '<div class="stat-sub">' + sub + '</div>' : '') +
    '</div>';
}

function renderTrendChart(trend){
  var ctx = document.getElementById('trendChart').getContext('2d');
  var labels = trend.map(function(t){ return t.label; });
  var data = trend.map(function(t){ return t.nominal; });

  if(STATE.trendChartInstance) STATE.trendChartInstance.destroy();
  STATE.trendChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'Nominal Setoran',
        data: data,
        backgroundColor: '#146c43',
        borderRadius: 6,
        maxBarThickness: 38
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { ticks: { callback: function(v){ return 'Rp ' + (v/1000) + 'rb'; } }, grid:{color:'#eef3f0'} },
        x: { grid: { display: false } }
      }
    }
  });
}

function renderDusunBreakdown(perDusun){
  var maxNominal = Math.max.apply(null, perDusun.map(function(p){ return p.nominal; }).concat([1]));
  var sorted = perDusun.slice().sort(function(a,b){ return b.nominal - a.nominal; });
  var html = sorted.map(function(p){
    var pct = Math.round((p.nominal / maxNominal) * 100);
    return '<div class="dusun-row">' +
      '<div class="dusun-row-head"><span>' + escapeHtml(p.dusun) + '</span><b>' + formatRupiah(p.nominal) + '</b></div>' +
      '<div class="progress-bg"><div class="progress-fill" style="width:' + pct + '%"></div></div>' +
      '</div>';
  }).join('');
  document.getElementById('dusunBreakdown').innerHTML = html || emptyState('Belum ada data setoran.');
}

function renderTopKotak(topKotak){
  if(!topKotak.length){
    document.getElementById('topKotakList').innerHTML = emptyState('Belum ada data.');
    return;
  }
  var html = topKotak.map(function(k, i){
    return '<div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid #f1f4f2;">' +
      '<div style="width:26px;height:26px;border-radius:50%;background:var(--emas-muda);color:var(--hijau-tua);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;">' + (i+1) + '</div>' +
      '<div style="flex:1;"><div style="font-size:13.5px;font-weight:600;">' + escapeHtml(k.nama) + '</div>' +
      '<div style="font-size:11.5px;color:var(--teks-muda);">' + escapeHtml(k.dusun) + ' · ' + k.jumlahSetor + 'x setor</div></div>' +
      '<div style="font-weight:700;color:var(--hijau-tua);font-size:13px;">' + formatRupiah(k.total) + '</div>' +
      '</div>';
  }).join('');
  document.getElementById('topKotakList').innerHTML = html;
}

function renderRecentSetoran(list){
  if(!list.length){
    document.getElementById('recentSetoranList').innerHTML = emptyState('Belum ada setoran tercatat.');
    return;
  }
  var html = list.map(function(s){
    return '<div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid #f1f4f2;">' +
      '<div style="width:34px;height:34px;border-radius:10px;background:var(--hijau-muda);display:flex;align-items:center;justify-content:center;font-size:15px;">🪙</div>' +
      '<div style="flex:1;"><div style="font-size:13.5px;font-weight:600;">' + escapeHtml(s.nama) + '</div>' +
      '<div style="font-size:11.5px;color:var(--teks-muda);">' + formatTanggalIndo(s.tanggal) + ' · ' + escapeHtml(s.dusun) + '</div></div>' +
      '<div style="font-weight:700;color:var(--hijau-tua);font-size:13px;">' + formatRupiah(s.jumlah) + '</div>' +
      '</div>';
  }).join('');
  document.getElementById('recentSetoranList').innerHTML = html;
}

function emptyState(msg){
  return '<div class="empty-state"><div class="empty-icon">🗂️</div>' + msg + '</div>';
}

function loadDashboard(){
  callServer('getDashboardStats', STATE.token).then(function(res){
    if(res && res.success){
      STATE.dashboard = res.data;
      renderDashboard();
      showToast('Dashboard diperbarui.');
    } else {
      showToast((res && res.message) || 'Gagal memuat dashboard.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

</script>
<script>
// ================= KOTAK VIEW =================
function loadKotakView(){
  document.getElementById('kotakTableBody').innerHTML = '<tr><td colspan="8"><div class="loading-inline"><div class="spinner-sm"></div> Memuat data kotak...</div></td></tr>';
  callServer('getKotakList', STATE.token).then(function(res){
    if(res && res.success){
      STATE.kotakList = res.data;
      populateKotakPetugasFilter_();
      renderKotakTable();
    } else {
      showToast((res && res.message) || 'Gagal memuat data kotak.', 'error');
    }
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function populateKotakPetugasFilter_(){
  var sel = document.getElementById('kotakFilterPetugas');
  var current = sel.value;
  var petugasSet = {};
  STATE.kotakList.forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasSet[p] = true;
  });
  var petugasNames = Object.keys(petugasSet).sort();
  sel.innerHTML = '<option value="">Semua Petugas</option>' +
    petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">' + escapeHtml(p) + '</option>'; }).join('');
  if(current && petugasNames.indexOf(current) > -1) sel.value = current;
}

function renderKotakTable(){
  var btnTambah = document.getElementById('btnTambahKotak');
  var btnUpload = document.getElementById('btnUploadKotak');
  if(btnTambah) btnTambah.style.display = canDo('kotak', 'tambah') ? '' : 'none';
  if(btnUpload) btnUpload.style.display = canDo('kotak', 'upload') ? '' : 'none';

  var search = (document.getElementById('kotakSearch').value || '').toLowerCase();
  var filterDusun = document.getElementById('kotakFilterDusun').value;
  var filterPetugas = document.getElementById('kotakFilterPetugas').value;
  var filterStatus = document.getElementById('kotakFilterStatus').value;

  var filtered = STATE.kotakList.filter(function(k){
    var matchSearch = !search || (k.nama||'').toLowerCase().indexOf(search) > -1 || String(k.id||'').toLowerCase().indexOf(search) > -1;
    var matchDusun = !filterDusun || k.dusun === filterDusun;
    var matchPetugas = !filterPetugas || k.namaPetugas === filterPetugas;
    var matchStatus = !filterStatus || k.status === filterStatus;
    return matchSearch && matchDusun && matchPetugas && matchStatus;
  });

  if(!filtered.length){
    document.getElementById('kotakTableBody').innerHTML = '<tr><td colspan="8">' + emptyState('Tidak ada data kotak.') + '</td></tr>';
    return;
  }

  filtered.sort(function(a,b){ return (Number(a.noUrut)||0) - (Number(b.noUrut)||0); });

  var canEdit = canDo('kotak', 'edit');
  var canHapus = canDo('kotak', 'hapus');

  document.getElementById('kotakTableBody').innerHTML = filtered.map(function(k){
    var badgeClass = k.status === 'Aktif' ? 'badge-aktif' : 'badge-nonaktif';
    var aksi = (canEdit ? '<div class="icon-btn" onclick="editKotak(\'' + k.id + '\')" title="Edit">✏️</div>' : '') +
               (canHapus ? '<div class="icon-btn danger" onclick="confirmDeleteKotak(\'' + k.id + '\')" title="Hapus">🗑️</div>' : '');
    return '<tr>' +
      '<td>' + escapeHtml(k.noUrut) + '</td>' +
      '<td><b>' + escapeHtml(k.id) + '</b></td>' +
      '<td>' + escapeHtml(k.nama) + '</td>' +
      '<td>' + escapeHtml(k.alamat || '-') + '</td>' +
      '<td>' + escapeHtml(k.dusun) + '</td>' +
      '<td>' + escapeHtml(k.namaPetugas || '-') + '</td>' +
      '<td><span class="badge ' + badgeClass + '">' + escapeHtml(k.status) + '</span></td>' +
      '<td><div class="row-actions">' + (aksi || '<span style="color:var(--teks-muda);font-size:12px;">-</span>') + '</div></td>' +
      '</tr>';
  }).join('');
}

function populateKotakNamaPetugasDatalist_(){
  var dl = document.getElementById('kotakNamaPetugasList');
  var petugasSet = {};
  (STATE.kotakList || []).forEach(function(k){
    var p = (k.namaPetugas || '').trim();
    if(p) petugasSet[p] = true;
  });
  var petugasNames = Object.keys(petugasSet).sort();
  dl.innerHTML = petugasNames.map(function(p){ return '<option value="' + escapeHtml(p) + '">'; }).join('');
}

function openKotakModal(){
  document.getElementById('kotakModalTitle').textContent = 'Tambah Kotak Koin';
  document.getElementById('kotakId').value = '';
  document.getElementById('kotakNoKotak').value = '';
  document.getElementById('kotakNoKotak').disabled = false;
  document.getElementById('kotakNama').value = '';
  document.getElementById('kotakDusun').value = '';
  document.getElementById('kotakAlamat').value = '';
  document.getElementById('kotakNamaPetugas').value = '';
  document.getElementById('kotakStatusGroup').style.display = 'none';
  populateKotakNamaPetugasDatalist_();
  openModal('modalKotak');
}

function editKotak(id){
  var k = STATE.kotakList.find(function(x){ return x.id === id; });
  if(!k) return;
  document.getElementById('kotakModalTitle').textContent = 'Edit Kotak Koin';
  document.getElementById('kotakId').value = k.id;
  document.getElementById('kotakNoKotak').value = k.id;
  document.getElementById('kotakNoKotak').disabled = true; // No Kotak tidak diubah agar histori setoran tetap valid
  document.getElementById('kotakNama').value = k.nama;
  document.getElementById('kotakDusun').value = k.dusun;
  document.getElementById('kotakAlamat').value = k.alamat || '';
  document.getElementById('kotakNamaPetugas').value = k.namaPetugas || '';
  document.getElementById('kotakStatusGroup').style.display = 'block';
  document.getElementById('kotakStatus').value = k.status || 'Aktif';
  populateKotakNamaPetugasDatalist_();
  openModal('modalKotak');
}

function saveKotak(){
  var id = document.getElementById('kotakId').value;
  var noKotak = document.getElementById('kotakNoKotak').value.trim();
  var nama = document.getElementById('kotakNama').value.trim();
  var dusun = document.getElementById('kotakDusun').value;

  if(!noKotak || !nama || !dusun){
    showToast('No Kotak, Nama Pemegang, dan Dusun wajib diisi.', 'error');
    return;
  }

  var payload = {
    id: id || noKotak,
    noKotak: noKotak,
    nama: nama,
    dusun: dusun,
    alamat: document.getElementById('kotakAlamat').value.trim(),
    namaPetugas: document.getElementById('kotakNamaPetugas').value.trim(),
    status: document.getElementById('kotakStatus').value
  };

  var btn = document.getElementById('btnSaveKotak');
  setBtnLoading(btn, true, 'Menyimpan...');

  var fn = id ? 'updateKotak' : 'addKotak';
  callServer(fn, STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, 'Simpan');
    if(res && res.success){
      showToast(id ? 'Data kotak diperbarui.' : 'Kotak baru ditambahkan.');
      closeModal('modalKotak');
      loadKotakView();
      loadDashboard();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeleteKotak(id){
  openConfirm('Hapus kotak ' + id + '? Data setoran terkait tidak akan terhapus otomatis.', function(){
    callServer('deleteKotak', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Kotak dihapus.');
        loadKotakView();
        loadDashboard();
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ================= DATA KAS (KAS UPZISNU & KAS BOP) =================
var STATE_KAS_TAB = 'upzisnu';
var STATE_KAS_DATA = { UPZISNU: [], BOP: [] }; // selalu berisi data LENGKAP (belum difilter)
var STATE_RKAT_TAB = 'input';
var STATE_RKAT_DATA = []; // selalu berisi data LENGKAP (belum difilter), dipakai bersama oleh sub-tab Data & Realisasi

function loadKasView(){
  switchKasSubTab_(STATE_KAS_TAB);
}

function switchKasSubTab_(tab){
  STATE_KAS_TAB = tab;
  document.getElementById('kasUpzisnuSub').style.display = tab === 'upzisnu' ? 'block' : 'none';
  document.getElementById('kasBopSub').style.display = tab === 'bop' ? 'block' : 'none';
  document.getElementById('kasPencairanSub').style.display = tab === 'pencairan' ? 'block' : 'none';

  if(tab === 'pencairan'){
    document.getElementById('kasViewTitle').textContent = 'Rekap Pencairan Dana';
    document.getElementById('kasViewSubtitle').textContent = 'Catatan pencairan dana dari Kas UPZISNU maupun Kas BOP, lengkap dengan pelaksananya';
    loadPencairanList_();
    return;
  }

  var isBop = tab === 'bop';
  document.getElementById('kasViewTitle').textContent = isBop ? 'Data Kas BOP' : 'Data Kas UPZISNU';
  document.getElementById('kasViewSubtitle').textContent = isBop
    ? 'Rekap kas masuk & keluar untuk Kas BOP (Biaya Operasional)'
    : 'Rekap kas masuk & keluar untuk Kas UPZISNU';

  loadKasList_(isBop ? 'BOP' : 'UPZISNU');
}

function loadKasList_(jenisKas){
  callServer('getKasList', STATE.token, { jenisKas: jenisKas }).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat data kas.', 'error');
      return;
    }
    STATE_KAS_DATA[jenisKas] = res.data.rows;
    populateKasFilterDropdowns_(jenisKas);
    renderKasFiltered_(jenisKas);
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

// Bulan statis Jan-Des (bukan cuma 12 bulan terakhir seperti di Setoran Koin),
// karena Data Kas dimaksudkan untuk direkap lintas tahun juga — makanya
// filter Bulan & Tahun dipisah, bukan digabung kayak "Juli 2026".
function populateKasFilterDropdowns_(jenisKas){
  var prefix = jenisKas === 'BOP' ? 'kasBop' : 'kasUpzisnu';
  var bulanSel = document.getElementById(prefix + 'FilterBulan');
  var tahunSel = document.getElementById(prefix + 'FilterTahun');
  var jenisSel = document.getElementById(prefix + 'FilterJenis');
  var pertamaKali = bulanSel.options.length <= 1;

  if(pertamaKali){
    var bulanOpt = '<option value="">Semua Bulan</option>';
    MONTH_NAMES_ID.forEach(function(nama, idx){
      bulanOpt += '<option value="' + (idx + 1) + '">' + nama + '</option>';
    });
    bulanSel.innerHTML = bulanOpt;

    // Opsi filter Jenis mengikuti daftar Jenis yang sama dengan modal
    // Tambah/Edit, supaya bisa filter per kategori (Setoran Koin, Bagi Hasil
    // Bank, dll), bukan cuma Masuk/Keluar generik.
    var opsiJenis = KAS_JENIS_OPTIONS_[jenisKas] || ['Masuk', 'Keluar'];
    jenisSel.innerHTML = '<option value="">Semua Jenis</option>' +
      opsiJenis.map(function(o){ return '<option value="' + escapeHtml(o) + '">' + escapeHtml(o) + '</option>'; }).join('');
  }

  var currentTahun = tahunSel.value;
  var tahunSet = {};
  (STATE_KAS_DATA[jenisKas] || []).forEach(function(r){
    var y = String(r.tanggal || '').substring(0, 4);
    if(y) tahunSet[y] = true;
  });
  tahunSet[String(new Date().getFullYear())] = true; // tahun berjalan selalu ada, meski belum ada data
  var tahunList = Object.keys(tahunSet).sort().reverse();
  tahunSel.innerHTML = '<option value="">Semua Tahun</option>' +
    tahunList.map(function(y){ return '<option value="' + y + '">' + y + '</option>'; }).join('');

  if(pertamaKali){
    // Default tampilan: bulan & tahun BERJALAN (bukan "Semua Bulan/Tahun"),
    // supaya begitu dibuka langsung menunjukkan data bulan berjalan.
    var sekarang = new Date();
    bulanSel.value = String(sekarang.getMonth() + 1);
    var tahunBerjalan = String(sekarang.getFullYear());
    tahunSel.value = tahunList.indexOf(tahunBerjalan) > -1 ? tahunBerjalan : '';
  } else if(currentTahun && tahunList.indexOf(currentTahun) > -1){
    tahunSel.value = currentTahun;
  }
}

function renderKasFiltered_(jenisKas){
  var prefix = jenisKas === 'BOP' ? 'kasBop' : 'kasUpzisnu';
  var bulan = document.getElementById(prefix + 'FilterBulan').value; // '' atau '1'..'12'
  var tahun = document.getElementById(prefix + 'FilterTahun').value; // '' atau 'YYYY'
  var jenis = document.getElementById(prefix + 'FilterJenis').value; // '' / 'Masuk' / 'Keluar'

  var rows = (STATE_KAS_DATA[jenisKas] || []).filter(function(r){
    var tgl = String(r.tanggal || '');
    if(bulan && Number(tgl.substring(5, 7)) !== Number(bulan)) return false;
    if(tahun && tgl.substring(0, 4) !== tahun) return false;
    if(jenis && normalizeKeyClient_(r.jenisTransaksi) !== normalizeKeyClient_(jenis)) return false;
    return true;
  });

  var totalMasuk = 0, totalKeluar = 0;
  rows.forEach(function(r){
    // Apapun label Jenis-nya (Masuk, Setoran Koin, Bagi Hasil Bank, dll),
    // hanya yang persis "Keluar" dihitung sebagai pengeluaran.
    if(isJenisKeluarClient_(r.jenisTransaksi)) totalKeluar += r.nominal;
    else totalMasuk += r.nominal;
  });

  renderKasStatGrid_(jenisKas, { totalMasuk: totalMasuk, totalKeluar: totalKeluar, saldo: totalMasuk - totalKeluar });
  renderKasTable_(jenisKas, rows);

  // Info filter yang lagi aktif, ditampilkan di kop cetak PDF supaya jelas
  // laporan ini untuk periode/jenis apa.
  var teksBulan = bulan ? ('Bulan ' + MONTH_NAMES_ID[Number(bulan) - 1]) : 'Semua Bulan';
  var teksTahun = tahun ? ('Tahun ' + tahun) : 'Semua Tahun';
  var bagianInfo = [teksBulan + ' ' + teksTahun];
  if(jenis) bagianInfo.push('Jenis: ' + jenis);
  document.getElementById(prefix + 'PrintFilterInfo').textContent = bagianInfo.join(' • ');
}

// Menyusun & mencetak "Buku Kas" (saldo berjalan): urut tanggal naik, baris
// pertama = saldo pindahan dari sebelum periode yang difilter (kalau Bulan &
// Tahun sama-sama dipilih), lalu tiap baris transaksi menambah/mengurangi
// saldo berjalan di kolom paling kanan (menggantikan kolom Aksi yang memang
// tidak relevan di cetakan).
function cetakKasPDF_(jenisKas){
  var allRows = STATE_KAS_DATA[jenisKas] || [];
  if(!allRows.length){
    showToast('Belum ada data kas untuk dicetak.', 'error');
    return;
  }

  var prefix = jenisKas === 'BOP' ? 'kasBop' : 'kasUpzisnu';
  var bulan = document.getElementById(prefix + 'FilterBulan').value; // '' atau '1'..'12'
  var tahun = document.getElementById(prefix + 'FilterTahun').value; // '' atau 'YYYY'
  var jenis = document.getElementById(prefix + 'FilterJenis').value; // '' / 'Masuk' / 'Keluar'

  // Urutkan SEMUA data (bukan cuma yang lolos filter) tanggal naik, dipakai
  // untuk menghitung saldo berjalan yang akurat sejak transaksi paling awal.
  var semuaUrut = allRows.slice().sort(function(a, b){
    if(a.tanggal !== b.tanggal) return a.tanggal < b.tanggal ? -1 : 1;
    return String(a.timestamp || '') < String(b.timestamp || '') ? -1 : 1;
  });

  // Saldo Pindahan Bulan Sebelumnya: cuma punya arti yang jelas kalau Bulan
  // & Tahun dua-duanya dipilih. Dihitung dari SEMUA transaksi sebelum
  // periode itu (bukan cuma yang lolos filter Jenis), supaya saldo
  // bawaannya tetap akurat walau lagi filter "Semua Jenis" atau "Masuk" saja.
  var saldoAwal = 0;
  var cutoff = null;
  if(bulan && tahun){
    cutoff = tahun + '-' + String(bulan).padStart(2, '0') + '-01';
    semuaUrut.forEach(function(r){
      if(r.tanggal < cutoff){
        saldoAwal += (isJenisKeluarClient_(r.jenisTransaksi) ? -r.nominal : r.nominal);
      }
    });
  }

  // Baris yang dicetak: ikuti filter Bulan/Tahun/Jenis yang aktif di layar,
  // tapi urut tanggal naik supaya kolom Saldo mengalir logis dari atas ke bawah.
  var rowsTercetak = semuaUrut.filter(function(r){
    var tgl = String(r.tanggal || '');
    if(bulan && Number(tgl.substring(5, 7)) !== Number(bulan)) return false;
    if(tahun && tgl.substring(0, 4) !== tahun) return false;
    if(jenis && normalizeKeyClient_(r.jenisTransaksi) !== normalizeKeyClient_(jenis)) return false;
    return true;
  });

  if(!rowsTercetak.length){
    showToast('Tidak ada data kas untuk filter ini.', 'error');
    return;
  }

  var noUrut = 1;
  var barisHtml = '';

  if(cutoff){
    barisHtml += '<tr>' +
      '<td>' + (noUrut++) + '</td>' +
      '<td>-</td>' +
      '<td>-</td>' +
      '<td style="font-style:italic;">Pindahan Saldo Bulan Sebelumnya</td>' +
      '<td style="text-align:right;">-</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(saldoAwal) + '</td>' +
      '</tr>';
  }

  var saldoJalan = saldoAwal;
  barisHtml += rowsTercetak.map(function(r){
    var isKeluar = isJenisKeluarClient_(r.jenisTransaksi);
    saldoJalan += isKeluar ? -r.nominal : r.nominal;
    var jenisColor = isKeluar ? 'var(--merah)' : 'var(--hijau)';
    return '<tr>' +
      '<td>' + (noUrut++) + '</td>' +
      '<td>' + formatTanggalIndo(r.tanggal) + '</td>' +
      '<td><span style="color:' + jenisColor + ';font-weight:700;">' + escapeHtml(r.jenisTransaksi) + '</span></td>' +
      '<td style="white-space:normal !important;word-break:break-word;">' + escapeHtml(r.keterangan || '-') + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.nominal) + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(saldoJalan) + '</td>' +
      '</tr>';
  }).join('');

  var bodyElId = jenisKas === 'BOP' ? 'kasBopPrintTableBody' : 'kasUpzisnuPrintTableBody';
  document.getElementById(bodyElId).innerHTML = barisHtml;

  var ttdTanggalEl = document.getElementById(prefix + 'TtdTanggal');
  if(ttdTanggalEl) ttdTanggalEl.textContent = 'Baleharjo, ' + formatTanggalIndo(todayInputValue_());

  window.print();
}

function renderKasStatGrid_(jenisKas, data){
  var elId = jenisKas === 'BOP' ? 'kasBopStatGrid' : 'kasUpzisnuStatGrid';
  document.getElementById(elId).innerHTML =
    statCard('⬇️', 'Total Masuk', formatRupiah(data.totalMasuk), '', true) +
    statCard('⬆️', 'Total Keluar', formatRupiah(data.totalKeluar)) +
    statCard('🏦', 'Saldo', formatRupiah(data.saldo), '', true);
}

function renderKasTable_(jenisKas, rows){
  var elId = jenisKas === 'BOP' ? 'kasBopTableBody' : 'kasUpzisnuTableBody';
  var body = document.getElementById(elId);
  if(!rows.length){
    body.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--teks-muda);padding:24px;">Tidak ada data kas ' + escapeHtml(jenisKas) + ' untuk filter ini.</td></tr>';
    return;
  }
  body.innerHTML = rows.map(function(r, idx){
    var isKeluar = isJenisKeluarClient_(r.jenisTransaksi);
    var jenisColor = isKeluar ? 'var(--merah)' : 'var(--hijau)';
    return '<tr>' +
      '<td>' + (idx + 1) + '</td>' +
      '<td>' + formatTanggalIndo(r.tanggal) + '</td>' +
      '<td><span style="color:' + jenisColor + ';font-weight:700;">' + escapeHtml(r.jenisTransaksi) + '</span></td>' +
      '<td>' + escapeHtml(r.keterangan || '-') + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.nominal) + '</td>' +
      '<td class="row-actions">' +
        (canDo(kasChildKeyClient_(jenisKas),'edit') ? '<button class="icon-btn" onclick="editKas(\'' + r.id + '\',\'' + jenisKas + '\')" title="Edit">✏️</button>' : '') +
        (canDo(kasChildKeyClient_(jenisKas),'hapus') ? '<button class="icon-btn" onclick="confirmDeleteKas(\'' + r.id + '\',\'' + jenisKas + '\')" title="Hapus">🗑️</button>' : '') +
      '</td>' +
      '</tr>';
  }).join('');
}

// Opsi dropdown "Jenis" di modal Tambah/Edit Kas — beda daftar untuk Kas
// UPZISNU vs Kas BOP. "Setoran Koin"/"Setoran BOP 20%"/"Bagi Hasil Bank"
// tetap tersimpan sebagai transaksi "Masuk" (supaya rekap Total Masuk/Keluar
// tidak berubah), tapi otomatis mengisi Keterangan dengan label tsb supaya
// petugas tidak perlu ketik manual.
var KAS_JENIS_OPTIONS_ = {
  UPZISNU: ['Masuk', 'Setoran Koin', 'Bagi Hasil Bank', 'Setor 50% Ke MWC', 'Setor 20% Ke BOP', 'Keluar'],
  BOP: ['Masuk', 'Setoran BOP 20%', 'Bagi Hasil Bank', 'Keluar']
};

// Label Jenis yang dianggap PENGELUARAN (Keluar) untuk keperluan hitung Total
// Masuk/Keluar & saldo berjalan — harus SAMA PERSIS dengan KELUAR_JENIS_LABELS_
// di Code.gs (backend), supaya angka di layar & PDF konsisten dengan backend.
var KELUAR_JENIS_LABELS_ = ['keluar', 'setor 50% ke mwc', 'setor 20% ke bop'];
function isJenisKeluarClient_(jenisTransaksi){
  return KELUAR_JENIS_LABELS_.indexOf(normalizeKeyClient_(jenisTransaksi)) > -1;
}

function isiJenisKasOptions_(jenisKas, selectedValue){
  var select = document.getElementById('kasJenisTransaksi');
  var opsi = KAS_JENIS_OPTIONS_[jenisKas] || ['Masuk', 'Keluar'];
  select.innerHTML = opsi.map(function(o){ return '<option value="' + escapeHtml(o) + '">' + escapeHtml(o) + '</option>'; }).join('');
  select.value = opsi.indexOf(selectedValue) > -1 ? selectedValue : 'Masuk';
}

function todayInputValue_(){
  var d = new Date();
  var m = String(d.getMonth() + 1).padStart(2, '0');
  var day = String(d.getDate()).padStart(2, '0');
  return d.getFullYear() + '-' + m + '-' + day;
}

function openKasModal(jenisKas){
  document.getElementById('kasModalTitle').textContent = 'Tambah Data Kas ' + jenisKas;
  document.getElementById('kasId').value = '';
  document.getElementById('kasJenisKas').value = jenisKas;
  document.getElementById('kasTanggal').value = todayInputValue_();
  isiJenisKasOptions_(jenisKas, 'Masuk');
  document.getElementById('kasKeterangan').value = '';
  document.getElementById('kasNominal').value = '';
  openModal('modalKas');
}

function editKas(id, jenisKas){
  var row = (STATE_KAS_DATA[jenisKas] || []).find(function(x){ return x.id === id; });
  if(!row) return;
  document.getElementById('kasModalTitle').textContent = 'Edit Data Kas ' + jenisKas;
  document.getElementById('kasId').value = row.id;
  document.getElementById('kasJenisKas').value = jenisKas;
  document.getElementById('kasTanggal').value = row.tanggal;
  isiJenisKasOptions_(jenisKas, row.jenisTransaksi);
  document.getElementById('kasKeterangan').value = row.keterangan || '';
  document.getElementById('kasNominal').value = formatAngka(row.nominal);
  openModal('modalKas');
}

function saveKas(){
  var id = document.getElementById('kasId').value;
  var jenisKas = document.getElementById('kasJenisKas').value;
  var tanggal = document.getElementById('kasTanggal').value;
  var jenisTransaksi = document.getElementById('kasJenisTransaksi').value;
  var keterangan = document.getElementById('kasKeterangan').value.trim();
  var nominal = parseRupiahInput_(document.getElementById('kasNominal').value);

  if(!tanggal || !keterangan || !nominal){
    showToast('Tanggal, Keterangan, dan Nominal wajib diisi.', 'error');
    return;
  }

  var payload = { id: id || undefined, jenisKas: jenisKas, tanggal: tanggal, jenisTransaksi: jenisTransaksi, keterangan: keterangan, nominal: nominal };
  var btn = document.getElementById('btnSaveKas');
  setBtnLoading(btn, true, 'Menyimpan...');

  var fn = id ? 'updateKas' : 'addKas';
  callServer(fn, STATE.token, payload).then(function(res){
    setBtnLoading(btn, false, null, 'Simpan');
    if(res && res.success){
      showToast(id ? 'Data kas diperbarui.' : 'Data kas ditambahkan.');
      closeModal('modalKas');
      loadKasList_(jenisKas);
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeleteKas(id, jenisKas){
  openConfirm('Hapus data kas ini? Tindakan ini tidak bisa dibatalkan.', function(){
    callServer('deleteKas', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Data kas dihapus.');
        loadKasList_(jenisKas);
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ================= REKAP PENCAIRAN DANA =================
var STATE_PENCAIRAN_DATA = []; // selalu berisi data LENGKAP (belum difilter)
var JENIS_KAS_LABEL_ = { UPZISNU: 'Kas UPZISNU', BOP: 'Kas BOP' };

function loadPencairanList_(){
  callServer('getPencairanDanaList', STATE.token).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat data pencairan dana.', 'error');
      return;
    }
    STATE_PENCAIRAN_DATA = res.data.rows;
    populatePencairanFilterDropdowns_();
    renderPencairanFiltered_();
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function populatePencairanFilterDropdowns_(){
  var bulanSel = document.getElementById('pencairanFilterBulan');
  var tahunSel = document.getElementById('pencairanFilterTahun');

  if(bulanSel.options.length <= 1){
    var bulanOpt = '<option value="">Semua Bulan</option>';
    MONTH_NAMES_ID.forEach(function(nama, idx){
      bulanOpt += '<option value="' + (idx + 1) + '">' + nama + '</option>';
    });
    bulanSel.innerHTML = bulanOpt;
  }

  var currentTahun = tahunSel.value;
  var tahunSet = {};
  STATE_PENCAIRAN_DATA.forEach(function(r){
    var y = String(r.tanggal || '').substring(0, 4);
    if(y) tahunSet[y] = true;
  });
  tahunSet[String(new Date().getFullYear())] = true;
  var tahunList = Object.keys(tahunSet).sort().reverse();
  tahunSel.innerHTML = '<option value="">Semua Tahun</option>' +
    tahunList.map(function(y){ return '<option value="' + y + '">' + y + '</option>'; }).join('');
  if(currentTahun && tahunList.indexOf(currentTahun) > -1) tahunSel.value = currentTahun;
}

function renderPencairanFiltered_(){
  var bulan = document.getElementById('pencairanFilterBulan').value;
  var tahun = document.getElementById('pencairanFilterTahun').value;
  var jenis = document.getElementById('pencairanFilterJenis').value;

  var rows = STATE_PENCAIRAN_DATA.filter(function(r){
    var tgl = String(r.tanggal || '');
    if(bulan && Number(tgl.substring(5, 7)) !== Number(bulan)) return false;
    if(tahun && tgl.substring(0, 4) !== tahun) return false;
    if(jenis && normalizeKeyClient_(r.jenisKas) !== normalizeKeyClient_(jenis)) return false;
    return true;
  });

  var total = rows.reduce(function(sum, r){ return sum + r.nominal; }, 0);
  document.getElementById('pencairanStatGrid').innerHTML =
    statCard('🧾', 'Total Pencairan', formatRupiah(total), rows.length + ' transaksi', true);

  renderPencairanTable_(rows);

  var bagianInfo = [];
  bagianInfo.push(bulan ? MONTH_NAMES_ID[Number(bulan) - 1] : 'Semua Bulan');
  bagianInfo.push(tahun || 'Semua Tahun');
  if(jenis) bagianInfo.push('Sumber: ' + (JENIS_KAS_LABEL_[jenis] || jenis));
  document.getElementById('pencairanPrintFilterInfo').textContent = bagianInfo.join(' • ');
}

var STATE_PENCAIRAN_SELECTED_ = {}; // { id: true } — dipakai untuk memilih kegiatan mana yang mau dibuatkan SP Pencairan / Kwitansi

function togglePilihSemuaPencairan_(el){
  document.querySelectorAll('#pencairanTableBody .pencairan-row-checkbox').forEach(function(cb){
    cb.checked = el.checked;
    STATE_PENCAIRAN_SELECTED_[cb.value] = el.checked;
  });
}

function onPilihPencairanChange_(id, el){
  if(el.checked) STATE_PENCAIRAN_SELECTED_[id] = true;
  else delete STATE_PENCAIRAN_SELECTED_[id];
  var semuaCb = document.querySelectorAll('#pencairanTableBody .pencairan-row-checkbox');
  var semuaCentang = semuaCb.length > 0 && Array.prototype.every.call(semuaCb, function(cb){ return cb.checked; });
  var checkAllEl = document.getElementById('pencairanCheckAll');
  if(checkAllEl) checkAllEl.checked = semuaCentang;
}

function renderPencairanTable_(rows){
  var body = document.getElementById('pencairanTableBody');
  if(!rows.length){
    body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--teks-muda);padding:24px;">Tidak ada data pencairan dana untuk filter ini.</td></tr>';
    return;
  }
  body.innerHTML = rows.map(function(r, idx){
    return '<tr>' +
      '<td class="pencairan-checkbox-col"><input type="checkbox" class="pencairan-row-checkbox" value="' + r.id + '" ' + (STATE_PENCAIRAN_SELECTED_[r.id] ? 'checked' : '') + ' onchange="onPilihPencairanChange_(\'' + r.id + '\', this)" style="width:16px;height:16px;"></td>' +
      '<td>' + (idx + 1) + '</td>' +
      '<td>' + formatTanggalIndo(r.tanggal) + '</td>' +
      '<td>' + escapeHtml(JENIS_KAS_LABEL_[r.jenisKas] || r.jenisKas) + '</td>' +
      '<td>' + escapeHtml(r.uraianKegiatan || '-') + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.nominal) + '</td>' +
      '<td>' + escapeHtml(r.namaPelaksana || '-') + '</td>' +
      '<td class="row-actions">' +
        '<button class="icon-btn" onclick="cetakSuratPerintahPencairan_(\'' + r.id + '\')" title="Cetak Surat Perintah Pencairan Dana">📄</button>' +
        (canDo('kas_pencairan','edit') ? '<button class="icon-btn" onclick="editPencairan(\'' + r.id + '\')" title="Edit">✏️</button>' : '') +
        (canDo('kas_pencairan','hapus') ? '<button class="icon-btn" onclick="confirmDeletePencairan(\'' + r.id + '\')" title="Hapus">🗑️</button>' : '') +
      '</td>' +
      '</tr>';
  }).join('');
}

// Tombol "🖨️ Cetak PDF Kwitansi": mencetak SATU kwitansi per kegiatan yang
// dicentang checkbox-nya di tabel (bukan lagi mencetak tabel rekap).
function cetakPencairanPDF_(){
  var idTerpilih = Object.keys(STATE_PENCAIRAN_SELECTED_).filter(function(id){ return STATE_PENCAIRAN_SELECTED_[id]; });
  if(!idTerpilih.length){
    showToast('Centang dulu kegiatan yang mau dibuatkan kwitansi di tabel.', 'error');
    return;
  }
  var rows = STATE_PENCAIRAN_DATA.filter(function(r){ return idTerpilih.indexOf(r.id) > -1; });
  cetakKwitansiUntukRows_(rows);
}

// Mengubah angka jadi tulisan terbilang Bahasa Indonesia (dipakai di
// Kwitansi, standar dokumen resmi keuangan).
function angkaKeTerbilang_(n){
  n = Math.floor(Math.abs(Number(n) || 0));
  if(n === 0) return 'nol';
  var satuan = ['', 'satu', 'dua', 'tiga', 'empat', 'lima', 'enam', 'tujuh', 'delapan', 'sembilan', 'sepuluh', 'sebelas'];
  function eja(x){
    if(x < 12) return satuan[x];
    if(x < 20) return eja(x - 10) + ' belas';
    if(x < 100) return eja(Math.floor(x / 10)) + ' puluh' + (x % 10 ? ' ' + eja(x % 10) : '');
    if(x < 200) return 'seratus' + (x % 100 ? ' ' + eja(x % 100) : '');
    if(x < 1000) return eja(Math.floor(x / 100)) + ' ratus' + (x % 100 ? ' ' + eja(x % 100) : '');
    if(x < 2000) return 'seribu' + (x % 1000 ? ' ' + eja(x % 1000) : '');
    if(x < 1000000) return eja(Math.floor(x / 1000)) + ' ribu' + (x % 1000 ? ' ' + eja(x % 1000) : '');
    if(x < 1000000000) return eja(Math.floor(x / 1000000)) + ' juta' + (x % 1000000 ? ' ' + eja(x % 1000000) : '');
    if(x < 1000000000000) return eja(Math.floor(x / 1000000000)) + ' miliar' + (x % 1000000000 ? ' ' + eja(x % 1000000000) : '');
    return eja(Math.floor(x / 1000000000000)) + ' triliun' + (x % 1000000000000 ? ' ' + eja(x % 1000000000000) : '');
  }
  var hasil = eja(n).trim().replace(/\s+/g, ' ');
  return hasil.charAt(0).toUpperCase() + hasil.slice(1);
}

// Membangun & mencetak satu KWITANSI per baris (kalau lebih dari satu,
// masing-masing di halaman terpisah), format sama seperti contoh: kop
// organisasi, "Telah diterima dari / Uang sebanyak / Guna membayar",
// kotak Terbilang, lalu tempat-tanggal & "Yang menerima" (nama dikosongkan
// untuk ditulis/ditandatangani manual, sama seperti kolom tanggal).
function cetakKwitansiUntukRows_(rows){
  var logoUrl = STATE_ORG_SETTINGS.logoUrl || '';
  var kop = '<div style="display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:10px;">' +
      (logoUrl ? '<img src="' + logoUrl + '" style="max-height:70px;flex-shrink:0;">' : '') +
      '<div style="text-align:center;">' +
        '<h2 style="font-size:15px;margin:0 0 1px;">PENGURUS RANTING NAHDLATUL ULAMA</h2>' +
        '<h2 style="font-size:14px;margin:0 0 2px;">DESA BALEHARJO</h2>' +
        '<p style="font-size:11px;font-weight:600;margin:2px 0;">Unit Pengelola Zakat Infaq Dan Shodaqoh</p>' +
        (STATE_ORG_SETTINGS.alamatSekretariat ? '<p style="font-size:10px;color:var(--teks-muda);margin:1px 0;">' + escapeHtml(STATE_ORG_SETTINGS.alamatSekretariat) + '</p>' : '') +
      '</div>' +
    '</div><hr style="border:none;border-top:2px solid #333;margin:8px 0 16px;">';

  document.getElementById('kwitansiPrintArea').innerHTML = rows.map(function(r, idx){
    var namaPenerima = r.penerimaDana ? escapeHtml(r.penerimaDana) : '.........................';
    var namaPenyerah = STATE_ORG_SETTINGS.namaBendahara ? escapeHtml(STATE_ORG_SETTINGS.namaBendahara) : '.........................';
    return '<div class="kwitansi-page"' + (idx < rows.length - 1 ? ' style="page-break-after:always;"' : '') + '>' +
      kop +
      '<h1 style="text-align:center;font-size:22px;letter-spacing:2px;margin:10px 0 26px;">KWITANSI</h1>' +
      '<table style="font-size:13px;width:100%;margin-bottom:16px;">' +
        '<tr><td style="width:150px;vertical-align:top;padding:4px 0;">Telah diterima dari</td><td style="width:14px;vertical-align:top;">:</td><td style="vertical-align:top;font-weight:700;">Pengurus UPZISNU Desa Baleharjo</td></tr>' +
        '<tr><td style="vertical-align:top;padding:4px 0;">Uang sebanyak</td><td style="vertical-align:top;">:</td><td style="vertical-align:top;font-weight:700;">Rp' + formatAngka(r.nominal) + ',00</td></tr>' +
        '<tr><td style="vertical-align:top;padding:4px 0;">Guna membayar</td><td style="vertical-align:top;">:</td><td style="vertical-align:top;font-weight:700;">' + escapeHtml(r.uraianKegiatan) + '</td></tr>' +
      '</table>' +
      '<table style="font-size:13px;width:100%;margin-bottom:24px;"><tr>' +
        '<td style="width:150px;vertical-align:top;">Terbilang</td><td style="width:14px;vertical-align:top;">:</td>' +
        '<td><div style="display:inline-block;background:#fce4c4;border:1px solid #d9a25c;border-radius:4px;padding:6px 18px;font-style:italic;">' + angkaKeTerbilang_(r.nominal) + ' rupiah</div></td>' +
      '</tr></table>' +
      '<p style="text-align:center;font-size:13px;margin-bottom:0;">Baleharjo, ...............................</p>' +
      // Dua tanda tangan otomatis: Bendahara (yang menyerahkan dana dari kas)
      // di kiri, dan penerima dana kegiatan ini (kalau diisi saat input
      // pencairan; kalau kosong, dibiarkan titik-titik untuk diisi manual) di kanan.
      '<div style="display:flex;justify-content:space-between;font-size:13px;margin-top:6px;">' +
        '<div style="text-align:center;width:45%;">' +
          'Yang menyerahkan' +
          '<div style="height:50px;"></div>' +
          '<div style="font-weight:700;text-decoration:underline;">' + namaPenyerah + '</div>' +
          '<div style="font-size:11px;color:var(--teks-muda);">Bendahara</div>' +
        '</div>' +
        '<div style="text-align:center;width:45%;">' +
          'Yang menerima' +
          '<div style="height:50px;"></div>' +
          '<div style="font-weight:700;text-decoration:underline;">' + namaPenerima + '</div>' +
        '</div>' +
      '</div>' +
    '</div>';
  }).join('');

  document.body.classList.add('print-mode-kwitansi');
  window.print();
  window.onafterprint = function(){
    document.body.classList.remove('print-mode-kwitansi');
    window.onafterprint = null;
  };
  setTimeout(function(){ document.body.classList.remove('print-mode-kwitansi'); }, 4000);
}

// Tombol toolbar "📃 Cetak SP Pencairan": kalau ada kegiatan yang dicentang
// checkbox-nya, cetak SATU surat berisi semua kegiatan yang dicentang itu
// (bisa lintas tanggal/pelaksana kalau memang sengaja dipilih begitu). Kalau
// belum ada yang dicentang, minta pilih dulu.
function cetakSpPencairanHandler_(){
  var idTerpilih = Object.keys(STATE_PENCAIRAN_SELECTED_).filter(function(id){ return STATE_PENCAIRAN_SELECTED_[id]; });
  if(!idTerpilih.length){
    showToast('Centang dulu kegiatan yang mau dimasukkan ke Surat Perintah Pencairan.', 'error');
    return;
  }
  var rows = STATE_PENCAIRAN_DATA.filter(function(r){ return idTerpilih.indexOf(r.id) > -1; });
  cetakSuratPerintahUntukRows_(rows, rows[0]);
}

// Ikon 📄 di satu baris: cetak SATU surat untuk kegiatan baris itu SAJA
// (tidak lagi otomatis menggabung baris lain yang tanggal/pelaksananya
// sama). Untuk menggabung beberapa kegiatan ke satu surat, centang
// checkbox-nya lalu pakai tombol toolbar "📃 Cetak SP Pencairan".
function cetakSuratPerintahPencairan_(id){
  var row = STATE_PENCAIRAN_DATA.find(function(x){ return x.id === id; });
  if(!row) return;
  cetakSuratPerintahUntukRows_([row], row);
}

// Nama, alamat, & label jabatan pengurus berdasarkan Jabatan Pelaksana yang
// dipilih saat input pencairan (Ketua/Sekretaris/Bendahara) — dipakai untuk
// mengisi bagian "Memerintahkan kepada" di Surat Perintah Pencairan supaya
// sesuai orang yang BENERAN ditugaskan, bukan selalu Bendahara. Kalau
// pelaksananya Ketua sendiri (Ketua mencairkan sendiri), datanya otomatis
// sama dengan penandatangan di atas — surat tetap valid dicetak.
function getPengurusByJabatan_(jabatan){
  var j = normalizeKeyClient_(jabatan);
  if(j === 'sekretaris'){
    return { nama: STATE_ORG_SETTINGS.namaSekretaris, alamat: STATE_ORG_SETTINGS.alamatSekretaris, label: 'Sekretaris' };
  }
  if(j === 'ketua'){
    return { nama: STATE_ORG_SETTINGS.namaKetua, alamat: STATE_ORG_SETTINGS.alamatKetua, label: 'Ketua' };
  }
  return { nama: STATE_ORG_SETTINGS.namaBendahara, alamat: STATE_ORG_SETTINGS.alamatBendahara, label: 'Bendahara' };
}

// Membangun & mencetak Surat Perintah Pencairan Dana resmi yang DITUJUKAN KE
// BANK/BMT dari kumpulan baris (bisa dari checkbox terpilih ATAU dari SATU
// baris via ikon 📄), dengan tabel kegiatan sesuai baris yang diberikan —
// satu surat bisa mencakup beberapa kegiatan sekaligus (lewat checkbox).
function cetakSuratPerintahUntukRows_(rows, acuanTanggal){
  // Rekening tujuan mengikuti jenis kas baris yang dipilih (Kas UPZISNU dan
  // Kas BOP bisa punya rekening berbeda, diatur di Pengaturan > Data
  // Rekening). Kalau kegiatan yang dicentang campur UPZISNU & BOP, dipakai
  // rekening dari baris PERTAMA sebagai acuan.
  var jenisKasAcuan = (rows[0] && rows[0].jenisKas) || 'UPZISNU';
  var isBop = normalizeKeyClient_(jenisKasAcuan) === 'bop';
  var namaBank = (isBop ? STATE_ORG_SETTINGS.namaBankBop : STATE_ORG_SETTINGS.namaBankUpzisnu) || 'KSPPS BMT';
  var alamatBank = isBop ? STATE_ORG_SETTINGS.alamatBankBop : STATE_ORG_SETTINGS.alamatBankUpzisnu;
  var nomorRekening = isBop ? STATE_ORG_SETTINGS.nomorRekeningBop : STATE_ORG_SETTINGS.nomorRekeningUpzisnu;
  var atasNamaRekening = isBop ? STATE_ORG_SETTINGS.atasNamaRekeningBop : STATE_ORG_SETTINGS.atasNamaRekeningUpzisnu;

  document.getElementById('spPencairanNamaBank').textContent = namaBank;
  document.getElementById('spPencairanNamaBank2').textContent = namaBank + (alamatBank ? (' ' + alamatBank) : '');
  document.getElementById('spPencairanNoRek').textContent = nomorRekening || '..................................';
  document.getElementById('spPencairanAtasNama').textContent = atasNamaRekening || '..................................';

  var tanggalSurat = (acuanTanggal && acuanTanggal.tanggal) || todayInputValue_();
  document.getElementById('spPencairanTanggalSurat').textContent = formatTanggalIndo(tanggalSurat);
  document.getElementById('spPencairanNamaKetua').textContent = STATE_ORG_SETTINGS.namaKetua || '.........................';
  document.getElementById('spPencairanAlamatKetua').textContent = STATE_ORG_SETTINGS.alamatKetua || '-';

  // "Memerintahkan kepada" mengikuti Jabatan Pelaksana yang sebenarnya
  // dipilih (bisa Bendahara, Sekretaris, bahkan Ketua sendiri).
  var pelaksana = getPengurusByJabatan_((acuanTanggal && acuanTanggal.namaPelaksana) || (rows[0] && rows[0].namaPelaksana));
  document.getElementById('spPencairanNamaBendahara').textContent = pelaksana.nama || '.........................';
  document.getElementById('spPencairanJabatanPelaksana').textContent = pelaksana.label + ' UPZISNU-CARE LAZISNU Desa Baleharjo';
  document.getElementById('spPencairanAlamatBendahara').textContent = pelaksana.alamat || '-';

  document.getElementById('spPencairanTtdKetuaNama').textContent = STATE_ORG_SETTINGS.namaKetua || '.........................';

  var totalAnggaran = 0;
  document.getElementById('spPencairanKegiatanBody').innerHTML = rows.map(function(r, idx){
    totalAnggaran += r.nominal;
    return '<tr>' +
      '<td style="border:1px solid #333;padding:2px 4px;text-align:center;">' + (idx + 1) + '</td>' +
      '<td style="border:1px solid #333;padding:2px 4px;">' + escapeHtml(r.uraianKegiatan) + '</td>' +
      '<td style="border:1px solid #333;padding:2px 4px;text-align:right;">' + formatAngka(r.nominal) + '</td>' +
      '</tr>';
  }).join('');
  document.getElementById('spPencairanJumlahTotal').textContent = formatAngka(totalAnggaran);

  // Nomor surat urut mulai dari 1, terpisah untuk Kas UPZISNU vs Kas BOP,
  // reset tiap ganti tahun — dihitung dari POSISI KRONOLOGIS pencairan ini
  // sendiri di antara semua pencairan jenis kas & tahun yang sama (bukan
  // dari counter yang nambah tiap kali tombol cetak diklik), supaya
  // pencairan yang sama selalu dapat nomor yang SAMA persis walau dicetak
  // ulang berkali-kali.
  var tahunSurat = String(tanggalSurat).substring(0, 4) || String(new Date().getFullYear());
  var nomorUrut = hitungNomorSuratPencairan_(rows[0], jenisKasAcuan, tahunSurat);
  document.getElementById('spPencairanNomor').textContent = nomorUrut + '/Upzisnu Care-Lazisnu/Blhrjo/' + tahunSurat;

  document.body.classList.add('print-mode-surat');
  window.print();
  window.onafterprint = function(){
    document.body.classList.remove('print-mode-surat');
    window.onafterprint = null;
  };
  // Jaga-jaga kalau event afterprint tidak terpicu di browser tertentu.
  setTimeout(function(){ document.body.classList.remove('print-mode-surat'); }, 4000);
}

// Menentukan nomor urut SP Pencairan berdasarkan posisi kronologis pencairan
// (tanggal + pelaksana yang sama = satu "batch"/satu surat) di antara semua
// pencairan JENIS KAS & TAHUN yang sama — diurutkan dari yang paling awal.
// Deterministik: pencairan yang sama akan selalu dapat nomor yang sama,
// berapa kali pun tombol cetak diklik.
function hitungNomorSuratPencairan_(baris, jenisKas, tahun){
  var batchMap = {};
  STATE_PENCAIRAN_DATA.forEach(function(r){
    if(r.jenisKas !== jenisKas) return;
    if(String(r.tanggal).substring(0, 4) !== tahun) return;
    var key = r.tanggal + '|' + normalizeKeyClient_(r.namaPelaksana);
    if(!batchMap[key]) batchMap[key] = { tanggal: r.tanggal, key: key };
  });
  var daftarBatch = Object.keys(batchMap).map(function(k){ return batchMap[k]; }).sort(function(a, b){
    return a.tanggal < b.tanggal ? -1 : (a.tanggal > b.tanggal ? 1 : 0);
  });
  var kunciSekarang = baris.tanggal + '|' + normalizeKeyClient_(baris.namaPelaksana);
  var posisi = daftarBatch.findIndex(function(b){ return b.key === kunciSekarang; });
  return posisi > -1 ? posisi + 1 : daftarBatch.length + 1;
}

function openPencairanModal(){
  document.getElementById('pencairanModalTitle').textContent = 'Tambah Pencairan Dana';
  document.getElementById('pencairanId').value = '';
  document.getElementById('pencairanTanggal').value = todayInputValue_();
  document.getElementById('pencairanJenisKas').value = 'UPZISNU';
  document.getElementById('pencairanJabatan').value = '';
  for(var i = 1; i <= 5; i++){
    document.getElementById('pencairanUraian' + i).value = '';
    document.getElementById('pencairanNominal' + i).value = '';
    document.getElementById('pencairanPenerima' + i).value = '';
  }
  // Mode Tambah: semua 5 blok kegiatan ditampilkan (isi sesuai jumlah kegiatan
  // pada pencairan ini, sisanya boleh dikosongkan).
  document.getElementById('pencairanKegiatanExtra').style.display = 'block';
  document.getElementById('pencairanKegiatanHint').style.display = 'block';
  openModal('modalPencairan');
}

function editPencairan(id){
  var row = STATE_PENCAIRAN_DATA.find(function(x){ return x.id === id; });
  if(!row) return;
  document.getElementById('pencairanModalTitle').textContent = 'Edit Pencairan Dana';
  document.getElementById('pencairanId').value = row.id;
  document.getElementById('pencairanTanggal').value = row.tanggal;
  document.getElementById('pencairanJenisKas').value = row.jenisKas;
  document.getElementById('pencairanJabatan').value = row.namaPelaksana || '';
  document.getElementById('pencairanUraian1').value = row.uraianKegiatan || '';
  document.getElementById('pencairanNominal1').value = formatAngka(row.nominal);
  document.getElementById('pencairanPenerima1').value = row.penerimaDana || '';
  for(var i = 2; i <= 5; i++){
    document.getElementById('pencairanUraian' + i).value = '';
    document.getElementById('pencairanNominal' + i).value = '';
    document.getElementById('pencairanPenerima' + i).value = '';
  }
  // Mode Edit: satu record lama = satu kegiatan. Blok 2-5 disembunyikan
  // supaya tidak disangka bisa nambah kegiatan baru lewat edit ini.
  document.getElementById('pencairanKegiatanExtra').style.display = 'none';
  document.getElementById('pencairanKegiatanHint').style.display = 'none';
  openModal('modalPencairan');
}

function savePencairan(){
  var id = document.getElementById('pencairanId').value;
  var tanggal = document.getElementById('pencairanTanggal').value;
  var jenisKas = document.getElementById('pencairanJenisKas').value;
  var jabatan = document.getElementById('pencairanJabatan').value;

  if(!tanggal || !jabatan){
    showToast('Tanggal Pencairan dan Jabatan Pelaksana wajib diisi.', 'error');
    return;
  }

  var btn = document.getElementById('btnSavePencairan');

  if(id){
    // Mode Edit: 1 kegiatan saja, pakai endpoint lama seperti biasa.
    var uraian = document.getElementById('pencairanUraian1').value.trim();
    var nominal = parseRupiahInput_(document.getElementById('pencairanNominal1').value);
    if(!uraian || !nominal){
      showToast('Uraian Kegiatan dan Nominal wajib diisi.', 'error');
      return;
    }
    var payload = {
      id: id, tanggal: tanggal, jenisKas: jenisKas,
      uraianKegiatan: uraian, nominal: nominal, namaPelaksana: jabatan,
      penerimaDana: document.getElementById('pencairanPenerima1').value.trim()
    };
    setBtnLoading(btn, true, 'Menyimpan...');
    callServer('updatePencairanDana', STATE.token, payload).then(function(res){
      setBtnLoading(btn, false, null, 'Simpan');
      if(res && res.success){
        showToast('Data pencairan diperbarui.');
        closeModal('modalPencairan');
        loadPencairanList_();
      } else {
        showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
      }
    }).catch(function(err){
      setBtnLoading(btn, false, null, 'Simpan');
      showToast('Gagal: ' + err.message, 'error');
    });
    return;
  }

  // Mode Tambah: kumpulkan sampai 5 kegiatan, kirim sekaligus lewat batch.
  var kegiatan = [];
  for(var i = 1; i <= 5; i++){
    var u = document.getElementById('pencairanUraian' + i).value.trim();
    var n = parseRupiahInput_(document.getElementById('pencairanNominal' + i).value);
    var p = document.getElementById('pencairanPenerima' + i).value.trim();
    if(u && n) kegiatan.push({ uraianKegiatan: u, nominal: n, penerimaDana: p });
  }
  if(!kegiatan.length){
    showToast('Isi minimal Kegiatan 1 (Uraian Kegiatan + Nominal).', 'error');
    return;
  }

  var payloadBatch = { tanggal: tanggal, jenisKas: jenisKas, namaPelaksana: jabatan, kegiatan: kegiatan };
  setBtnLoading(btn, true, 'Menyimpan...');
  callServer('addPencairanDanaBatch', STATE.token, payloadBatch).then(function(res){
    setBtnLoading(btn, false, null, 'Simpan');
    if(res && res.success){
      showToast('Berhasil menyimpan ' + res.data.jumlahKegiatan + ' kegiatan pencairan.');
      closeModal('modalPencairan');
      loadPencairanList_();
    } else {
      showToast((res && res.message) || 'Gagal menyimpan data.', 'error');
    }
  }).catch(function(err){
    setBtnLoading(btn, false, null, 'Simpan');
    showToast('Gagal: ' + err.message, 'error');
  });
}

function confirmDeletePencairan(id){
  openConfirm('Hapus data pencairan dana ini? Tindakan ini tidak bisa dibatalkan.', function(){
    callServer('deletePencairanDana', STATE.token, id).then(function(res){
      closeModal('modalConfirm');
      if(res && res.success){
        showToast('Data pencairan dihapus.');
        loadPencairanList_();
      } else {
        showToast((res && res.message) || 'Gagal menghapus.', 'error');
      }
    }).catch(function(err){ closeModal('modalConfirm'); showToast('Gagal: ' + err.message, 'error'); });
  });
}

// ================= REKAP PENTASYARUFAN =================
var STATE_PENTASYARUFAN_DATA = []; // selalu berisi data LENGKAP (belum difilter)

function loadPentasyarufanView(){
  loadPentasyarufanList_();
}

function loadPentasyarufanList_(){
  callServer('getPentasyarufanList', STATE.token).then(function(res){
    if(!res || !res.success){
      showToast((res && res.message) || 'Gagal memuat data pentasyarufan.', 'error');
      return;
    }
    STATE_PENTASYARUFAN_DATA = res.data.rows;
    populatePentasyarufanFilterDropdowns_();
    renderPentasyarufanFiltered_();
  }).catch(function(err){ showToast('Gagal: ' + err.message, 'error'); });
}

function populatePentasyarufanFilterDropdowns_(){
  var bulanSel = document.getElementById('pentasyarufanFilterBulan');
  var tahunSel = document.getElementById('pentasyarufanFilterTahun');
  var isFirstLoad = bulanSel.options.length <= 1;

  if(isFirstLoad){
    var bulanOpt = '<option value="">Semua Bulan</option>';
    MONTH_NAMES_ID.forEach(function(nama, idx){
      bulanOpt += '<option value="' + (idx + 1) + '">' + nama + '</option>';
    });
    bulanSel.innerHTML = bulanOpt;
  }

  var currentTahun = tahunSel.value;
  var tahunSet = {};
  STATE_PENTASYARUFAN_DATA.forEach(function(r){
    var y = String(r.tanggal || '').substring(0, 4);
    if(y) tahunSet[y] = true;
  });
  var today_ = new Date();
  tahunSet[String(today_.getFullYear())] = true;
  var tahunList = Object.keys(tahunSet).sort().reverse();
  tahunSel.innerHTML = '<option value="">Semua Tahun</option>' +
    tahunList.map(function(y){ return '<option value="' + y + '">' + y + '</option>'; }).join('');

  if(isFirstLoad){
    // Default ke bulan & tahun BERJALAN begitu halaman dibuka, supaya rekap
    // yang langsung terlihat relevan tanpa perlu difilter manual dulu.
    bulanSel.value = String(today_.getMonth() + 1);
    tahunSel.value = String(today_.getFullYear());
  } else if(currentTahun && tahunList.indexOf(currentTahun) > -1){
    tahunSel.value = currentTahun;
  }
}

function renderPentasyarufanFiltered_(){
  var bulan = document.getElementById('pentasyarufanFilterBulan').value;
  var tahun = document.getElementById('pentasyarufanFilterTahun').value;

  var rows = STATE_PENTASYARUFAN_DATA.filter(function(r){
    var tgl = String(r.tanggal || '');
    if(bulan && Number(tgl.substring(5, 7)) !== Number(bulan)) return false;
    if(tahun && tgl.substring(0, 4) !== tahun) return false;
    return true;
  });

  var total = rows.reduce(function(sum, r){ return sum + r.nominal; }, 0);
  document.getElementById('pentasyarufanStatGrid').innerHTML =
    statCard('🎁', 'Total Pentasyarufan', formatRupiah(total), rows.length + ' penerima', true);

  renderPentasyarufanTable_(rows);

  var teksBulan = bulan ? ('Bulan ' + MONTH_NAMES_ID[Number(bulan) - 1]) : 'Semua Bulan';
  var teksTahun = tahun ? ('Tahun ' + tahun) : 'Semua Tahun';
  document.getElementById('pentasyarufanPrintFilterInfo').textContent = teksBulan + ' ' + teksTahun;
}

function renderPentasyarufanTable_(rows){
  var body = document.getElementById('pentasyarufanTableBody');
  if(!rows.length){
    body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--teks-muda);padding:24px;">Tidak ada data pentasyarufan untuk filter ini.</td></tr>';
    return;
  }
  body.innerHTML = rows.map(function(r, idx){
    var foto = r.fotoUrl
      ? '<a href="' + escapeHtml(r.fotoUrl) + '" target="_blank" rel="noopener"><img class="pentasyarufan-foto-thumb" src="' + escapeHtml(r.fotoUrl) + '" alt="Foto" style="width:44px;height:44px;object-fit:cover;border-radius:8px;border:1px solid #e1e8e4;"></a>'
      : '<span style="color:var(--teks-muda);font-size:12px;">-</span>';
    return '<tr>' +
      '<td>' + (idx + 1) + '</td>' +
      '<td>' + formatTanggalIndo(r.tanggal) + '</td>' +
      '<td>' + escapeHtml(r.namaKegiatan) + '</td>' +
      '<td>' + escapeHtml(r.namaPenerima) + '</td>' +
      '<td>' + escapeHtml(r.alamat || '-') + '</td>' +
      '<td style="text-align:right;font-weight:700;">' + formatRupiah(r.nominal) + '</td>' +
      '<td>' + foto + '</td>' +
      '<td class="row-actions pentasyarufan-aksi-cell">' +
        (canDo('pentasyarufan_rekap','edit') ? '<button class="icon-btn" onclick="editPentasyarufan(\'' + r.id + '\')" title="Edit">✏️</button>' : '') +
        (canDo('pentasyarufan_rekap','hapus') ? '<button class="icon-btn" onclick="confirmDeletePentasyarufan(\'' + r.id + '\')" title="Hapus">🗑️</button>' : '') +
      '</td>' +
      '</tr>';
  }).join('');
}

function cetakPentasyarufanPDF_(){
  if(!STATE_PENTASYARUFAN_DATA.length){
    showToast('Belum ada data pentasyarufan untuk dicetak.', 'error');
    return;
  }

  document.getElementById('pentasyarufanTtdKetua').textContent = STATE_ORG_SETTINGS.namaKetua || '.........................';
  document.getElementById('pentasyarufanTtdSekretaris').textContent = STATE_ORG_SETTINGS.namaSekretaris || '.........................';
  document.getElementById('pentasyarufanTtdBendahara').textContent = STATE_ORG_SETTINGS.namaBendahara || '.........................';
  document.getElementById('pentasyarufanTtdTanggal').textContent = 'Baleharjo, ' + formatTanggalIndo(todayInputValue_());

  window.print();
}


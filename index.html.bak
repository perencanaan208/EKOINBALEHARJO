<!-- ============ MODAL: EDIT SETORAN (Laporan - verifikasi Admin Utama) ============ -->
<div class="modal-overlay" id="modalEditLaporan">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Edit Data Setoran</h3>
      <div class="modal-close" onclick="closeModal('modalEditLaporan')">✕</div>
    </div>
    <input type="hidden" id="editLaporanId">

        <div id="uploadSummaryText" style="font-size:13px;font-weight:600;color:var(--hijau-tua);margin-bottom:8px;"></div>
        <div class="table-wrap" style="max-height:260px;overflow-y:auto;">
          <table>
            <thead><tr><th>No Kotak</th><th>Nama Pemegang</th><th>Dusun</th><th>Alamat</th><th>Petugas</th></tr></thead>
            <tbody id="uploadPreviewBody"></tbody>

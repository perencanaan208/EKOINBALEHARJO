              <button class="btn btn-outline" id="rkatBatalEditBtn" onclick="resetRkatInputForm_()" style="display:none;">Batal Edit</button>
              <button class="btn btn-primary" onclick="saveRkatHandler_()" style="flex:1;">💾 Simpan Rencana</button>
            </div>
